---
import '../styles/global.css';
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Model-agnostic AI agents, private AI infrastructure, and n8n automation. Transparent pricing, Vertex-first security, no vendor lock-in.',
  ogImage = `${Astro.site}og-image.svg`
} = Astro.props;

// Generate canonical URL using configured site
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- SEO -->
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: ogImage,
          url: canonicalURL,
        },
        optional: {
          description: description,
          siteName: 'intent solutions io',
        }
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: ogImage,
      }}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
