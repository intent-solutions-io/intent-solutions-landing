---
import '../styles/global.css';
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'independent ai consultant building automation systems and shipping real products. from automotive diagnostics to youth sports tracking.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- SEO -->
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: 'https://intentsolutions.io/og-image.jpg',
        },
        optional: {
          description: description,
          siteName: 'intent solutions io',
        }
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: 'https://intentsolutions.io/og-image.jpg',
      }}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
