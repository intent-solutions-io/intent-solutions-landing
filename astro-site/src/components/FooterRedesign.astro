<style>
  .footer {
    background-color: rgb(var(--color-bg-secondary));
    border-top: 1px solid rgb(var(--color-border));
    margin-top: auto;
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
  }

  /* Footer Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Brand Section */
  .footer-brand {
    margin-bottom: 0.5rem;
  }

  .footer-logo {
    font-size: 1.125rem;
    font-weight: 700;
    color: rgb(var(--color-text-primary));
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: rgb(var(--color-text-tertiary));
    font-style: italic;
    margin: 0;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-location {
    font-size: 0.875rem;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  .footer-email {
    font-size: 0.875rem;
    color: rgb(var(--color-accent-primary));
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-email:hover {
    color: rgb(var(--color-accent-hover));
  }

  /* Social Links */
  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: rgb(var(--color-text-tertiary));
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    color: rgb(var(--color-accent-primary));
    border-color: rgb(var(--color-accent-primary));
    transform: translateY(-2px);
  }

  /* Footer Headings */
  .footer-heading {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-text-primary));
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  /* Footer Links */
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links a {
    font-size: 0.9375rem;
    color: rgb(var(--color-text-secondary));
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: rgb(var(--color-accent-primary));
  }

  /* Footer Bottom */
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--color-border));
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .footer-copyright,
  .footer-note {
    font-size: 0.875rem;
    color: rgb(var(--color-text-tertiary));
    margin: 0;
  }
</style>
