---
/**
 * PageCTA — full-width CTA banner for bottom of service pages.
 *
 * Usage:
 *   <PageCTA
 *     title="Ready to get started?"
 *     description="Book a discovery call and we'll find the right fit for your team."
 *     primaryCTA={{ text: "Book a Discovery Call", href: "https://calendar.app.google/Wqbt8EJuEh5xvvV58" }}
 *     secondaryCTA={{ text: "Explore Plugins", href: "https://claudecodeplugins.io" }}
 *     note="No pressure, no pitch deck — just an honest conversation."
 *   />
 */

interface Props {
  title: string;
  description: string;
  primaryCTA?: { text: string; href: string; external?: boolean };
  secondaryCTA?: { text: string; href: string; external?: boolean };
  note?: string;
}

const {
  title,
  description,
  primaryCTA,
  secondaryCTA,
  note,
} = Astro.props;

const BOOKING_LINK = 'https://calendar.app.google/Wqbt8EJuEh5xvvV58';

const resolvedPrimary = primaryCTA ?? { text: 'Book a Discovery Call', href: BOOKING_LINK, external: true };
---

<section class="page-cta" aria-label="Call to action">
  <!-- Ambient glows -->
  <div class="cta-glow cta-glow--left"  aria-hidden="true"></div>
  <div class="cta-glow cta-glow--right" aria-hidden="true"></div>

  <!-- Top cyan accent rule -->
  <div class="cta-top-rule" aria-hidden="true"></div>

  <div class="cta-container">
    <!-- Eyebrow -->
    <div class="cta-eyebrow" aria-hidden="true">
      <span class="eyebrow-rule"></span>
      <span class="eyebrow-diamond">◆</span>
      <span class="eyebrow-rule"></span>
    </div>

    <h2 class="cta-title">{title}</h2>
    <p class="cta-description">{description}</p>

    <div class="cta-actions">
      <a
        href={resolvedPrimary.href}
        target={resolvedPrimary.external ? '_blank' : undefined}
        rel={resolvedPrimary.external ? 'noopener noreferrer' : undefined}
        class="cta-btn-primary"
      >
        {resolvedPrimary.text}
      </a>
      {secondaryCTA && (
        <a
          href={secondaryCTA.href}
          target={secondaryCTA.external ? '_blank' : undefined}
          rel={secondaryCTA.external ? 'noopener noreferrer' : undefined}
          class="cta-btn-secondary"
        >
          {secondaryCTA.text}
        </a>
      )}
    </div>

    {note && <p class="cta-note">{note}</p>}
  </div>
</section>

<style>
  .page-cta {
    position: relative;
    padding: 6rem 0;
    background: rgb(9 9 11); /* zinc-950 */
    border-top: 1px solid rgba(39, 39, 42, 0.5);
    overflow: hidden;
    text-align: center;
  }

  /* Top cyan accent */
  .cta-top-rule {
    position: absolute;
    top: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(34,211,238,0.35), transparent);
  }

  /* Ambient glows */
  .cta-glow {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(34,211,238,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-glow--left  { top: -20%; left: -8%; }
  .cta-glow--right { bottom: -20%; right: -8%; }

  .cta-container {
    position: relative;
    z-index: 1;
    max-width: 44rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Eyebrow */
  .cta-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .eyebrow-rule {
    display: block;
    height: 1px;
    width: 3rem;
    background: linear-gradient(to right, transparent, rgba(34,211,238,0.25));
  }

  .eyebrow-rule:last-child {
    background: linear-gradient(to left, transparent, rgba(34,211,238,0.25));
  }

  .eyebrow-diamond {
    font-size: 0.4rem;
    color: rgba(34,211,238,0.5);
    line-height: 1;
  }

  /* Title */
  .cta-title {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    color: rgb(250 250 250);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  /* Description */
  .cta-description {
    font-size: 1.05rem;
    color: rgb(161 161 170);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  /* Actions */
  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    background: rgb(34 211 238);
    color: rgb(9 9 11);
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
    box-shadow: 0 0 20px rgba(34,211,238,0.25);
  }

  .cta-btn-primary:hover {
    background: rgb(6 182 212);
    box-shadow: 0 0 30px rgba(34,211,238,0.4);
    transform: translateY(-1px);
  }

  .cta-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    background: transparent;
    color: rgb(212 212 216);
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid rgba(63, 63, 70, 0.8);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .cta-btn-secondary:hover {
    border-color: rgba(34,211,238,0.3);
    color: rgb(250 250 250);
  }

  /* Note */
  .cta-note {
    font-size: 0.85rem;
    color: rgb(82 82 91);
    margin-top: 0.75rem;
  }

  @media (max-width: 640px) {
    .page-cta { padding: 4.5rem 0; }

    .cta-actions {
      flex-direction: column;
      align-items: center;
    }

    .cta-btn-primary,
    .cta-btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
