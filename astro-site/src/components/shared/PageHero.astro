---
/**
 * PageHero — reusable hero for interior pages.
 *
 * Usage:
 *   <PageHero
 *     badge="For Teams"
 *     title="Learn with Jeremy"
 *     description="Executive onramps, leadership workshops, and team enablement."
 *     showCTAs
 *     primaryCTA={{ text: "Book a Discovery Call", href: "https://calendar.app.google/Wqbt8EJuEh5xvvV58" }}
 *     secondaryCTA={{ text: "Explore Plugins", href: "https://claudecodeplugins.io" }}
 *   />
 */

interface Props {
  badge: string;
  title: string;
  description: string;
  showCTAs?: boolean;
  primaryCTA?: { text: string; href: string; external?: boolean };
  secondaryCTA?: { text: string; href: string; external?: boolean };
}

const {
  badge,
  title,
  description,
  showCTAs = false,
  primaryCTA,
  secondaryCTA,
} = Astro.props;

const BOOKING_LINK = 'https://calendar.app.google/Wqbt8EJuEh5xvvV58';

// Default primary CTA always goes to discovery call
const resolvedPrimary = primaryCTA ?? { text: 'Book a Discovery Call', href: BOOKING_LINK, external: true };
---

<section class="page-hero" aria-label={title}>
  <!-- Ambient glow -->
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="hero-container">
    <!-- Eyebrow badge -->
    <div class="hero-badge-wrap">
      <span class="hero-badge-dot"></span>
      <span class="hero-badge">{badge}</span>
    </div>

    <!-- Title -->
    <h1 class="hero-title" set:html={title} />

    <!-- Cyan rule -->
    <div class="hero-rule" aria-hidden="true"></div>

    <!-- Description -->
    <p class="hero-description">{description}</p>

    <!-- CTAs -->
    {showCTAs && (
      <div class="hero-ctas">
        <a
          href={resolvedPrimary.href}
          target={resolvedPrimary.external ? '_blank' : undefined}
          rel={resolvedPrimary.external ? 'noopener noreferrer' : undefined}
          class="hero-btn-primary"
        >
          {resolvedPrimary.text}
        </a>
        {secondaryCTA && (
          <a
            href={secondaryCTA.href}
            target={secondaryCTA.external ? '_blank' : undefined}
            rel={secondaryCTA.external ? 'noopener noreferrer' : undefined}
            class="hero-btn-secondary"
          >
            {secondaryCTA.text}
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding: 7rem 0 5rem;
    background: rgb(9 9 11); /* zinc-950 */
    border-bottom: 1px solid rgba(39, 39, 42, 0.5);
    overflow: hidden;
    text-align: center;
  }

  /* Ambient cyan glow top-right */
  .hero-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    top: -20%;
    right: -10%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(34,211,238,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Badge */
  .hero-badge-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .hero-badge-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: rgb(34 211 238);
    box-shadow: 0 0 6px rgba(34,211,238,0.7);
    flex-shrink: 0;
  }

  .hero-badge {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgb(34 211 238);
    padding: 0.3rem 0.75rem;
    border: 1px solid rgba(34,211,238,0.2);
    border-radius: 2rem;
    background: rgba(34,211,238,0.04);
  }

  /* Title */
  .hero-title {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    color: rgb(250 250 250);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  /* Cyan rule */
  .hero-rule {
    width: 3rem;
    height: 1px;
    background: linear-gradient(to right, rgb(34 211 238), transparent);
    margin: 0 auto 1.5rem;
  }

  /* Description */
  .hero-description {
    font-size: clamp(1rem, 1.5vw, 1.175rem);
    color: rgb(161 161 170);
    line-height: 1.7;
    max-width: 42rem;
    margin: 0 auto 2.5rem;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: rgb(34 211 238);
    color: rgb(9 9 11);
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
    box-shadow: 0 0 20px rgba(34,211,238,0.25);
  }

  .hero-btn-primary:hover {
    background: rgb(6 182 212);
    box-shadow: 0 0 30px rgba(34,211,238,0.4);
    transform: translateY(-1px);
  }

  .hero-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: transparent;
    color: rgb(212 212 216);
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border: 1px solid rgba(63, 63, 70, 0.8);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .hero-btn-secondary:hover {
    border-color: rgba(34,211,238,0.3);
    color: rgb(250 250 250);
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: 5rem 0 4rem;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }

    .hero-btn-primary,
    .hero-btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
