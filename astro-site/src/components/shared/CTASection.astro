---
/**
 * CTASection — compact inline CTA block for mid-page use.
 * Lighter than PageCTA — use within section flows, not at page bottom.
 *
 * Usage:
 *   <CTASection
 *     title="Ready to Build Your AI System?"
 *     description="Tell us about your team and goals — we'll respond within 24 hours."
 *     ctaText="Start a Project"
 *     ctaHref="https://calendar.app.google/Wqbt8EJuEh5xvvV58"
 *   />
 */

interface Props {
  title: string;
  description: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  description,
  ctaText = 'Book a Discovery Call',
  ctaHref = 'https://calendar.app.google/Wqbt8EJuEh5xvvV58',
} = Astro.props;
---

<div class="cta-section" aria-label="Call to action">
  <div class="cta-inner">
    <div class="cta-text">
      <h2 class="cta-title" set:html={title} />
      <p class="cta-desc">{description}</p>
    </div>
    <a
      href={ctaHref}
      target="_blank"
      rel="noopener noreferrer"
      class="cta-btn"
    >
      {ctaText}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .cta-section {
    padding: 3.5rem 2rem;
    background: rgba(18, 18, 20, 0.7);
    border: 1px solid rgba(34, 211, 238, 0.12);
    border-radius: 1rem;
    backdrop-filter: blur(8px);
    margin: 2rem 0;
  }

  .cta-inner {
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-text {
    flex: 1;
    min-width: 0;
  }

  .cta-title {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: rgb(250 250 250);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .cta-desc {
    font-size: 0.9rem;
    color: rgb(113 113 122);
    line-height: 1.6;
    margin: 0;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: rgb(34 211 238);
    color: rgb(9 9 11);
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 0.5rem;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
    box-shadow: 0 0 16px rgba(34,211,238,0.2);
  }

  .cta-btn:hover {
    background: rgb(6 182 212);
    box-shadow: 0 0 24px rgba(34,211,238,0.35);
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .cta-section { padding: 2.5rem 1.5rem; }

    .cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
