---
// Services section with redesigned layout
---

<section class="services-section">
  <div class="container">
    <!-- Section Badge -->
    <span class="section-badge animate-on-scroll">
      <span class="badge-dot"></span>
      WHAT WE DO
    </span>

    <!-- Section Heading with Highlight -->
    <h2 class="section-title animate-on-scroll">
      AI Solutions That
      <span class="highlight-box">Transform</span>
      Your Business
    </h2>

    <p class="section-subtitle animate-on-scroll">
      From custom Claude Code setups to enterprise automation pipelines.
    </p>

    <!-- Service Cards Grid -->
    <div class="services-grid stagger-children">

      <!-- Card 1: Claude Code -->
      <a href="/claude-code" class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        </div>
        <h3>Claude Code Systems</h3>
        <p>Custom setups, plugin development, and team training for Claude Code workflows.</p>
        <span class="card-link">Learn more →</span>
      </a>

      <!-- Card 2: AI Agents -->
      <a href="/agents" class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 2l-4.2 4.2m13.2-5.2h-6m-6 0H1m13.2 5.2l-4.2-4.2m0-2L5.8 5.8"></path>
          </svg>
        </div>
        <h3>AI Agents</h3>
        <p>Custom Intent Agent Models designed for your specific workflow needs.</p>
        <span class="card-link">View packages →</span>
      </a>

      <!-- Card 3: Automation -->
      <a href="/automation" class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
        </div>
        <h3>Automation</h3>
        <p>n8n workflows that eliminate manual work and streamline operations.</p>
        <span class="card-link">See workflows →</span>
      </a>

      <!-- Card 4: Cloud & Data -->
      <a href="/cloud" class="service-card">
        <div class="service-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
          </svg>
        </div>
        <h3>Cloud & Data</h3>
        <p>Google Cloud-native architectures built for scale and reliability.</p>
        <span class="card-link">Explore services →</span>
      </a>

    </div>
  </div>
</section>

<style>
  .services-section {
    padding: var(--section-padding) 0;
    background: var(--bg-primary);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  /* Section Badge */
  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-secondary);
    border: 1px solid rgba(0, 0, 0, 0.1);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent-secondary);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.8;
    }
  }

  /* Section Title with Highlight */
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .highlight-box {
    display: inline-block;
    background-color: var(--color-highlight);
    color: var(--text-primary);
    padding: 0.25rem 1rem;
    border-radius: 0.5rem;
    margin: 0 0.25rem;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  /* Service Card */
  .service-card {
    background: var(--bg-primary);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-xl);
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: var(--transition-base);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-wave);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent-primary);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    flex-shrink: 0;
  }

  .service-icon svg {
    width: 24px;
    height: 24px;
    color: white;
    stroke-width: 2;
  }

  .service-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .service-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .card-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    transition: gap var(--transition-fast);
  }

  .service-card:hover .card-link {
    gap: 0.625rem;
  }

  @media (max-width: 768px) {
    .services-section {
      padding: 3rem 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .section-subtitle {
      font-size: 1rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .service-card {
      padding: 1.5rem;
    }
  }
</style>
