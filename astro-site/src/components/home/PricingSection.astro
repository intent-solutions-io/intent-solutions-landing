---
// Pricing Section with Dark Background and Flowing Teal Waves
---

<section class="pricing-section">
  <!-- Flowing Wave Background -->
  <div class="wave-background">
    <svg class="wave wave-1" viewBox="0 0 1440 320" preserveAspectRatio="none">
      <path fill="rgba(13, 148, 136, 0.3)" d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
    </svg>
    <svg class="wave wave-2" viewBox="0 0 1440 320" preserveAspectRatio="none">
      <path fill="rgba(20, 184, 166, 0.2)" d="M0,64L48,80C96,96,192,128,288,128C384,128,480,96,576,90.7C672,85,768,107,864,144C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
    </svg>
  </div>

  <div class="container">
    <!-- Section Header -->
    <div class="pricing-header animate-on-scroll">
      <span class="section-badge section-badge-dark">
        <span class="badge-dot"></span>
        PRICING
      </span>
      <h2 class="section-title section-title-light">
        Simple
        <span class="highlight-box">Flexible</span>
        Pricing.
      </h2>
      <p class="section-subtitle section-subtitle-light">
        Work short-term or long-term. Your choice.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="pricing-grid stagger-children">

      <!-- Starter -->
      <div class="pricing-card">
        <h3 class="tier-name">Starter</h3>
        <p class="tier-audience">Solo / Small Team</p>
        <div class="tier-price">
          <span class="price">Custom</span>
        </div>
        <p class="tier-description">Get up and running with Claude Code fast</p>
        <ul class="tier-features">
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Curated plugin pack for your stack
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Basic system setup and configuration
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            1-hour training session
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Setup documentation
          </li>
        </ul>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-pricing">Get Started</a>
      </div>

      <!-- Growth - Most Popular -->
      <div class="pricing-card popular">
        <span class="popular-badge">MOST POPULAR</span>
        <h3 class="tier-name">Growth</h3>
        <p class="tier-audience">Growing Teams</p>
        <div class="tier-price">
          <span class="price">Custom</span>
        </div>
        <p class="tier-description">Custom plugins and team-wide configuration</p>
        <ul class="tier-features">
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Everything in Starter
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Custom plugin development (up to 3)
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Team workflow optimization
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            4-hour training workshop
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            30-day support
          </li>
        </ul>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-pricing btn-pricing-primary">Get Started</a>
      </div>

      <!-- Scale -->
      <div class="pricing-card">
        <h3 class="tier-name">Scale</h3>
        <p class="tier-audience">Departments</p>
        <div class="tier-price">
          <span class="price">Custom</span>
        </div>
        <p class="tier-description">Full system build with ongoing support</p>
        <ul class="tier-features">
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Everything in Growth
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Complete system architecture
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Unlimited custom plugins
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Team training (up to 20 seats)
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            90-day support + check-ins
          </li>
        </ul>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-pricing">Get Started</a>
      </div>

      <!-- Enterprise -->
      <div class="pricing-card">
        <h3 class="tier-name">Enterprise</h3>
        <p class="tier-audience">Organization-wide</p>
        <div class="tier-price">
          <span class="price">Let's Talk</span>
        </div>
        <p class="tier-description">Custom everything with dedicated partnership</p>
        <ul class="tier-features">
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Everything in Scale
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Ongoing retainer relationship
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Quarterly workshops
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Priority development queue
          </li>
          <li>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            White-label options available
          </li>
        </ul>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-pricing">Get Started</a>
      </div>

    </div>

    <!-- Footer Note -->
    <p class="pricing-note animate-on-scroll">
      All tiers include access to <a href="https://claudecodeplugins.io" target="_blank">258+ open-source plugins</a>
    </p>

  </div>
</section>

<style>
  .pricing-section {
    position: relative;
    padding: var(--section-padding) 0;
    background: var(--bg-dark);
    overflow: hidden;
  }

  /* Wave Background */
  .wave-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40%;
  }

  .wave-1 {
    animation: wave-float 20s ease-in-out infinite;
  }

  .wave-2 {
    animation: wave-float 15s ease-in-out infinite reverse;
  }

  @keyframes wave-float {
    0%, 100% {
      transform: translateX(0) translateY(0);
    }
    50% {
      transform: translateX(-20px) translateY(10px);
    }
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* Dark Section Badges & Titles */
  .section-badge-dark {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-light);
  }

  .section-title-light {
    color: var(--text-light);
  }

  .section-subtitle-light {
    color: var(--text-light-muted);
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent-secondary);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.8;
    }
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .highlight-box {
    display: inline-block;
    background-color: var(--color-highlight);
    color: var(--text-primary);
    padding: 0.25rem 1rem;
    border-radius: 0.5rem;
    margin: 0 0.25rem;
  }

  .section-subtitle {
    font-size: 1.125rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Pricing Grid */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* Pricing Card */
  .pricing-card {
    background: var(--text-light);
    border-radius: var(--radius-xl);
    padding: 2rem;
    position: relative;
    transition: var(--transition-base);
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  /* Popular Card */
  .pricing-card.popular {
    border: 2px solid var(--color-accent-secondary);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent-secondary);
    color: var(--text-light);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .tier-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent-secondary);
    margin-bottom: 0.25rem;
  }

  .tier-audience {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .tier-price {
    margin-bottom: 0.5rem;
  }

  .tier-price .price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .tier-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .tier-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .tier-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .check-icon {
    width: 18px;
    height: 18px;
    color: var(--color-accent-secondary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Pricing Buttons */
  .btn-pricing {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-base);
    background: var(--bg-dark);
    color: var(--text-light);
  }

  .btn-pricing:hover {
    background: var(--bg-dark-lighter);
    transform: translateY(-2px);
  }

  .btn-pricing-primary {
    background: var(--color-accent-secondary);
  }

  .btn-pricing-primary:hover {
    background: #0f766e;
  }

  /* Footer Note */
  .pricing-note {
    text-align: center;
    margin-top: 2.5rem;
    font-size: 0.875rem;
    color: var(--text-light-muted);
    position: relative;
    z-index: 1;
  }

  .pricing-note a {
    color: var(--color-accent-tertiary);
    text-decoration: underline;
  }

  .pricing-note a:hover {
    color: var(--color-highlight);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .pricing-section {
      padding: 3rem 0;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .pricing-card {
      padding: 1.5rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .wave {
      height: 30%;
    }
  }
</style>
