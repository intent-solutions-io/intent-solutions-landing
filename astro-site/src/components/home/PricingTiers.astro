            </svg>
            <span>Dedicated account manager</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Custom SLA agreements</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>On-site training</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Security & compliance review</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Multi-region deployment</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Private cloud option</span>
          </li>
        </ul>

        <a href="#contact" class="tier-button">Contact Sales</a>
      </div>
    </div>

    <div class="pricing-footer">
      <p>All plans include 30 days of post-launch support. <a href="/pricing">View detailed pricing →</a></p>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 6rem 0;
    background-color: white;
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: rgb(var(--color-text-primary));
    margin-bottom: 1rem;
  }

  .section-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background-color: white;
    border: 2px solid rgb(var(--color-border));
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
    position: relative;
  }

  .pricing-card:hover {
    border-color: rgb(var(--color-accent-primary));
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .pricing-card.featured {
    border-color: rgb(var(--color-accent-primary));
    box-shadow: var(--shadow-md);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.375rem 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
    background: linear-gradient(135deg, rgb(var(--color-accent-primary)), rgb(67 56 202));
    border-radius: var(--radius-full);
  }

  .pricing-header {
    margin-bottom: 2rem;
  }

  .tier-name {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: rgb(var(--color-text-primary));
  }

  .tier-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .price-amount {
    font-size: 2.5rem;
    font-weight: 800;
    color: rgb(var(--color-accent-primary));
    line-height: 1;
  }

  .price-period {
    font-size: 0.875rem;
    color: rgb(var(--color-text-tertiary));
  }

  .tier-description {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgb(var(--color-text-secondary));
  }

  .feature-list {
    flex: 1;
    margin-bottom: 2rem;
    list-style: none;
    padding: 0;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
    font-size: 0.9375rem;
    color: rgb(var(--color-text-secondary));
  }

  .check-icon {
    flex-shrink: 0;
    margin-top: 0.125rem;
    color: rgb(var(--color-accent-primary));
  }

  .tier-button {
    display: block;
    width: 100%;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    color: white;
    background: linear-gradient(135deg, rgb(var(--color-accent-primary)), rgb(67 56 202));
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .tier-button:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .pricing-card:not(.featured) .tier-button {
    background: rgb(var(--color-text-primary));
  }

  .pricing-footer {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--color-border));
  }

  .pricing-footer p {
    font-size: 0.9375rem;
    color: rgb(var(--color-text-secondary));
  }

  .pricing-footer a {
    color: rgb(var(--color-accent-primary));
    font-weight: 600;
    text-decoration: none;
  }

  .pricing-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: 4rem 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .price-amount {
      font-size: 2rem;
    }
  }
</style>
