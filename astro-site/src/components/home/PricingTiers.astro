---
// Pricing Tiers section - 4 clean cards
---

<section class="pricing-section">
  <div class="container">
    <div class="section-header animate-on-scroll fade-up">
      <h2 class="section-title">Simple, Transparent Pricing</h2>
      <p class="section-description">
        Choose the package that fits your needs. All plans include setup, training, and ongoing support.
      </p>
    </div>

    <div class="pricing-grid stagger-children">
      <!-- Starter Tier -->
      <div class="pricing-card">
        <div class="pricing-header">
          <h3 class="tier-name">Starter</h3>
          <div class="tier-price">
            <span class="price-amount">$2,500</span>
            <span class="price-period">/one-time</span>
          </div>
          <p class="tier-description">Perfect for solo developers and small teams getting started.</p>
        </div>

        <ul class="feature-list">
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Claude Code setup</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>50+ essential plugins</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>2 hours training</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Email support (48hr)</span>
          </li>
          <li class="feature-item">
            <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>1 custom workflow</span>
          </li>
        </ul>

        <a href="#contact" class="tier-button">Get Started</a>
      </div>

      <!-- Growth Tier -->
      <div class="pricing-card featured">
        <div class="featured-badge">Most Popular</div>
