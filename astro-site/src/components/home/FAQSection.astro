---
const faqs = [
  {
    question: 'What exactly is a Claude Code setup?',
    answer:
      'I configure Claude Code for your specific tech stack, team size, and workflows. This includes custom CLAUDE.md files, curated plugin packs, slash commands, MCP server connections, and hooks—everything tuned so your team gets maximum value from day one.',
  },
  {
    question: 'Do I need to know how to code?',
    answer:
      'Not at all. The Learn track is specifically designed for decision-makers and team leads. I\'ll show you what Claude Code can do, how it fits your org, and what to watch for—no coding required.',
  },
  {
    question: 'What\'s included in the discovery call?',
    answer:
      'A 30-minute conversation where I learn about your team, workflows, and goals. I\'ll give honest recommendations on which tier makes sense—or if Claude Code isn\'t the right fit. No pressure, no pitch deck.',
  },
  {
    question: 'Can you work with teams outside the US?',
    answer:
      'Absolutely. I work with remote teams across all time zones. Sessions are scheduled around your availability, and all training materials are async-friendly.',
  },
  {
    question: 'What happens after the initial setup?',
    answer:
      'Every tier includes a support window (30–90 days depending on tier). I\'m available for questions, plugin tweaks, and workflow adjustments. Enterprise clients get ongoing retainer relationships with quarterly workshops.',
  },
  {
    question: 'How is this different from just reading the docs?',
    answer:
      'The docs tell you what buttons to press. I show you how to build systems that make your team faster. Custom plugins, team workflows, CI/CD integration, and training that sticks—things you won\'t find in any documentation.',
  },
];
---

<section id="faq" class="faq-section" aria-labelledby="faq-title">
  <div class="faq-container">

    <!-- Header -->
    <div class="faq-header">
      <div class="faq-eyebrow" aria-hidden="true">
        <span class="eyebrow-rule"></span>
        <span class="eyebrow-label">Common Questions</span>
        <span class="eyebrow-rule"></span>
      </div>
      <h2 id="faq-title" class="faq-title">frequently asked questions</h2>
      <p class="faq-subtitle">Everything you need to know before booking a call.</p>
    </div>

    <!-- FAQ list -->
    <div class="faq-list" role="list">
      {faqs.map((faq, index) => (
        <div class="faq-item" role="listitem" data-faq-index={index}>
          <button
            class="faq-trigger"
            aria-expanded="false"
            aria-controls={`faq-panel-${index}`}
            id={`faq-btn-${index}`}
          >
            <span class="faq-question">{faq.question}</span>
            <span class="faq-icon" aria-hidden="true">
              <!-- Plus icon -->
              <svg class="icon-plus" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <line x1="9" y1="2.5" x2="9" y2="15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="2.5" y1="9" x2="15.5" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <!-- Minus icon -->
              <svg class="icon-minus" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <line x1="2.5" y1="9" x2="15.5" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
          </button>

          <div
            class="faq-panel"
            id={`faq-panel-${index}`}
            role="region"
            aria-labelledby={`faq-btn-${index}`}
            hidden
          >
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer CTA -->
    <div class="faq-footer">
      <p class="faq-footer-text">Still have questions?</p>
      <a
        href="https://calendar.app.google/Wqbt8EJuEh5xvvV58"
        target="_blank"
        rel="noopener"
        class="faq-cta"
      >
        Book a discovery call
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .faq-section {
    padding: 7rem 0;
    background: rgb(24 24 27); /* zinc-900 */
    border-top: 1px solid rgba(39, 39, 42, 0.5);
  }

  .faq-container {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .faq-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .faq-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.2rem;
  }

  .eyebrow-rule {
    display: block;
    height: 1px;
    width: 3.5rem;
    background: linear-gradient(to right, transparent, rgba(34,211,238,0.2));
  }

  .eyebrow-rule:last-child {
    background: linear-gradient(to left, transparent, rgba(34,211,238,0.2));
  }

  .eyebrow-label {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgb(34 211 238);
  }

  .faq-title {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: rgb(250 250 250);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .faq-subtitle {
    font-size: 0.925rem;
    color: rgb(113 113 122);
  }

  /* ── FAQ list ── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* ── FAQ item ── */
  .faq-item {
    background: rgba(24, 24, 27, 0.6);
    border: 1px solid rgba(39, 39, 42, 0.6);
    border-radius: 0.75rem;
    backdrop-filter: blur(8px);
    overflow: hidden;
    transition: border-color 0.28s ease;
  }

  .faq-item:has(.faq-trigger[aria-expanded="true"]) {
    border-color: rgba(34, 211, 238, 0.22);
    background: rgba(18, 18, 20, 0.8);
  }

  /* ── Trigger ── */
  .faq-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s ease;
  }

  .faq-trigger:hover {
    background: rgba(39, 39, 42, 0.25);
  }

  .faq-trigger:focus-visible {
    outline: 2px solid rgba(34, 211, 238, 0.5);
    outline-offset: -2px;
    border-radius: 0.625rem;
  }

  /* ── Question text ── */
  .faq-question {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgb(212 212 216);
    line-height: 1.45;
    transition: color 0.2s ease;
  }

  .faq-trigger:hover .faq-question,
  .faq-trigger[aria-expanded="true"] .faq-question {
    color: rgb(250 250 250);
  }

  /* ── Icon ── */
  .faq-icon {
    flex-shrink: 0;
    color: rgb(82 82 91);
    transition: color 0.25s ease;
    position: relative;
    width: 18px;
    height: 18px;
  }

  .faq-trigger:hover .faq-icon {
    color: rgb(161 161 170);
  }

  .faq-trigger[aria-expanded="true"] .faq-icon {
    color: rgb(34 211 238);
  }

  .icon-plus,
  .icon-minus {
    position: absolute;
    inset: 0;
    transition: opacity 0.2s ease;
  }

  .icon-minus {
    opacity: 0;
  }

  .faq-trigger[aria-expanded="true"] .icon-plus {
    opacity: 0;
  }

  .faq-trigger[aria-expanded="true"] .icon-minus {
    opacity: 1;
  }

  /* ── Panel ── */
  .faq-panel {
    overflow: hidden;
  }

  .faq-panel[hidden] {
    display: none;
  }

  .faq-panel.is-animating {
    display: block !important;
  }

  /* ── Answer ── */
  .faq-answer {
    padding: 0 1.5rem 1.375rem;
    border-top: 1px solid rgba(34, 211, 238, 0.08);
    padding-top: 1.125rem;
  }

  .faq-answer p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgb(161 161 170);
    margin: 0;
  }

  /* ── Footer ── */
  .faq-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(39, 39, 42, 0.5);
    flex-wrap: wrap;
  }

  .faq-footer-text {
    font-size: 0.9rem;
    color: rgb(113 113 122);
    margin: 0;
  }

  .faq-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(34 211 238);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .faq-cta:hover {
    color: rgb(103 232 249); /* cyan-300 */
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .faq-section {
      padding: 5rem 0;
    }

    .faq-container {
      padding: 0 1.25rem;
    }

    .faq-trigger {
      padding: 1rem 1.25rem;
    }

    .faq-answer {
      padding: 0 1.25rem 1.125rem;
      padding-top: 1rem;
    }

    .faq-title {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  function setupFAQ() {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        const panelId = trigger.getAttribute('aria-controls');
        if (!panelId) return;
        const panel = document.getElementById(panelId);
        if (!panel) return;

        if (isExpanded) {
          collapse(trigger, panel);
        } else {
          // Close any open item
          triggers.forEach((other) => {
            if (other !== trigger && other.getAttribute('aria-expanded') === 'true') {
              const otherId = other.getAttribute('aria-controls');
              if (!otherId) return;
              const otherPanel = document.getElementById(otherId);
              if (otherPanel) collapse(other, otherPanel);
            }
          });
          expand(trigger, panel);
        }
      });
    });
  }

  function expand(trigger: HTMLButtonElement, panel: HTMLElement) {
    trigger.setAttribute('aria-expanded', 'true');
    panel.classList.add('is-animating');
    panel.removeAttribute('hidden');

    const targetHeight = panel.scrollHeight;
    panel.style.height = '0px';
    panel.offsetHeight; // force reflow

    panel.style.transition = 'height 0.32s cubic-bezier(0.22, 1, 0.36, 1)';
    panel.style.height = `${targetHeight}px`;

    panel.addEventListener('transitionend', () => {
      panel.style.height = '';
      panel.style.transition = '';
      panel.classList.remove('is-animating');
    }, { once: true });
  }

  function collapse(trigger: HTMLButtonElement, panel: HTMLElement) {
    trigger.setAttribute('aria-expanded', 'false');
    panel.classList.add('is-animating');

    const startHeight = panel.scrollHeight;
    panel.style.height = `${startHeight}px`;
    panel.offsetHeight;

    panel.style.transition = 'height 0.28s cubic-bezier(0.4, 0, 0.2, 1)';
    panel.style.height = '0px';

    panel.addEventListener('transitionend', () => {
      panel.setAttribute('hidden', '');
      panel.style.height = '';
      panel.style.transition = '';
      panel.classList.remove('is-animating');
    }, { once: true });
  }

  document.addEventListener('DOMContentLoaded', setupFAQ);
  document.addEventListener('astro:page-load', setupFAQ);
</script>
