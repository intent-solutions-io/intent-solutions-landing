---
const projects = [
  {
    name: 'Claude Code Plugins Hub',
    description:
      '270+ plugins with 1,537 agent skills, CCPI package manager, and interactive tutorials—1,550+ GitHub stars, 186 forks.',
    badge: 'Python · Open Source · 1,550★',
    link: 'https://github.com/jeremylongshore/claude-code-plugins-plus-skills',
    external: true,
  },
  {
    name: 'IRSB',
    description:
      'On-chain guardrails for AI agents—EIP-7702 spend limits, cryptographic execution receipts, and automated dispute resolution.',
    badge: 'TypeScript · Ethereum · EIP-7702',
    link: 'https://github.com/jeremylongshore/irsb',
    external: true,
  },
  {
    name: 'Moat',
    description:
      'Verified Agent Capabilities Marketplace—MCP-first trust, policy, and execution layer for agents.',
    badge: 'Python · MCP · Agent Trust',
    link: 'https://github.com/jeremylongshore/moat',
    external: true,
  },
  {
    name: "Bob's Brain",
    description:
      'Collaborative AI assistant—Google Gemini 2.5 Flash, Neo4j knowledge graphs, BigQuery analytics, Cloud Run deployment.',
    badge: 'Python · Gemini · Neo4j',
    link: 'https://github.com/jeremylongshore/bobs-brain',
    external: true,
  },
  {
    name: 'News Pipeline',
    description:
      'Automated monitoring that converts daily news into structured intelligence briefs for decision makers.',
    badge: 'n8n · AI Analysis · 10★',
    link: 'https://github.com/jeremylongshore/news-pipeline-n8n',
    external: true,
  },
  {
    name: 'DiagnosticPro',
    description:
      'Live automotive diagnostics for service centers—Vertex AI orchestrates triage while Firebase keeps technicians synced.',
    badge: 'TypeScript · React · Vertex AI',
    link: 'https://diagnosticpro.io',
    external: true,
  },
];
---

<section id="projects" class="showcase-section" aria-labelledby="showcase-title">
  <div class="container">
    <h2 id="showcase-title" class="section-title">products i've shipped</h2>

    <ul class="project-grid" role="list">
      {projects.map((project, index) => (
        <li class="project-card" data-index={index} role="listitem">
          <a
            href={project.link}
            target={project.external ? '_blank' : undefined}
            rel={project.external ? 'noopener noreferrer' : undefined}
            class="card-link"
            aria-label={`${project.name} — ${project.badge}`}
          >
            <div class="card-inner">
              <h3 class="project-name">{project.name}</h3>
              <p class="project-desc">{project.description}</p>
              <div class="card-footer">
                <span class="tech-badge">{project.badge}</span>
                <span class="view-link" aria-hidden="true">
                  view project
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .showcase-section {
    padding: 6rem 0;
    background: rgb(24 24 27); /* zinc-900 */
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-size: 2.5rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-weight: 700;
    color: rgb(250 250 250); /* zinc-50 */
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Scroll-reveal initial state */
  .project-card {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .card-link {
    display: block;
    height: 100%;
    text-decoration: none;
    border-radius: 0.75rem;
    /* Gradient border via background-clip trick */
    padding: 1px;
    background: rgb(39 39 42); /* zinc-800 — default border color */
    transition:
      background 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-link:hover {
    background: linear-gradient(135deg, rgb(63 63 70) 0%, rgb(82 82 91) 100%); /* zinc-700 → zinc-600 */
    box-shadow:
      0 8px 24px rgb(0 0 0 / 0.35),
      0 2px 8px rgb(0 0 0 / 0.2);
    transform: translateY(-3px);
  }

  .card-link:focus-visible {
    outline: 2px solid rgb(228 228 231); /* zinc-200 */
    outline-offset: 3px;
  }

  .card-inner {
    background: rgb(39 39 42 / 0.7); /* zinc-800 semi-transparent */
    backdrop-filter: blur(8px);
    border-radius: calc(0.75rem - 1px);
    padding: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: background 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-link:hover .card-inner {
    background: rgb(39 39 42 / 0.9);
  }

  .project-name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: rgb(250 250 250); /* zinc-50 */
    margin: 0 0 0.625rem;
    line-height: 1.4;
  }

  .project-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgb(161 161 170); /* zinc-400 */
    margin: 0 0 1.25rem;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .tech-badge {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgb(113 113 122); /* zinc-500 */
    background: rgb(24 24 27 / 0.6); /* zinc-900 */
    border: 1px solid rgb(63 63 70); /* zinc-700 */
    border-radius: 0.375rem;
    padding: 0.25rem 0.625rem;
    white-space: nowrap;
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .card-link:hover .tech-badge {
    border-color: rgb(82 82 91); /* zinc-600 */
    color: rgb(161 161 170); /* zinc-400 */
  }

  .view-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3125rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgb(113 113 122); /* zinc-500 */
    transition: color 0.2s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-link:hover .view-link {
    color: rgb(228 228 231); /* zinc-200 */
  }

  /* Tablet: 2 columns */
  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile: 1 column */
  @media (max-width: 640px) {
    .showcase-section {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1.25rem;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 2.5rem;
    }

    .project-grid {
      grid-template-columns: 1fr;
      gap: 0.875rem;
    }

    /* Disable lift on touch devices */
    .card-link:hover {
      transform: none;
    }
  }
</style>

<script>
  function setupShowcaseObserver() {
    const cards = document.querySelectorAll<HTMLElement>('.project-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const card = entry.target as HTMLElement;
            const index = parseInt(card.dataset.index ?? '0', 10);

            // Stagger delay by index
            setTimeout(() => {
              card.classList.add('revealed');
            }, index * 80);

            observer.unobserve(card);
          }
        });
      },
      {
        threshold: 0.1,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    cards.forEach((card) => observer.observe(card));
  }

  document.addEventListener('DOMContentLoaded', setupShowcaseObserver);
  document.addEventListener('astro:page-load', setupShowcaseObserver);
</script>
