---

<section id="projects" class="showcase-section" aria-labelledby="showcase-title">
  <div class="showcase-container">

    <!-- Section header -->
    <div class="showcase-header">
      <div class="showcase-eyebrow" aria-hidden="true">
        <span class="eyebrow-rule"></span>
        <span class="eyebrow-label">Open Source Work</span>
        <span class="eyebrow-rule"></span>
      </div>
      <h2 id="showcase-title" class="showcase-title">products i've shipped</h2>
      <p class="showcase-subtitle">Real systems built and deployed—not demos, not proofs of concept.</p>
    </div>

    <ul class="project-grid" role="list">
      {projects.map((project, index) => (
        <li class="project-card" data-index={index} role="listitem">
          <a
            href={project.link}
            target={project.external ? '_blank' : undefined}
            rel={project.external ? 'noopener noreferrer' : undefined}
            class="card-link"
            aria-label={`${project.name} — ${project.badge}`}
          >
            <!-- Gradient header panel -->
            <div class="card-visual" style={`background: ${project.gradient};`}>
              <!-- Grid pattern overlay -->
              <div class="card-grid-overlay" aria-hidden="true"></div>
              <!-- Project icon -->
              <div class="card-icon-wrap" style={`border-color: ${project.accentColor.replace('0.7)', '0.25)')};`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"
                  style={`color: ${project.accentColor};`}>
                  <path d={project.iconPath} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <!-- Corner accent -->
              <div class="card-corner-tl" aria-hidden="true"></div>
              <div class="card-corner-br" aria-hidden="true"></div>
            </div>

            <!-- Card body -->
            <div class="card-body">
              <h3 class="project-name">{project.name}</h3>
              <p class="project-desc">{project.description}</p>
              <div class="card-footer">
                <span class="tech-badge">{project.badge}</span>
                <span class="view-link" aria-hidden="true">
                  view
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </div>

            <!-- Hover border glow -->
            <div class="card-hover-border" aria-hidden="true"></div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .showcase-section {
    padding: 7rem 0;
    background: rgb(9 9 11); /* zinc-950 */
    border-top: 1px solid rgba(39, 39, 42, 0.5);
  }

  .showcase-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .showcase-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .showcase-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.2rem;
  }

  .eyebrow-rule {
    display: block;
    height: 1px;
    width: 3.5rem;
    background: linear-gradient(to right, transparent, rgba(34,211,238,0.2));
  }

  .eyebrow-rule:last-child {
    background: linear-gradient(to left, transparent, rgba(34,211,238,0.2));
  }

  .eyebrow-label {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgb(34 211 238);
  }

  .showcase-title {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: rgb(250 250 250);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .showcase-subtitle {
    font-size: 0.925rem;
    color: rgb(113 113 122);
  }

  /* ── Grid ── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Card scroll-reveal ── */
  .project-card {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Card link wrapper ── */
  .card-link {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    border-radius: 0.875rem;
    border: 1px solid rgba(39, 39, 42, 0.75);
    background: rgba(18, 18, 20, 0.85);
    backdrop-filter: blur(8px);
    overflow: hidden;
    transition:
      border-color 0.28s ease,
      box-shadow 0.28s ease,
      transform 0.22s ease;
  }

  .card-link:hover {
    border-color: rgba(34, 211, 238, 0.2);
    box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(34,211,238,0.04);
    transform: translateY(-3px);
  }

  .card-link:focus-visible {
    outline: 2px solid rgb(34 211 238);
    outline-offset: 3px;
  }

  /* ── Visual header panel ── */
  .card-visual {
    position: relative;
    height: 6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Subtle grid texture */
  .card-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.6;
  }

  /* Icon centered in visual */
  .card-icon-wrap {
    position: relative;
    z-index: 2;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.625rem;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(9, 9, 11, 0.45);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.22s ease, background 0.22s ease;
  }

  .card-link:hover .card-icon-wrap {
    transform: scale(1.08);
    background: rgba(9, 9, 11, 0.65);
  }

  /* Corner brackets (targeting-reticle style) */
  .card-corner-tl,
  .card-corner-br {
    position: absolute;
    width: 10px;
    height: 10px;
    z-index: 2;
  }

  .card-corner-tl {
    top: 8px;
    left: 8px;
    border-top: 1px solid rgba(255,255,255,0.12);
    border-left: 1px solid rgba(255,255,255,0.12);
  }

  .card-corner-br {
    bottom: 8px;
    right: 8px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    border-right: 1px solid rgba(255,255,255,0.12);
  }

  /* ── Card body ── */
  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    border-top: 1px solid rgba(39, 39, 42, 0.5);
  }

  .project-name {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: rgb(228 228 231);
    margin: 0 0 0.6rem;
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .card-link:hover .project-name {
    color: rgb(250 250 250);
  }

  .project-desc {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: rgb(113 113 122);
    margin: 0 0 1.25rem;
    flex: 1;
    transition: color 0.2s ease;
  }

  .card-link:hover .project-desc {
    color: rgb(161 161 170);
  }

  /* ── Card footer ── */
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .tech-badge {
    font-family: 'Syne', system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: rgb(82 82 91);
    background: rgba(39, 39, 42, 0.5);
    border: 1px solid rgba(63, 63, 70, 0.6);
    border-radius: 3px;
    padding: 0.22rem 0.5rem;
    white-space: nowrap;
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .card-link:hover .tech-badge {
    border-color: rgba(34, 211, 238, 0.2);
    color: rgb(113 113 122);
  }

  .view-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgb(63 63 70);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .card-link:hover .view-link {
    color: rgb(34 211 238);
  }

  /* ── Hover border glow (pseudo-element trick alternative) ── */
  .card-hover-border {
    display: none; /* Reserved for future gradient border effect */
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .showcase-section {
      padding: 5rem 0;
    }

    .showcase-container {
      padding: 0 1.25rem;
    }

    .project-grid {
      grid-template-columns: 1fr;
      gap: 0.875rem;
    }

    .card-link:hover {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function setupShowcaseObserver() {
    const cards = document.querySelectorAll<HTMLElement>('.project-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const card = entry.target as HTMLElement;
            const index = parseInt(card.dataset.index ?? '0', 10);
            setTimeout(() => card.classList.add('revealed'), index * 80);
            observer.unobserve(card);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((card) => observer.observe(card));
  }

  document.addEventListener('DOMContentLoaded', setupShowcaseObserver);
  document.addEventListener('astro:page-load', setupShowcaseObserver);
</script>
