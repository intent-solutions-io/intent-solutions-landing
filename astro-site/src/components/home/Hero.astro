---
// Synthesia-style hero section for homepage
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <!-- Pre-headline badge -->
      <div class="hero-badge">
        <span class="badge">AI Implementation Partners</span>
      </div>

      <!-- Main headline -->
      <h1 class="hero-headline">
        We Build AI Systems<br />That Actually Ship
      </h1>

      <!-- Subheadline -->
      <p class="hero-subheadline">
        From Claude Code setups to full automation pipelines. We turn AI ideas into production-ready systems with transparent pricing, enterprise security, and zero vendor lock-in.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-primary btn-xl">
          Start a Project
        </a>
        <a href="/learn" class="btn btn-outline btn-xl">
          Explore Plugins →
        </a>
      </div>

      <!-- Trust signals -->
      <div class="hero-trust">
        <span class="trust-item">No commitment</span>
        <span class="trust-divider">•</span>
        <span class="trust-item">24hr response</span>
        <span class="trust-divider">•</span>
        <span class="trust-item">258+ plugins</span>
      </div>
    </div>

    <!-- Hero visual -->
    <div class="hero-visual">
      <div class="visual-gradient"></div>
      <div class="visual-grid"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    background-color: white;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 2;
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 4rem 0;
  }

  /* Badge */
  .hero-badge {
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.025em;
    color: rgb(var(--color-accent-primary));
    background-color: rgb(var(--color-accent-light));
    border: 1px solid rgb(var(--color-accent-lighter));
    border-radius: var(--radius-full);
    transition: all var(--transition-base);
  }

  .badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.15);
  }

  /* Main headline */
  .hero-headline {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-text-primary));
    animation: fadeInUp 0.6s ease-out 0.1s backwards;
  }

  @media (max-width: 768px) {
    .hero-headline {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-headline {
      font-size: 4.5rem;
    }
  }

  /* Subheadline */
  .hero-subheadline {
    font-size: 1.25rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 3rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeInUp 0.6s ease-out 0.2s backwards;
  }

  @media (max-width: 768px) {
    .hero-subheadline {
      font-size: 1.125rem;
    }
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.6s ease-out 0.3s backwards;
  }

  .btn-xl {
    padding: 1rem 2rem;
    font-size: 1.0625rem;
    font-weight: 600;
  }

  .btn-outline {
    background-color: transparent;
    color: rgb(var(--color-text-primary));
    border: 2px solid rgb(var(--color-border));
  }

  .btn-outline:hover {
    background-color: rgb(var(--color-bg-secondary));
    border-color: rgb(var(--color-text-primary));
    transform: translateY(-2px);
  }

  /* Trust signals */
  .hero-trust {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.9375rem;
    color: rgb(var(--color-text-tertiary));
    animation: fadeInUp 0.6s ease-out 0.4s backwards;
  }

  .trust-item {
    font-weight: 500;
  }

  .trust-divider {
    color: rgb(var(--color-border));
  }

  /* Hero visual */
  .hero-visual {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .visual-gradient {
    position: absolute;
    top: -50%;
    right: -10%;
    width: 60%;
    height: 120%;
    background: radial-gradient(
      ellipse at center,
      rgba(79, 70, 229, 0.08) 0%,
      rgba(79, 70, 229, 0.03) 40%,
      transparent 70%
    );
    animation: float 20s ease-in-out infinite;
  }

  .visual-grid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.5;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      transform: translate(30px, -30px) rotate(5deg);
    }
    66% {
      transform: translate(-20px, 20px) rotate(-5deg);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .hero {
      min-height: 80vh;
    }

    .hero-content {
      padding: 3rem 0;
    }

    .hero-trust {
      font-size: 0.875rem;
      gap: 0.75rem;
    }

    .btn-xl {
      padding: 0.875rem 1.5rem;
      font-size: 1rem;
    }
  }
</style>
