---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/private-ai', label: 'Private AI' },
  { href: '/ai-agents', label: 'AI Agents' },
  { href: '/automation', label: 'Automation' },
  { href: '/cloud', label: 'Cloud & Data' },
];
---

<nav class="sticky top-0 z-50 backdrop-blur-md bg-zinc-950/70 border-b border-zinc-800/60">
  <div class="container mx-auto px-6 sm:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="text-sm font-semibold tracking-widest uppercase text-zinc-300">
        intent solutions io
      </a>
      <div class="hidden md:flex items-center gap-6">
        {
          links.map(({ href, label }) => (
            <a
              href={href}
              class="text-sm text-zinc-400 hover:text-zinc-100 transition-smooth"
            >
              {label}
            </a>
          ))
        }
        <a href="/#contact" class="btn-primary text-sm">
          Start a project
        </a>
      </div>
      <div class="md:hidden">
        <a href="/#contact" class="btn-primary text-sm">
          Start
        </a>
      </div>
    </div>
  </div>
</nav>
