---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="Cloud & Google Cloud Architecture - Intent Solutions">
  <!-- SECTION 1: Hero + Core Capabilities (IMAGE BACKGROUND) -->
  <section class="cloud-hero-capabilities">
    <div class="container">
      <!-- Hero Content -->
      <div class="hero-content">
        <span class="section-badge">Cloud & Data</span>
        <h1><span class="highlight-box">Google Cloud</span> foundations built for speed and safety</h1>
        <p>From Vertex AI pipelines to BigQuery analytics and Firebase backends, we build cloud systems that ship fast, stay compliant, and remain simple enough for your team to maintain.</p>
        <div class="hero-buttons">
          <a href="#contact" class="btn-primary">Schedule a Cloud Workshop</a>
          <a href="#capabilities" class="btn-secondary-light">View Capabilities</a>
        </div>
      </div>

      <!-- Capabilities Content -->
      <div class="capabilities-content" id="capabilities">
        <h2>Core <span class="highlight-box">Capabilities</span></h2>
        <p class="section-subtitle">End-to-end Google Cloud services optimized for AI, data, and modern application development</p>

        <div class="capabilities-grid">
          <div class="capability-card">
            <h3>Vertex AI Pipelines</h3>
            <p>Model training, evaluation, and deployment workflows with automated guardrails and rollback.</p>
          </div>

          <div class="capability-card">
            <h3>BigQuery Analytics</h3>
            <p>Data warehouses with dbt, scheduled transformations, and Looker Studio dashboards your ops team can trust.</p>
          </div>

          <div class="capability-card">
            <h3>Firebase / Firestore</h3>
            <p>Real-time application backends with security rules, multitenant support, and offline-first UX.</p>
          </div>

          <div class="capability-card">
            <h3>Cloud Run & Functions</h3>
            <p>Serverless APIs, cron jobs, and automation endpoints that scale without upkeep.</p>
          </div>

          <div class="capability-card">
            <h3>Identity & Access</h3>
            <p>IAM, service accounts, and workload identity federation configured to keep auditors happy.</p>
          </div>

          <div class="capability-card">
            <h3>Observability</h3>
            <p>Cloud Logging, Metrics, and Grafana dashboards wired from day one so issues surface immediately.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Engagement Blueprint + Why Operators Choose (NEW IMAGE BACKGROUND) -->
  <section class="engagement-operators-section">
    <div class="blueprint-content">
      <div class="container">
        <div class="blueprint-layout">
          <div class="blueprint-steps">
            <h2><span class="highlight-box">Engagement</span> Blueprint</h2>
            <ol>
              <li>Audit your current architecture and capture success metrics.</li>
              <li>Design reference architecture diagrams and IaC templates.</li>
              <li>Implement environments with CI/CD, testing, and monitoring hooks.</li>
              <li>Roll out to production with training for your engineers and operators.</li>
            </ol>
            <p class="timeline-note">Most foundations deploy within four weeks, with optional retained support for continuous optimization.</p>
          </div>

          <div class="tooling-box">
            <h3>Tooling We Lean On</h3>
            <ul>
              <li>Terraform, Pulumi, and Google Cloud Deploy for repeatable infrastructure.</li>
              <li>Cloud Build, GitHub Actions, and Artifact Registry for delivery pipelines.</li>
              <li>Secret Manager + KMS for key rotation and least privilege access.</li>
              <li>Cloud Armor, VPC Service Controls, and BeyondCorp for secure perimeters.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="operators-content">
      <div class="container">
        <h2>Why Operators Choose <span class="highlight-box">Intent Solutions</span></h2>
        <p class="section-subtitle">We build cloud foundations that empower your team to ship confidently and scale sustainably.</p>

        <div class="benefits-grid">
          <div class="benefit-card">
            <h3>Ship Fast, Stay Sane</h3>
            <p>We prioritize workable MVPs with clear handoff docs instead of sprawling multi-quarter projects.</p>
          </div>

          <div class="benefit-card">
            <h3>Operator-First Communication</h3>
            <p>Weekly syncs, shared Kanban boards, and transparent burn rates keep leadership aligned.</p>
          </div>

          <div class="benefit-card">
            <h3>Compliance Ready</h3>
            <p>Access policies, logging, and backup strategies tuned for HIPAA, SOC2, PCI, or CJIS environments.</p>
          </div>

          <div class="benefit-card">
            <h3>Handoff Without Drama</h3>
            <p>Internal teams get training, runbooks, and co-working sessions so they feel confident owning the stack.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Cloud Roadmap + FAQ + CTA (DARK + TEAL WAVE) -->
  <section class="cloud-faq-cta-section" id="contact">
    <div class="wave-background">
      <svg class="wave wave-1" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="rgba(13, 148, 136, 0.3)" d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
      <svg class="wave wave-2" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="rgba(20, 184, 166, 0.2)" d="M0,64L48,80C96,96,192,128,288,128C384,128,480,96,576,90.7C672,85,768,107,864,144C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
    </div>

    <div class="roadmap-content">
      <div class="container">
        <div class="roadmap-layout">
          <div class="roadmap-text">
            <h2>Let's tune your <span class="highlight-box">cloud roadmap</span></h2>
            <p>Bring your current diagrams (or napkin sketches). We'll highlight gaps, quick wins, and rollout strategies.</p>
            <a href="mailto:jeremy@intentsolutions.io" class="btn-primary">Schedule a Cloud Workshop</a>
          </div>

          <div class="faq-box">
            <h3>Frequently Asked</h3>
            <div class="faq-item">
              <h4>Do you only work on Google Cloud?</h4>
              <p>GCP is home base, but we bridge to AWS, Azure, and on-prem systems when needed.</p>
            </div>
            <div class="faq-item">
              <h4>Can you support us after launch?</h4>
              <p>Yes—choose a retainer for monitoring, cost tuning, and roadmap execution.</p>
            </div>
            <div class="faq-item">
              <h4>What about data migrations?</h4>
              <p>We provide migration runbooks, rehearsal plans, and rollback strategies to keep stakeholders calm.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="cta-content">
      <div class="container">
        <h2>Ready to Build Your <span class="highlight-box">AI System</span>?</h2>
        <p>Tell us about your team and goals — we'll respond within 24 hours.</p>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-primary">Start a Project</a>
      </div>
    </div>
  </section>
</LayoutRedesign>

<style>
  /* ============================================
     Highlight Box
     ============================================ */
  .highlight-box {
    display: inline-block;
    background: var(--color-highlight);
    color: var(--bg-dark);
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
  }

  /* ============================================
     SECTION 1: Hero + Capabilities (IMAGE)
     ============================================ */
  .cloud-hero-capabilities {
    position: relative;
    background:
      linear-gradient(
        to bottom,
        rgba(10, 15, 26, 0.88) 0%,
        rgba(10, 15, 26, 0.75) 40%,
        rgba(10, 15, 26, 0.80) 100%
      ),
      url('/images/hero-cloud.jpg') center/cover no-repeat;
    background-attachment: scroll, fixed;
    overflow: hidden;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero Content */
  .hero-content {
    padding: 8rem 0 4rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-light);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .hero-content h1 {
    color: var(--text-light);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .hero-content p {
    color: var(--text-light-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 750px;
    margin: 0 auto 2rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: var(--text-light);
    color: var(--bg-dark);
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
  }

  .btn-secondary-light {
    display: inline-block;
    background: transparent;
    color: var(--text-light);
    border: 2px solid rgba(255, 255, 255, 0.3);
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .btn-secondary-light:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--text-light);
  }

  /* Capabilities Content */
  .capabilities-content {
    padding: 4rem 0 6rem;
    text-align: center;
  }

  .capabilities-content h2 {
    color: var(--text-light);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    color: var(--text-light-muted);
    font-size: 1.125rem;
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto 2.5rem;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    text-align: left;
  }

  .capability-card {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: var(--transition-base);
  }

  .capability-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .capability-card h3 {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .capability-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 6rem 0 3rem;
    }

    .capabilities-grid {
      grid-template-columns: 1fr;
    }

    .capabilities-content {
      padding: 3rem 0 4rem;
    }
  }

  /* ============================================
     SECTION 2: Engagement + Operators (NEW IMAGE)
     ============================================ */
  .engagement-operators-section {
    position: relative;
    background:
      linear-gradient(
        to bottom,
        rgba(10, 15, 26, 0.85) 0%,
        rgba(10, 15, 26, 0.75) 50%,
        rgba(10, 15, 26, 0.85) 100%
      ),
      url('/images/cloud-engagement-bg.jpg') center/cover no-repeat;
    background-attachment: scroll, fixed;
    overflow: hidden;
  }

  .blueprint-content,
  .operators-content {
    padding: 5rem 0;
  }

  .blueprint-layout {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 3rem;
    align-items: start;
  }

  .blueprint-steps h2 {
    color: var(--text-light);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
  }

  .blueprint-steps ol {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    counter-reset: step;
  }

  .blueprint-steps ol li {
    color: var(--text-light-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
    padding: 0.75rem 0;
    padding-left: 2.5rem;
    position: relative;
    counter-increment: step;
  }

  .blueprint-steps ol li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0.75rem;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-secondary);
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 50%;
  }

  .timeline-note {
    color: var(--text-light-muted);
    font-size: 0.875rem;
    font-style: italic;
    line-height: 1.6;
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .tooling-box {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .tooling-box h3 {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .tooling-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tooling-box ul li {
    color: var(--text-secondary);
    font-size: 0.8125rem;
    line-height: 1.6;
    padding: 0.5rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .tooling-box ul li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-accent-secondary);
    font-size: 1.25rem;
    line-height: 1;
  }

  /* Why Operators Choose */
  .operators-content {
    padding-top: 3rem;
  }

  .operators-content h2 {
    color: var(--text-light);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .operators-content .section-subtitle {
    color: var(--text-light-muted);
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .benefit-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    transition: var(--transition-base);
  }

  .benefit-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .benefit-card h3 {
    color: var(--text-light);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .benefit-card p {
    color: var(--text-light-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 968px) {
    .blueprint-layout {
      grid-template-columns: 1fr;
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .blueprint-content,
    .operators-content {
      padding: 3rem 0;
    }
  }

  /* ============================================
     SECTION 3: Roadmap + FAQ + CTA (DARK + WAVES)
     ============================================ */
  .cloud-faq-cta-section {
    position: relative;
    background: var(--bg-dark);
    overflow: hidden;
  }

  .wave-background {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .wave-1 {
    animation: wave-float 20s ease-in-out infinite;
  }

  .wave-2 {
    animation: wave-float 15s ease-in-out infinite reverse;
  }

  @keyframes wave-float {
    0%, 100% {
      transform: translateX(0) translateY(0);
    }
    50% {
      transform: translateX(-20px) translateY(10px);
    }
  }

  .roadmap-content,
  .cta-content {
    position: relative;
    z-index: 1;
  }

  .roadmap-content {
    padding: 5rem 0 4rem;
  }

  .roadmap-layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 3rem;
    align-items: start;
  }

  .roadmap-text h2 {
    color: var(--text-light);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .roadmap-text p {
    color: var(--text-light-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .faq-box {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .faq-box h3 {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .faq-item {
    margin-bottom: 1.25rem;
  }

  .faq-item:last-child {
    margin-bottom: 0;
  }

  .faq-item h4 {
    color: var(--text-primary);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .faq-item p {
    color: var(--text-secondary);
    font-size: 0.8125rem;
    line-height: 1.6;
    margin: 0;
  }

  /* CTA Content */
  .cta-content {
    padding: 4rem 0 6rem;
    text-align: center;
  }

  .cta-content h2 {
    color: var(--text-light);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: var(--text-light-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  @media (max-width: 968px) {
    .roadmap-layout {
      grid-template-columns: 1fr;
    }

    .roadmap-content {
      padding: 3rem 0 2rem;
    }

    .cta-content {
      padding: 3rem 0 5rem;
    }
  }

  @media (max-width: 768px) {
    .hero-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-primary,
    .btn-secondary-light {
      width: 100%;
      text-align: center;
    }
  }
</style>
