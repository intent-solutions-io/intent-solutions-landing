---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer';
import ColabHero from '../components/ColabHero';
import ColabTypes from '../components/ColabTypes';
import ColabIdealFor from '../components/ColabIdealFor';
import Contact from '../components/Contact';
---

<Layout
  title="Colab with Jeremy | Partnerships & Joint Ventures"
  description="Build together. Ship together. Win together. Looking for a technical partner who can actually build? Joint ventures, white-label solutions, revenue share, and more."
>
  <SiteNav />

  <main class="bg-zinc-900">
    <ColabHero client:load />
    <ColabTypes client:visible />
    <ColabIdealFor client:visible />
    <Contact client:visible />
  </main>

  <Footer />
</Layout>
