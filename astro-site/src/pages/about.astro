---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer';
---

<Layout
  title="about intent solutions io"
  description="Meet the team building pragmatic AI systems, automation, and cloud foundations from Gulf Shores, Alabama."
>
  <SiteNav />

  <main class="bg-zinc-900">
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl">
          <p class="uppercase tracking-[0.3em] text-xs font-semibold text-zinc-500 mb-4">
            about
          </p>
          <h1 class="text-h1 font-bold text-zinc-50 mb-6">
            Pioneering AI with operator-first execution
          </h1>
          <p class="text-zinc-400 leading-relaxed text-lg">
            intent solutions io sits where practical operations meets modern AI. We design, ship,
            and maintain production systems that eliminate manual busywork while keeping data private
            and compliant. Every build is crafted in Gulf Shores, Alabama, and tuned to go live fast.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-zinc-800/60 bg-zinc-950">
      <div class="container mx-auto px-8">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-3">AI / ML Expertise</h3>
            <p class="text-sm text-zinc-400">
              Fine-tuned agents, RAG pipelines, and reasoning systems that deliver measurable wins,
              not just demos.
            </p>
          </div>
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-3">Universal Diagnostics</h3>
            <p class="text-sm text-zinc-400">
              From automotive to healthcare, we build platforms that surface the right insight in the
              right moment.
            </p>
          </div>
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-3">Open Source</h3>
            <p class="text-sm text-zinc-400">
              270+ Claude Code plugins, 1,537 agent skills, and the only external contributor to Google's Agent Starter Pack.
            </p>
          </div>
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-3">Market Leadership</h3>
            <p class="text-sm text-zinc-400">
              Active in right-to-repair and emerging AI standards so your infrastructure stays
              future-ready.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="grid gap-12 lg:grid-cols-2 items-start">
          <div>
            <h2 class="text-3xl font-bold text-zinc-50 mb-6">
              Built for cloud partnership
            </h2>
            <p class="text-zinc-400 leading-relaxed mb-4">
              Every system we ship follows enterprise architecture patterns with observability,
              access control, and rollback strategies baked in. Our experience across Google Cloud,
              Firebase, and Vertex AI makes us a fast match for platform teams that value velocity and
              safety.
            </p>
            <ul class="space-y-3 text-sm text-zinc-300">
              <li class="flex items-center gap-3">
                <span class="h-2 w-2 rounded-full bg-zinc-200"></span>
                Enterprise-ready AI/ML workloads delivered with IaC.
              </li>
              <li class="flex items-center gap-3">
                <span class="h-2 w-2 rounded-full bg-zinc-200"></span>
                Cloud-native design tuned for scale, redundancy, and compliance.
              </li>
              <li class="flex items-center gap-3">
                <span class="h-2 w-2 rounded-full bg-zinc-200"></span>
                Continuous R&D to keep your stack modern without breaking production.
              </li>
            </ul>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="card-slate text-center">
              <div class="text-2xl font-bold text-zinc-100 mb-2">AI / ML</div>
              <p class="text-xs uppercase tracking-widest text-zinc-400">Core Technology</p>
            </div>
            <div class="card-slate text-center">
              <div class="text-2xl font-bold text-zinc-100 mb-2">Cloud</div>
              <p class="text-xs uppercase tracking-widest text-zinc-400">Native Architecture</p>
            </div>
            <div class="card-slate text-center">
              <div class="text-2xl font-bold text-zinc-100 mb-2">Scale</div>
              <p class="text-xs uppercase tracking-widest text-zinc-400">Enterprise Ready</p>
            </div>
            <div class="card-slate text-center">
              <div class="text-2xl font-bold text-zinc-100 mb-2">Innovation</div>
              <p class="text-xs uppercase tracking-widest text-zinc-400">Continuous R&D</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mb-12">
          <h2 class="text-3xl font-bold text-zinc-50 mb-4">
            Production systems we’ve shipped
          </h2>
          <p class="text-zinc-400">
            We partner directly with operators—dealership principals, partners, and practice owners—to
            design software that outlasts the hype cycle.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-2">DiagnosticPro</h3>
            <p class="text-sm text-zinc-400">
              AI-powered vehicle diagnostics that triage repair orders across multiple rooftops in
              real time.
            </p>
          </div>
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-2">Enterprise Automation</h3>
            <p class="text-sm text-zinc-400">
              n8n and Netlify powered flows that offload onboarding, reporting, and compliance tasks
              across departments.
            </p>
          </div>
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-2">Firebase + Firestore</h3>
            <p class="text-sm text-zinc-400">
              Scalable real-time backends supporting distributed teams and customer-facing analytics.
            </p>
          </div>
          <div class="card-slate">
            <h3 class="text-lg font-semibold text-zinc-50 mb-2">Vertex AI Integrations</h3>
            <p class="text-sm text-zinc-400">
              End-to-end pipelines that run on Google Cloud with guardrails around privacy and cost.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
