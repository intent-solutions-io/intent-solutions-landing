---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Footer from '../../components/Footer';
import { getCollection } from 'astro:content';

const posts = (await getCollection('field-notes'))
  .filter(post => !post.data.featured || post.data.featured !== undefined)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const title = 'Field Notes | intent solutions io';
const description = 'Notes from the field — architecture decisions, production systems, and technical leadership from shipping real AI infrastructure.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Field Notes',
  description,
  url: 'https://intentsolutions.io/field-notes',
  author: {
    '@type': 'Person',
    name: 'Jeremy Longshore',
  },
  publisher: {
    '@type': 'Organization',
    name: 'intent solutions io',
    url: 'https://intentsolutions.io',
  },
};
---

<Layout title={title} description={description}>
  <SiteNav />

  <main class="min-h-screen bg-zinc-950">
    <section class="py-20 sm:py-28">
      <div class="container mx-auto px-6 sm:px-8 max-w-4xl">
        <p class="text-xs font-semibold tracking-[0.2em] text-zinc-500 uppercase mb-4">Field Notes</p>
        <h1 class="text-h1 font-bold text-zinc-50 mb-4">From the field</h1>
        <p class="text-body-lg text-zinc-400 max-w-2xl mb-16">
          Architecture decisions, production systems, and technical leadership — notes from actually shipping AI infrastructure.
        </p>

        <div class="space-y-6">
          {posts.map((post) => (
            <a href={`/field-notes/${post.id.replace(/\.md$/, '')}`} class="card-slate block group">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                <h2 class="text-lg font-semibold text-zinc-100 group-hover:text-zinc-50 transition-smooth">
                  {post.data.title}
                </h2>
                <time
                  datetime={post.data.date}
                  class="text-sm text-zinc-500 shrink-0"
                >
                  {new Date(post.data.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <p class="text-sm text-zinc-400 mb-3 line-clamp-2">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.slice(0, 4).map((tag: string) => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-zinc-800/60 text-zinc-500 border border-zinc-700/30">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>

        <div class="mt-12 pt-8 border-t border-zinc-800/40 text-center">
          <a
            href="/field-notes/rss.xml"
            class="text-sm text-zinc-500 hover:text-zinc-300 transition-smooth"
          >
            RSS Feed
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
