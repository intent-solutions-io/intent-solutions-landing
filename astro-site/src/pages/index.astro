---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Hero from '../components/Hero';
import Products from '../components/Products';
import Services from '../components/Services';
import Contact from '../components/Contact';
import Footer from '../components/Footer';
---

<Layout title="intent solutions io - ai consultant building real products">
  <SiteNav />
  <Hero client:load />

  <section class="py-24 bg-zinc-950 border-t border-b border-zinc-800/50">
    <div class="container mx-auto px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-h1 font-bold text-zinc-50 mb-4">ship containerized agents, not hours</h2>
        <p class="text-zinc-400">
          Production-ready AI agents you can deploy today. LinkedIn outbound, meeting intelligence, customer support—Docker Compose, FastAPI, PostgreSQL. Self-hosted or fully managed.
        </p>
      </div>

      <!-- Featured: AI Agents - Full Width Hero -->
      <div class="mb-8">
        <a href="/agents" class="card-slate p-8 flex flex-col md:flex-row gap-8 hover:border-zinc-600 transition-smooth">
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-zinc-50 mb-4">AI Agents → Ready to Deploy</h3>
            <p class="text-base text-zinc-300 mb-4">
              3 containerized agents built with FastAPI + PostgreSQL. LinkedIn outbound prospecting, meeting intelligence transcription, and customer support triage. Deploy in under 2 hours with Docker Compose.
            </p>
            <ul class="space-y-2 mb-6">
              <li class="flex items-start gap-2 text-sm text-zinc-400">
                <span class="mt-1 h-1.5 w-1.5 rounded-full bg-zinc-400" />
                <span><strong class="text-zinc-200">LinkedIn Outbound:</strong> $197/mo self-hosted | $647/mo managed</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-zinc-400">
                <span class="mt-1 h-1.5 w-1.5 rounded-full bg-zinc-400" />
                <span><strong class="text-zinc-200">Meeting Intelligence:</strong> $97/mo self-hosted | $297/mo managed</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-zinc-400">
                <span class="mt-1 h-1.5 w-1.5 rounded-full bg-zinc-400" />
                <span><strong class="text-zinc-200">Support Triage:</strong> $147/mo self-hosted | $497/mo managed</span>
              </li>
            </ul>
            <span class="inline-flex items-center text-zinc-50 font-semibold">
              See full pricing & agent details →
            </span>
          </div>
          <div class="md:w-64 flex flex-col justify-center gap-4">
            <div class="bg-zinc-900 border border-zinc-700 rounded-lg p-4">
              <div class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Average ROI</div>
              <div class="text-3xl font-bold text-zinc-50">247%</div>
              <div class="text-xs text-zinc-400 mt-1">within 90 days</div>
            </div>
            <div class="bg-zinc-900 border border-zinc-700 rounded-lg p-4">
              <div class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Deploy Time</div>
              <div class="text-3xl font-bold text-zinc-50">&lt;2hr</div>
              <div class="text-xs text-zinc-400 mt-1">Docker Compose</div>
            </div>
          </div>
        </a>
      </div>

      <!-- Other Services Grid -->
      <div class="grid gap-6 md:grid-cols-3">
        <a href="/private-ai" class="card-slate h-full flex flex-col">
          <h3 class="text-lg font-semibold text-zinc-50 mb-3">Private AI</h3>
          <p class="text-sm text-zinc-400 flex-1">
            Keep data on your cloud while offering a ChatGPT-style experience to every teammate.
          </p>
          <span class="mt-6 text-sm text-zinc-200">Review pricing & ROI →</span>
        </a>
        <a href="/automation" class="card-slate h-full flex flex-col">
          <h3 class="text-lg font-semibold text-zinc-50 mb-3">Automation</h3>
          <p class="text-sm text-zinc-400 flex-1">
            n8n + Netlify workflows that eliminate manual reporting, onboarding, and follow-ups.
          </p>
          <span class="mt-6 text-sm text-zinc-200">Automation menu →</span>
        </a>
        <a href="/cloud" class="card-slate h-full flex flex-col">
          <h3 class="text-lg font-semibold text-zinc-50 mb-3">Cloud & Data</h3>
          <p class="text-sm text-zinc-400 flex-1">
            Google Cloud-native architectures—Vertex AI, BigQuery, Firebase—with observability baked in.
          </p>
          <span class="mt-6 text-sm text-zinc-200">See cloud blueprint →</span>
        </a>
      </div>
    </div>
  </section>

  <Products client:visible />
  <Services client:visible />
  <Contact client:visible />
  <Footer />
</Layout>
