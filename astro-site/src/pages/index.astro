---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Hero from '../components/Hero';
import ClaudeCodeTiers from '../components/ClaudeCodeTiers';
import Products from '../components/Products';
import Contact from '../components/Contact';
import Footer from '../components/Footer';
---

<Layout title="Claude Code Systems - Build + Train | intent solutions io">
  <SiteNav />

  <Hero client:load />
  <ClaudeCodeTiers client:visible />

  <!-- Learn + Colab -->
  <section class="py-24 bg-zinc-900 border-t border-zinc-800/50">
    <div class="container mx-auto px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-h2 font-bold text-zinc-50 mb-4">two ways to work together</h2>
        <p class="text-zinc-400">
          Whether you need to learn Claude Code or need someone to build with you.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 max-w-4xl mx-auto">
        <a href="/learn" class="card-slate h-full flex flex-col group hover:border-zinc-600 transition-smooth">
          <p class="text-sm text-zinc-500 uppercase tracking-wider mb-2">For decision-makers</p>
          <h3 class="text-xl font-bold text-zinc-50 mb-3 group-hover:text-zinc-200">Learn with Jeremy</h3>
          <p class="text-sm text-zinc-400 flex-1 mb-4">
            Executive onramps, leadership workshops, and team enablement. Understand what Claude Code is, how it fits your org, and how to roll it out safely.
          </p>
          <span class="text-sm text-zinc-200 group-hover:text-zinc-50">Explore Learn →</span>
        </a>
        <a href="/colab" class="card-slate h-full flex flex-col group hover:border-zinc-600 transition-smooth">
          <p class="text-sm text-zinc-500 uppercase tracking-wider mb-2">For teams ready to ship</p>
          <h3 class="text-xl font-bold text-zinc-50 mb-3 group-hover:text-zinc-200">Colab with Jeremy</h3>
          <p class="text-sm text-zinc-400 flex-1 mb-4">
            Implementation partner in your repo. Delivery sprints, monthly cadence, or advisory. Real PRs, reviewed and deployed.
          </p>
          <span class="text-sm text-zinc-200 group-hover:text-zinc-50">Explore Colab →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Other Services (Secondary) -->
  <section class="py-24 bg-zinc-900">
    <div class="container mx-auto px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-h2 font-bold text-zinc-50 mb-4">also available</h2>
        <p class="text-zinc-400">
          Beyond Claude Code—additional AI and automation services.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <a href="/agents" class="card-slate h-full flex flex-col">
          <h3 class="text-lg font-semibold text-zinc-50 mb-3">AI Agents</h3>
          <p class="text-sm text-zinc-400 flex-1">
            Custom Intent Agent Models for any workflow.
          </p>
          <span class="mt-4 text-sm text-zinc-200">Learn more →</span>
        </a>
        <a href="/private-ai" class="card-slate h-full flex flex-col">
          <h3 class="text-lg font-semibold text-zinc-50 mb-3">Private AI</h3>
          <p class="text-sm text-zinc-400 flex-1">
            ChatGPT-style experience on your own cloud.
          </p>
          <span class="mt-4 text-sm text-zinc-200">Learn more →</span>
        </a>
        <a href="/automation" class="card-slate h-full flex flex-col">
          <h3 class="text-lg font-semibold text-zinc-50 mb-3">Automation</h3>
          <p class="text-sm text-zinc-400 flex-1">
            n8n workflows that eliminate manual work.
          </p>
          <span class="mt-4 text-sm text-zinc-200">Learn more →</span>
        </a>
        <a href="/cloud" class="card-slate h-full flex flex-col">
          <h3 class="text-lg font-semibold text-zinc-50 mb-3">Cloud & Data</h3>
          <p class="text-sm text-zinc-400 flex-1">
            Google Cloud-native architectures.
          </p>
          <span class="mt-4 text-sm text-zinc-200">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <Products client:visible />
  <Contact client:visible />
  <Footer />
</Layout>
