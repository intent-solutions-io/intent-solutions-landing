---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="Intent Solutions - AI Agents, Private AI, and Automation">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge">AI Systems Built for Production</span>
        </div>

        <h1 class="hero-title">
          Creating industries<br />that don't exist
        </h1>

        <p class="hero-description">
          Model-agnostic AI agents, private AI infrastructure, and automation solutions.
          Transparent pricing, enterprise-grade security, no vendor lock-in.
        </p>

        <div class="hero-stats">
          <div class="stat">
            <div class="stat-value">48hrs</div>
            <div class="stat-label">Avg Deployment</div>
          </div>
          <div class="stat">
            <div class="stat-value">99.9%</div>
            <div class="stat-label">Uptime</div>
          </div>
          <div class="stat">
            <div class="stat-value">9+</div>
            <div class="stat-label">AI Models</div>
          </div>
        </div>

        <div class="hero-ctas">
          <a href="#contact" class="btn btn-primary btn-lg">
            Start a Project
          </a>
          <a href="/learn" class="btn btn-secondary btn-lg">
            Explore Solutions
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted By Section -->
  <section class="section trusted-section">
    <div class="container">
      <p class="trusted-text">Trusted by forward-thinking teams</p>
      <div class="trusted-badges">
        <div class="badge-item">Google Cloud Partner</div>
        <div class="badge-item">HIPAA Ready</div>
        <div class="badge-item">SOC 2 Certified</div>
        <div class="badge-item">Model Agnostic</div>
      </div>
    </div>
  </section>

  <!-- Solutions Grid -->
  <section class="section solutions-section">
    <div class="container">
      <div class="section-header">
        <h2>Explore Tailored Build Paths</h2>
        <p>Pick the journey that matches your next launch—agents, automation, private AI, or cloud infrastructure.</p>
      </div>

      <div class="solutions-grid">
        <!-- Claude Code -->
        <a href="/claude-code" class="solution-card">
          <div class="solution-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <h3>Claude Code</h3>
          <p>Custom Claude Code setups for teams of any size. 258+ plugins, training, and enablement.</p>
          <div class="solution-link">
            Learn more <span>→</span>
          </div>
        </a>

        <!-- AI Agents -->
        <a href="/agents" class="solution-card">
          <div class="solution-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 2l-4.2 4.2m13.2-5.2h-6m-6 0H1m13.2 5.2l-4.2-4.2m0-2L5.8 5.8"></path>
            </svg>
          </div>
          <h3>AI Agents (IAM)</h3>
          <p>Customizable Intent Agent Models for any workflow. Pre-configured M1/M2/M3 packages available.</p>
          <div class="solution-link">
            See packages <span>→</span>
          </div>
        </a>

        <!-- Private AI -->
        <a href="/private-ai" class="solution-card">
          <div class="solution-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <h3>Private AI</h3>
          <p>Keep data on your cloud while offering a ChatGPT-style experience to every teammate.</p>
          <div class="solution-link">
            Review pricing <span>→</span>
          </div>
        </a>

        <!-- Automation -->
        <a href="/automation" class="solution-card">
          <div class="solution-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
          </div>
          <h3>Automation</h3>
          <p>n8n + Netlify workflows that eliminate manual reporting, onboarding, and follow-ups.</p>
          <div class="solution-link">
            Automation menu <span>→</span>
          </div>
        </a>

        <!-- Cloud & Data -->
        <a href="/cloud" class="solution-card">
          <div class="solution-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
            </svg>
          </div>
          <h3>Cloud & Data</h3>
          <p>Google Cloud-native architectures—Vertex AI, BigQuery, Firebase—with observability baked in.</p>
          <div class="solution-link">
            See cloud blueprint <span>→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section cta-section" id="contact">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to build your system?</h2>
        <p>Let's discuss your project and create a custom solution that fits your needs.</p>
        <a href="mailto:jeremy@intentsolutions.io" class="btn btn-primary btn-lg">
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</LayoutRedesign>

<style>
  /* Hero Section */
  .hero-section {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, rgb(var(--color-bg-secondary)) 0%, rgb(var(--color-bg-primary)) 100%);
  }

  @media (min-width: 768px) {
    .hero-section {
      padding: 8rem 0 6rem;
    }
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-badge {
    margin-bottom: 1.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-accent-primary));
    background-color: rgb(var(--color-accent-light));
    border: 1px solid rgb(var(--color-accent-lighter));
    border-radius: var(--radius-full);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-text-primary));
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-bottom: 2.5rem;
    padding: 2rem 0;
    border-top: 1px solid rgb(var(--color-border));
    border-bottom: 1px solid rgb(var(--color-border));
  }

  @media (max-width: 640px) {
    .hero-stats {
      gap: 2rem;
    }
  }

  .stat {
    text-align: center;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: rgb(var(--color-accent-primary));
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: rgb(var(--color-text-tertiary));
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Trusted Section */
  .trusted-section {
    padding: 3rem 0;
    border-bottom: 1px solid rgb(var(--color-border));
  }

  .trusted-text {
    text-align: center;
    font-size: 0.875rem;
    color: rgb(var(--color-text-tertiary));
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .trusted-badges {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .badge-item {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-text-secondary));
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-md);
  }

  /* Solutions Section */
  .solutions-section {
    background-color: white;
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .section-header p {
    font-size: 1.125rem;
    color: rgb(var(--color-text-secondary));
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .solutions-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .solution-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: rgb(var(--color-text-primary));
    transition: all var(--transition-base);
  }

  .solution-card:hover {
    border-color: rgb(var(--color-accent-primary));
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .solution-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-accent-primary));
    background-color: rgb(var(--color-accent-light));
    border-radius: var(--radius-lg);
  }

  .solution-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: rgb(var(--color-text-primary));
  }

  .solution-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .solution-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgb(var(--color-accent-primary));
    transition: gap var(--transition-fast);
  }

  .solution-card:hover .solution-link {
    gap: 0.75rem;
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, rgb(var(--color-accent-primary)), rgb(67 56 202));
    color: white;
  }

  .cta-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    color: white;
    margin-bottom: 1rem;
  }

  .cta-content p {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
  }

  .cta-content .btn {
    background-color: white;
    color: rgb(var(--color-accent-primary));
    border-color: white;
  }

  .cta-content .btn:hover {
    background-color: rgba(255, 255, 255, 0.95);
    transform: translateY(-2px);
  }
</style>
