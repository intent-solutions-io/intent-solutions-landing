---
import LayoutRedesign from '../../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="HUSTLE Survey - Section 14 of 15">
  <div class="min-h-screen bg-zinc-900">
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 14 of 15</span>
            <span class="text-sm text-zinc-400">93%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 93%"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">pricing & value</h1>
          <p class="text-zinc-400 mb-12">
            help us understand what you'd be willing to pay
          </p>

          <div class="space-y-12">
            <!-- Question 63: Monthly pricing -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                63. What would you expect to pay MONTHLY for this app (per athlete)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="monthlyPrice" value="free-with-ads" required />
                  <span>Free (with ads)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="monthlyPrice" value="2.99" />
                  <span>$2.99/month</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="monthlyPrice" value="4.99" />
                  <span>$4.99/month</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="monthlyPrice" value="9.99" />
                  <span>$9.99/month</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="monthlyPrice" value="14.99" />
                  <span>$14.99/month</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="monthlyPrice" value="19.99" />
                  <span>$19.99/month</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="monthlyPrice" value="20-plus" />
                  <span>More than $20/month</span>
                </label>
              </div>
            </div>

            <!-- Question 64: Billing preference -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                64. Would you prefer monthly or annual billing?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="billingPreference" value="monthly-flexibility" required />
                  <span>Monthly (more flexibility)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="billingPreference" value="annual-save-money" />
                  <span>Annual (save money with upfront payment)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="billingPreference" value="either-works" />
                  <span>Either works</span>
                </label>
              </div>
            </div>

            <!-- Question 65: Pricing model -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                65. What pricing model makes most sense?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="pricingModel" value="free-basic-paid-premium" required />
                  <span>Free basic + paid premium features</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="pricingModel" value="free-trial-paid-subscription" />
                  <span>Free trial + paid subscription</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="pricingModel" value="one-time-purchase" />
                  <span>One-time purchase</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="pricingModel" value="freemium-optional-upgrades" />
                  <span>Freemium (free forever with optional upgrades)</span>
                </label>
              </div>
            </div>

            <!-- Question 66: Premium features (Multi-select) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                66. Which premium features would be worth paying extra for? (Select all that apply)
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="unlimited-storage" />
                  <span>Unlimited photo/video storage</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="ai-insights" />
                  <span>AI-powered insights and recommendations</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="advanced-analytics" />
                  <span>Advanced analytics and charts</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="coach-verification" />
                  <span>Coach verification and access</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="recruiting-profile" />
                  <span>College recruiting profile tools</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="export-pdf" />
                  <span>Export to PDF for recruiting</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="priority-support" />
                  <span>Priority customer support</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="ad-free" />
                  <span>Ad-free experience</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="premiumFeatures" value="family-plan" />
                  <span>Family plan (multiple athletes)</span>
                </label>
              </div>

              <div class="mt-4">
                <label class="block text-sm text-zinc-400 mb-2">Other (please specify):</label>
                <input
                  type="text"
                  name="premiumFeaturesOther"
                  class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                  placeholder="Other premium features..."
                />
              </div>
            </div>

            <!-- Question 67: Annual pricing -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                67. How much would you pay ANNUALLY (per athlete) if you got 2 months free?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="annualPrice" value="under-30" required />
                  <span>Under $30/year</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="annualPrice" value="30-50" />
                  <span>$30-50/year</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="annualPrice" value="50-75" />
                  <span>$50-75/year</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="annualPrice" value="75-100" />
                  <span>$75-100/year</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="annualPrice" value="100-150" />
                  <span>$100-150/year</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="annualPrice" value="150-plus" />
                  <span>More than $150/year</span>
                </label>
              </div>
            </div>

            <!-- Question 68: Time savings value -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                68. If this app saved you 2+ hours per week, what would it be worth to you monthly?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="timeSavingsValue" value="under-5" required />
                  <span>Under $5</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeSavingsValue" value="5-10" />
                  <span>$5-10</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeSavingsValue" value="10-15" />
                  <span>$10-15</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeSavingsValue" value="15-20" />
                  <span>$15-20</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeSavingsValue" value="20-30" />
                  <span>$20-30</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeSavingsValue" value="30-plus" />
                  <span>More than $30</span>
                </label>
              </div>
            </div>
          </div>

          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button type="button" id="back-btn" class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth">← back</button>
            <button type="button" id="next-btn" class="btn-primary px-8 py-3">final section →</button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const monthlyPrice = document.querySelector('input[name="monthlyPrice"]:checked');
        const billingPreference = document.querySelector('input[name="billingPreference"]:checked');
        const pricingModel = document.querySelector('input[name="pricingModel"]:checked');
        const premiumFeatures = document.querySelectorAll('input[name="premiumFeatures"]:checked');
        const annualPrice = document.querySelector('input[name="annualPrice"]:checked');
        const timeSavingsValue = document.querySelector('input[name="timeSavingsValue"]:checked');

        if (!monthlyPrice) {
          alert('Please answer: Monthly pricing expectation? (Q63)');
          return;
        }

        if (!billingPreference) {
          alert('Please answer: Billing preference? (Q64)');
          return;
        }

        if (!pricingModel) {
          alert('Please answer: Preferred pricing model? (Q65)');
          return;
        }

        if (premiumFeatures.length === 0) {
          alert('Please select at least one premium feature (Q66)');
          return;
        }

        if (!annualPrice) {
          alert('Please answer: Annual pricing? (Q67)');
          return;
        }

        if (!timeSavingsValue) {
          alert('Please answer: Time savings value? (Q68)');
          return;
        }

        // Save section data
        const sectionData = {
          monthlyPrice: (monthlyPrice as HTMLInputElement).value,
          billingPreference: (billingPreference as HTMLInputElement).value,
          pricingModel: (pricingModel as HTMLInputElement).value,
          premiumFeatures: Array.from(premiumFeatures).map((el: any) => el.value),
          premiumFeaturesOther: (document.querySelector('input[name="premiumFeaturesOther"]') as HTMLInputElement)?.value || '',
          annualPrice: (annualPrice as HTMLInputElement).value,
          timeSavingsValue: (timeSavingsValue as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_14', JSON.stringify(sectionData));
        window.location.href = '/survey/15';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/13';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option, .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover, .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input, .checkbox-option input {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span, .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    .rating-option {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .rating-option input {
      width: 20px;
      height: 20px;
      cursor: pointer;
    }

    .rating-option span {
      color: rgb(228 228 231);
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .question-block { padding: 1.5rem; }
      .radio-option input, .checkbox-option input { min-width: 24px; min-height: 24px; }
    }
  </style>
</LayoutRedesign>
