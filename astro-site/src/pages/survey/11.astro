---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="HUSTLE Survey - Section 11 of 15">
  <div class="min-h-screen bg-zinc-900">
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 11 of 15</span>
            <span class="text-sm text-zinc-400">73%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 73%"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">mobile experience</h1>
          <p class="text-zinc-400 mb-12">making logging fast and easy on the go</p>

          <div class="space-y-12">
            <!-- Question 42: Add to Home Screen -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                42. Would you like a prompt to "Add to Home Screen" so the app feels native?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="addToHomeScreen" value="yes-helpful" required />
                  <span>Yes, that would be helpful</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="addToHomeScreen" value="no-dont-prompt" />
                  <span>No, don't prompt me</span>
                </label>
              </div>
            </div>

            <!-- Question 43: Offline logging importance -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                43. How important is offline logging (log without internet, sync later)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="flex justify-between items-center gap-2">
                <span class="text-sm text-zinc-400">Not important</span>
                <div class="flex gap-3">
                  <label class="rating-option">
                    <input type="radio" name="offlineImportance" value="1" required />
                    <span>1</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="offlineImportance" value="2" />
                    <span>2</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="offlineImportance" value="3" />
                    <span>3</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="offlineImportance" value="4" />
                    <span>4</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="offlineImportance" value="5" />
                    <span>5</span>
                  </label>
                </div>
                <span class="text-sm text-zinc-400">Essential</span>
              </div>
            </div>

            <!-- Question 44: Time to log expectation -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                44. How long should logging take?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="timeToLog" value="under-60-seconds" required />
                  <span>Under 60 seconds</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeToLog" value="1-2-minutes" />
                  <span>1-2 minutes</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeToLog" value="up-to-3-minutes" />
                  <span>Up to 3 minutes is fine</span>
                </label>
              </div>
            </div>
          </div>

          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button type="button" id="back-btn" class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth">← back</button>
            <button type="button" id="next-btn" class="btn-primary px-8 py-3">next section →</button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      nextBtn?.addEventListener('click', () => {
        const homeScreen = document.querySelector('input[name="addToHomeScreen"]:checked');
        const offline = document.querySelector('input[name="offlineImportance"]:checked');
        const timeToLog = document.querySelector('input[name="timeToLog"]:checked');

        if (!homeScreen) {
          alert('Please answer: Add to Home Screen preference');
          return;
        }

        if (!offline) {
          alert('Please rate: Offline logging importance');
          return;
        }

        if (!timeToLog) {
          alert('Please answer: Time to log expectation');
          return;
        }

        const sectionData = {
          addToHomeScreen: (homeScreen as HTMLInputElement).value,
          offlineImportance: (offline as HTMLInputElement).value,
          timeToLog: (timeToLog as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_11', JSON.stringify(sectionData));
        window.location.href = '/survey/12';
      });

      backBtn?.addEventListener('click', () => window.location.href = '/survey/10');
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    .rating-option {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .rating-option input {
      width: 20px;
      height: 20px;
      cursor: pointer;
    }

    .rating-option span {
      color: rgb(228 228 231);
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .question-block { padding: 1.5rem; }
      .radio-option input { min-width: 24px; min-height: 24px; }
    }
  </style>
</Layout>
