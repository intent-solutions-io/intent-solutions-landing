---
// DEVELOPMENT ONLY - DELETE BEFORE PRODUCTION
import Layout from '../../layouts/Layout.astro';
---

<Layout title="🧪 Survey Test Submit">
  <div class="min-h-screen bg-zinc-900 flex items-center justify-center p-8">
    <div class="max-w-2xl w-full bg-zinc-800 rounded-lg p-8">
      <div class="bg-yellow-900/30 border border-yellow-600 rounded-lg p-4 mb-6">
        <p class="text-yellow-200 font-semibold">⚠️ DEVELOPMENT TEST PAGE</p>
        <p class="text-yellow-300 text-sm mt-1">
          This bypasses the full 76-question survey for testing. Delete before production deployment.
        </p>
      </div>

      <h1 class="text-3xl font-bold text-zinc-50 mb-2">🧪 Survey Submit Test</h1>
      <p class="text-zinc-400 mb-6">Test form submission, redirect, and email delivery</p>

      <!-- THIS MUST MATCH YOUR ACTUAL SURVEY FORM CONFIGURATION -->
      <form
        name="hustle-survey"
        method="POST"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        action="/survey/thank-you"
        class="space-y-6"
      >
        <!-- CRITICAL HIDDEN FIELDS -->
        <input type="hidden" name="form-name" value="hustle-survey" />

        <!-- HONEYPOT (must match actual form) -->
        <p class="hidden">
          <label>Don't fill: <input name="bot-field" /></label>
        </p>

        <!-- MINIMUM TEST FIELDS (pre-filled for speed) -->
        <div>
          <label for="email" class="block text-sm font-medium text-zinc-300 mb-2">
            Email Address *
          </label>
          <input
            type="email"
            name="email"
            id="email"
            value="test@example.com"
            required
            class="w-full px-4 py-3 bg-zinc-700 border border-zinc-600 rounded-lg text-zinc-100 focus:ring-2 focus:ring-zinc-400 focus:border-transparent"
            placeholder="your@email.com"
          />
          <p class="text-zinc-500 text-xs mt-1">Use a real email address you can check</p>
        </div>

        <div>
          <label for="firstName" class="block text-sm font-medium text-zinc-300 mb-2">
            First Name *
          </label>
          <input
            type="text"
            name="firstName"
            id="firstName"
            value="Test"
            required
            class="w-full px-4 py-3 bg-zinc-700 border border-zinc-600 rounded-lg text-zinc-100 focus:ring-2 focus:ring-zinc-400 focus:border-transparent"
          />
        </div>

        <div>
          <label for="lastName" class="block text-sm font-medium text-zinc-300 mb-2">
            Last Name *
          </label>
          <input
            type="text"
            name="lastName"
            id="lastName"
            value="User"
            required
            class="w-full px-4 py-3 bg-zinc-700 border border-zinc-600 rounded-lg text-zinc-100 focus:ring-2 focus:ring-zinc-400 focus:border-transparent"
          />
        </div>

        <!-- Add a few more fields to match real survey structure -->
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-2">
            Beta Testing Interest
          </label>
          <select
            name="betaInterest"
            class="w-full px-4 py-3 bg-zinc-700 border border-zinc-600 rounded-lg text-zinc-100 focus:ring-2 focus:ring-zinc-400 focus:border-transparent"
          >
            <option value="yes-signup">Yes! Sign me up</option>
            <option value="maybe">Maybe, tell me more</option>
            <option value="no-feedback-only">No, just feedback</option>
          </select>
        </div>

        <button
          type="submit"
          class="w-full py-4 px-6 bg-zinc-200 hover:bg-zinc-100 text-zinc-900 font-bold rounded-lg transition-colors text-lg"
        >
          🧪 TEST SUBMIT
        </button>
      </form>

      <div class="mt-8 p-6 bg-blue-900/20 border border-blue-700 rounded-lg">
        <h2 class="text-lg font-semibold text-blue-200 mb-3">After clicking submit, verify:</h2>
        <ul class="space-y-2 text-blue-300 text-sm">
          <li>✓ Browser redirects to /survey/thank-you</li>
          <li>✓ Thank you page shows HUSTLE branding</li>
          <li>✓ Test email arrives within 2 minutes</li>
          <li>✓ Netlify dashboard shows new submission</li>
          <li>✓ No console errors in DevTools</li>
        </ul>
      </div>

      <div class="mt-6 text-center">
        <a href="/survey/thank-you" class="text-zinc-400 hover:text-zinc-200 underline text-sm">
          → Test thank-you page directly
        </a>
      </div>
    </div>
  </div>
</Layout>
