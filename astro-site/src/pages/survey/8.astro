---
import LayoutRedesign from '../../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="HUSTLE Survey - Section 8 of 15">
  <div class="min-h-screen bg-zinc-900">
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 8 of 15</span>
            <span class="text-sm text-zinc-400">53%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 53%"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">verification & trust</h1>
          <p class="text-zinc-400 mb-8">
            To prevent stat inflation, we're building a verification system where parents and coaches can confirm game stats.
          </p>

          <div class="space-y-12">
            <!-- Question 31: Parent verification value -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                31. How valuable is parent verification (you approve stats via PIN)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="flex justify-between items-center gap-2">
                <span class="text-sm text-zinc-400">Not valuable</span>
                <div class="flex gap-3">
                  <label class="rating-option">
                    <input type="radio" name="parentVerificationValue" value="1" required />
                    <span>1</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="parentVerificationValue" value="2" />
                    <span>2</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="parentVerificationValue" value="3" />
                    <span>3</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="parentVerificationValue" value="4" />
                    <span>4</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="parentVerificationValue" value="5" />
                    <span>5</span>
                  </label>
                </div>
                <span class="text-sm text-zinc-400">Very valuable</span>
              </div>
            </div>

            <!-- Question 32: Coach verification importance -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                32. How important is coach verification in the future?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="coachVerification" value="must-have" required />
                  <span>Must have this—essential for credibility</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="coachVerification" value="nice-eventually" />
                  <span>Nice to have eventually</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="coachVerification" value="not-important" />
                  <span>Not important to me</span>
                </label>
              </div>
            </div>

            <!-- Question 33: Verified badge usefulness -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                33. Would a "Verified" badge and trust score on your child's profile be useful?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="flex justify-between items-center gap-2">
                <span class="text-sm text-zinc-400">Not useful</span>
                <div class="flex gap-3">
                  <label class="rating-option">
                    <input type="radio" name="verifiedBadgeUseful" value="1" required />
                    <span>1</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="verifiedBadgeUseful" value="2" />
                    <span>2</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="verifiedBadgeUseful" value="3" />
                    <span>3</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="verifiedBadgeUseful" value="4" />
                    <span>4</span>
                  </label>
                  <label class="rating-option">
                    <input type="radio" name="verifiedBadgeUseful" value="5" />
                    <span>5</span>
                  </label>
                </div>
                <span class="text-sm text-zinc-400">Very useful</span>
              </div>
            </div>

            <!-- Question 34: Verification time limit -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                34. Should there be a time limit for verifying stats (e.g., within 7 days of a game)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="verificationTimeLimit" value="7-days" required />
                  <span>Yes, 7 days is reasonable</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="verificationTimeLimit" value="custom-days" id="custom-days-radio" />
                  <span>Yes, but allow longer</span>
                </label>
                <div id="custom-days-input" class="hidden ml-8">
                  <div class="flex items-center gap-3">
                    <input
                      type="number"
                      name="customDays"
                      min="1"
                      max="90"
                      placeholder="Number of days"
                      class="w-32 px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                    />
                    <span class="text-zinc-400">days</span>
                  </div>
                </div>
                <label class="radio-option">
                  <input type="radio" name="verificationTimeLimit" value="no-limit" />
                  <span>No time limit needed</span>
                </label>
              </div>
            </div>
          </div>

          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button type="button" id="back-btn" class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth">← back</button>
            <button type="button" id="next-btn" class="btn-primary px-8 py-3">next section →</button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');
      const customDaysRadio = document.getElementById('custom-days-radio');
      const customDaysInput = document.getElementById('custom-days-input');

      // Show custom days input when selected
      customDaysRadio?.addEventListener('change', () => {
        if ((customDaysRadio as HTMLInputElement).checked) {
          customDaysInput?.classList.remove('hidden');
        }
      });

      // Hide custom days input when other options selected
      document.querySelectorAll('input[name="verificationTimeLimit"]').forEach(radio => {
        radio.addEventListener('change', (e) => {
          const target = e.target as HTMLInputElement;
          if (target.value !== 'custom-days') {
            customDaysInput?.classList.add('hidden');
          }
        });
      });

      nextBtn?.addEventListener('click', () => {
        const parentVerif = document.querySelector('input[name="parentVerificationValue"]:checked');
        const coachVerif = document.querySelector('input[name="coachVerification"]:checked');
        const badge = document.querySelector('input[name="verifiedBadgeUseful"]:checked');
        const timeLimit = document.querySelector('input[name="verificationTimeLimit"]:checked');

        if (!parentVerif) {
          alert('Please rate: Parent verification value');
          return;
        }

        if (!coachVerif) {
          alert('Please answer: Coach verification importance');
          return;
        }

        if (!badge) {
          alert('Please rate: Verified badge usefulness');
          return;
        }

        if (!timeLimit) {
          alert('Please answer: Verification time limit preference');
          return;
        }

        const sectionData = {
          parentVerificationValue: (parentVerif as HTMLInputElement).value,
          coachVerification: (coachVerif as HTMLInputElement).value,
          verifiedBadgeUseful: (badge as HTMLInputElement).value,
          verificationTimeLimit: (timeLimit as HTMLInputElement).value,
          customDays: (document.querySelector('input[name="customDays"]') as HTMLInputElement)?.value || ''
        };

        sessionStorage.setItem('survey_section_8', JSON.stringify(sectionData));
        window.location.href = '/survey/9';
      });

      backBtn?.addEventListener('click', () => window.location.href = '/survey/7');
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    .rating-option {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .rating-option input {
      width: 20px;
      height: 20px;
      cursor: pointer;
    }

    .rating-option span {
      color: rgb(228 228 231);
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .question-block { padding: 1.5rem; }
      .radio-option input { min-width: 24px; min-height: 24px; }
    }
  </style>
</LayoutRedesign>
