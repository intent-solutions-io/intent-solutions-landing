---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="HUSTLE Survey - Section 1 of 15">
  <div class="min-h-screen bg-zinc-900">
    <!-- Sticky Progress Bar -->
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <a href="/survey" class="text-sm text-zinc-400 hover:text-zinc-200 transition-smooth">
              ← back to intro
            </a>
            <span class="text-sm text-zinc-400">section 1 of 15</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 6.67%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Survey Form -->
    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">quick start</h1>
          <p class="text-zinc-400 mb-12">
            before we begin, we need your consent to participate in this research survey
          </p>

          <form
            name="hustle-survey"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-8"
            id="survey-form"
          >
            <!-- Hidden fields for Netlify -->
            <input type="hidden" name="form-name" value="hustle-survey" />
            <input type="hidden" name="section" value="1" />

            <!-- Honeypot spam protection -->
            <p class="hidden">
              <label>
                Don't fill this out if you're human: <input name="bot-field" />
              </label>
            </p>

            <!-- Question 1: Consent -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                1. Do you consent to participate in this research survey?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="flex items-start p-4 bg-zinc-800/50 border border-zinc-700 rounded-lg cursor-pointer hover:border-zinc-400 transition-smooth">
                  <input
                    type="radio"
                    name="consent"
                    value="yes"
                    required
                    class="mt-1 mr-3 w-5 h-5 text-zinc-200"
                  />
                  <span class="text-zinc-200">Yes, I'm in!</span>
                </label>

                <label class="flex items-start p-4 bg-zinc-800/50 border border-zinc-700 rounded-lg cursor-pointer hover:border-zinc-400 transition-smooth">
                  <input
                    type="radio"
                    name="consent"
                    value="no"
                    class="mt-1 mr-3 w-5 h-5 text-zinc-200"
                    id="consent-no"
                  />
                  <span class="text-zinc-200">No thanks</span>
                </label>
              </div>

              <p class="text-sm text-zinc-500 mt-3">
                Your responses will be kept confidential and used only to improve HUSTLE.
              </p>
            </div>

            <!-- Navigation -->
            <div class="flex justify-between items-center pt-8 border-t border-zinc-800">
              <a
                href="/survey"
                class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth"
              >
                ← back
              </a>

              <button
                type="button"
                id="next-btn"
                class="btn-primary px-8 py-3"
              >
                next section →
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>

  <script>
    // Handle consent validation and navigation
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('survey-form') as HTMLFormElement;
      const nextBtn = document.getElementById('next-btn');
      const consentNo = document.getElementById('consent-no') as HTMLInputElement;

      // Handle "No thanks" selection - end survey
      consentNo?.addEventListener('change', () => {
        if (consentNo.checked) {
          if (confirm('Are you sure you want to exit the survey?')) {
            window.location.href = '/survey';
          } else {
            consentNo.checked = false;
          }
        }
      });

      // Handle next button
      nextBtn?.addEventListener('click', () => {
        const consentYes = document.querySelector('input[name="consent"]:checked') as HTMLInputElement;

        if (!consentYes) {
          alert('Please select an option to continue');
          return;
        }

        if (consentYes.value === 'yes') {
          // Store consent in sessionStorage and move to next section
          sessionStorage.setItem('survey_consent', 'yes');
          sessionStorage.setItem('survey_section_1', JSON.stringify({
            consent: 'yes'
          }));
          window.location.href = '/survey/2';
        }
      });
    });
  </script>

  <style>
    /* Custom radio button styling for better mobile touch targets */
    input[type="radio"] {
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    /* Mobile optimization */
    @media (max-width: 768px) {
      .question-block {
        padding: 1.5rem;
      }

      input[type="radio"] {
        min-width: 24px;
        min-height: 24px;
      }
    }
  </style>
</Layout>
