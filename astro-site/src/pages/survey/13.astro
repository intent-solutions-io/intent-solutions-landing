---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="HUSTLE Survey - Section 13 of 15">
  <div class="min-h-screen bg-zinc-900">
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 13 of 15</span>
            <span class="text-sm text-zinc-400">87%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 87%"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">future features</h1>
          <p class="text-zinc-400 mb-12">
            we won't build these yet - just gauging interest
          </p>

          <div class="space-y-12">
            <!-- Question 59: Future features (Select up to 3) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                59. Which FUTURE features would you be most excited about? (Select up to 3)
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="nutrition-tracking" class="future-features-check" />
                  <span>Nutrition tracking</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="sleep-tracking" class="future-features-check" />
                  <span>Sleep tracking</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="strength-conditioning" class="future-features-check" />
                  <span>Strength/conditioning logs</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="mental-performance" class="future-features-check" />
                  <span>Mental performance journal</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="team-messaging" class="future-features-check" />
                  <span>Team messaging/communication</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="travel-planning" class="future-features-check" />
                  <span>Travel planning for tournaments</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="expense-tracking" class="future-features-check" />
                  <span>Expense tracking for sports costs</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="scholarship-recruiting" class="future-features-check" />
                  <span>Scholarship/recruiting tools</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="video-analysis" class="future-features-check" />
                  <span>Video analysis integration</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="futureFeatures" value="wearable-integration" class="future-features-check" />
                  <span>Wearable device integration (GPS, heart rate)</span>
                </label>
              </div>

              <div class="mt-4">
                <label class="block text-sm text-zinc-400 mb-2">Other (please specify):</label>
                <input
                  type="text"
                  name="futureFeaturesOther"
                  class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                  placeholder="Other future features..."
                />
              </div>

              <p class="text-sm text-zinc-500 mt-3">Select up to 3 options</p>
            </div>

            <!-- Question 60: Wearable integration -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                60. Would you want integration with wearable devices (GPS trackers, heart rate monitors)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="wearableIntegration" value="yes-already-use" required />
                  <span>Yes, we already use them</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="wearableIntegration" value="maybe-future" />
                  <span>Maybe in the future</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="wearableIntegration" value="no-too-complicated" />
                  <span>No, too complicated</span>
                </label>
              </div>
            </div>

            <!-- Question 61: Team communication -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                61. How important is team communication (chat, announcements) in a sports tracking app?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="teamCommunication" value="very-important-need-badly" required />
                  <span>Very important - we need this badly</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="teamCommunication" value="somewhat-important" />
                  <span>Somewhat important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="teamCommunication" value="not-important-other-apps" />
                  <span>Not important - we use other apps for that</span>
                </label>
              </div>
            </div>

            <!-- Question 62: Pay for premium features -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                62. Would you pay MORE for premium features like AI insights, video analysis, or advanced analytics?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="payPremium" value="yes-if-add-value" required />
                  <span>Yes, if they add real value</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="payPremium" value="maybe-depends-price" />
                  <span>Maybe, depends on price</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="payPremium" value="no-basic-enough" />
                  <span>No, basic features are enough</span>
                </label>
              </div>
            </div>
          </div>

          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button type="button" id="back-btn" class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth">← back</button>
            <button type="button" id="next-btn" class="btn-primary px-8 py-3">next section →</button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Limit future features to 3 selections
      const futureChecks = document.querySelectorAll('.future-features-check');
      futureChecks.forEach(check => {
        check.addEventListener('change', () => {
          const checked = document.querySelectorAll('.future-features-check:checked');
          if (checked.length > 3) {
            (check as HTMLInputElement).checked = false;
            alert('Please select up to 3 future features only');
          }
        });
      });

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const futureFeatures = document.querySelectorAll('input[name="futureFeatures"]:checked');
        const wearableIntegration = document.querySelector('input[name="wearableIntegration"]:checked');
        const teamCommunication = document.querySelector('input[name="teamCommunication"]:checked');
        const payPremium = document.querySelector('input[name="payPremium"]:checked');

        if (futureFeatures.length === 0) {
          alert('Please select at least one future feature (Q59)');
          return;
        }

        if (!wearableIntegration) {
          alert('Please answer: Wearable device integration? (Q60)');
          return;
        }

        if (!teamCommunication) {
          alert('Please answer: Team communication importance? (Q61)');
          return;
        }

        if (!payPremium) {
          alert('Please answer: Pay for premium features? (Q62)');
          return;
        }

        // Save section data
        const sectionData = {
          futureFeatures: Array.from(futureFeatures).map((el: any) => el.value),
          futureFeaturesOther: (document.querySelector('input[name="futureFeaturesOther"]') as HTMLInputElement)?.value || '',
          wearableIntegration: (wearableIntegration as HTMLInputElement).value,
          teamCommunication: (teamCommunication as HTMLInputElement).value,
          payPremium: (payPremium as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_13', JSON.stringify(sectionData));
        window.location.href = '/survey/14';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/12';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option, .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover, .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input, .checkbox-option input {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span, .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    @media (max-width: 768px) {
      .question-block { padding: 1.5rem; }
      .radio-option input, .checkbox-option input { min-width: 24px; min-height: 24px; }
    }
  </style>
</Layout>
