---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="HUSTLE Survey - Section 7 of 15">
  <div class="min-h-screen bg-zinc-900">
    <!-- Sticky Progress Bar -->
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 7 of 15</span>
            <span class="text-sm text-zinc-400">47%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 47%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Survey Form -->
    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">parent control & multi-kid management</h1>
          <p class="text-zinc-400 mb-12">
            managing multiple athletes and family access
          </p>

          <div class="space-y-12">
            <!-- Question 32: Multi-kid management -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                32. If you manage multiple athletes, how important is ONE account for all kids?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="multiKidAccount" value="critical" required />
                  <span>Critical (I'm not using separate apps per kid)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="multiKidAccount" value="very-important" />
                  <span>Very important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="multiKidAccount" value="somewhat-important" />
                  <span>Somewhat important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="multiKidAccount" value="not-applicable" />
                  <span>Not applicable (only 1 athlete)</span>
                </label>
              </div>
            </div>

            <!-- Question 33: Kid login -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                33. Should kids have their own login to see their own data?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="kidLogin" value="yes-see-everything" required />
                  <span>Yes, they should see everything</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="kidLogin" value="yes-parent-controls" />
                  <span>Yes, but parent controls what they see</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="kidLogin" value="no-parent-only" />
                  <span>No, parent-view only</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="kidLogin" value="dont-care" />
                  <span>Don't care</span>
                </label>
              </div>
            </div>

            <!-- Question 34: Private notes -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                34. Should parents be able to add private notes kids can't see?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="privateNotes" value="yes-absolutely" required />
                  <span>Yes, absolutely</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="privateNotes" value="maybe-depends" />
                  <span>Maybe, depends on the note</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="privateNotes" value="no-transparency" />
                  <span>No, full transparency</span>
                </label>
              </div>
            </div>

            <!-- Question 35: Export data -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                35. How important is exporting data (PDF, CSV) for recruiting or records?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="exportImportance" value="very-important" required />
                  <span>Very important - I need this for college recruiting</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="exportImportance" value="somewhat-important" />
                  <span>Somewhat important - nice to have</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="exportImportance" value="not-important" />
                  <span>Not important</span>
                </label>
              </div>
            </div>

            <!-- Question 36: Share with coaches -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                36. Would you want to share read-only access with coaches?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="coachAccess" value="yes-definitely" required />
                  <span>Yes, definitely</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="coachAccess" value="maybe-some-coaches" />
                  <span>Maybe, for some coaches</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="coachAccess" value="no-private" />
                  <span>No, I'd rather keep it private</span>
                </label>
              </div>
            </div>

            <!-- Question 37: Family plan pricing -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                37. Would you pay for family plan pricing if you have multiple kids?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="familyPlan" value="yes-if-saves" required />
                  <span>Yes, if it saves vs. individual plans</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="familyPlan" value="maybe-depends" />
                  <span>Maybe, depends on price</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="familyPlan" value="no-per-athlete" />
                  <span>No, I'd pay per athlete</span>
                </label>
              </div>
            </div>

            <!-- Question 38: Decision maker -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                38. Who should make decisions about the app in your household?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="decisionMaker" value="i-decide" required />
                  <span>I decide</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="decisionMaker" value="spouse-decides" />
                  <span>My spouse/partner decides</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="decisionMaker" value="we-decide-together" />
                  <span>We decide together</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="decisionMaker" value="child-decides" />
                  <span>My child decides</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="decisionMaker" value="family-decides" />
                  <span>We decide together as a family</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button
              type="button"
              id="back-btn"
              class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              ← back
            </button>

            <button
              type="button"
              id="next-btn"
              class="btn-primary px-8 py-3"
            >
              next section →
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const multiKidAccount = document.querySelector('input[name="multiKidAccount"]:checked');
        const kidLogin = document.querySelector('input[name="kidLogin"]:checked');
        const privateNotes = document.querySelector('input[name="privateNotes"]:checked');
        const exportImportance = document.querySelector('input[name="exportImportance"]:checked');
        const coachAccess = document.querySelector('input[name="coachAccess"]:checked');
        const familyPlan = document.querySelector('input[name="familyPlan"]:checked');
        const decisionMaker = document.querySelector('input[name="decisionMaker"]:checked');

        if (!multiKidAccount) {
          alert('Please answer: Multi-kid account importance? (Q32)');
          return;
        }

        if (!kidLogin) {
          alert('Please answer: Should kids have their own login? (Q33)');
          return;
        }

        if (!privateNotes) {
          alert('Please answer: Private parent notes? (Q34)');
          return;
        }

        if (!exportImportance) {
          alert('Please answer: Export data importance? (Q35)');
          return;
        }

        if (!coachAccess) {
          alert('Please answer: Share with coaches? (Q36)');
          return;
        }

        if (!familyPlan) {
          alert('Please answer: Family plan pricing? (Q37)');
          return;
        }

        if (!decisionMaker) {
          alert('Please answer: Who makes decisions? (Q38)');
          return;
        }

        // Save section data
        const sectionData = {
          multiKidAccount: (multiKidAccount as HTMLInputElement).value,
          kidLogin: (kidLogin as HTMLInputElement).value,
          privateNotes: (privateNotes as HTMLInputElement).value,
          exportImportance: (exportImportance as HTMLInputElement).value,
          coachAccess: (coachAccess as HTMLInputElement).value,
          familyPlan: (familyPlan as HTMLInputElement).value,
          decisionMaker: (decisionMaker as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_7', JSON.stringify(sectionData));
        window.location.href = '/survey/8';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/6';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option,
    .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover,
    .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input[type="radio"],
    .checkbox-option input[type="checkbox"] {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span,
    .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    /* Mobile optimization */
    @media (max-width: 768px) {
      .question-block {
        padding: 1.5rem;
      }

      .radio-option input[type="radio"],
      .checkbox-option input[type="checkbox"] {
        min-width: 24px;
        min-height: 24px;
      }
    }
  </style>
</Layout>
