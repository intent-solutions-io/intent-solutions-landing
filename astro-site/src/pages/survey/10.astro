---
import LayoutRedesign from '../../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="HUSTLE Survey - Section 10 of 15">
  <div class="min-h-screen bg-zinc-900">
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 10 of 15</span>
            <span class="text-sm text-zinc-400">67%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 67%"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">motivation & gamification</h1>
          <p class="text-zinc-400 mb-12">
            how do you prefer to celebrate achievements?
          </p>

          <div class="space-y-12">
            <!-- Question 48: Achievement badges -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                48. Would achievement badges motivate your child? (e.g., "Played 50 games", "Perfect attendance")
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="achievementBadges" value="yes-love-this" required />
                  <span>Yes, they'd love this</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="achievementBadges" value="maybe-for-some" />
                  <span>Maybe, for some kids</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="achievementBadges" value="no-add-pressure" />
                  <span>No, it might add pressure</span>
                </label>
              </div>
            </div>

            <!-- Question 49: Share achievements -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                49. Would you want to share achievements on social media from the app?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="shareAchievements" value="yes-if-child-approves" required />
                  <span>Yes, if my child approves</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="shareAchievements" value="no-keep-private" />
                  <span>No, I prefer to keep it private</span>
                </label>
              </div>
            </div>

            <!-- Question 50: Celebrate achievements -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                50. How do you prefer to celebrate your child's athletic achievements?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="celebrateAchievements" value="private-family" required />
                  <span>Private family recognition</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="celebrateAchievements" value="share-close-friends" />
                  <span>Share with close friends/family</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="celebrateAchievements" value="post-social-media" />
                  <span>Post on social media</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="celebrateAchievements" value="keep-low-key" />
                  <span>Keep it low-key</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="celebrateAchievements" value="let-child-decide" />
                  <span>Let my child decide</span>
                </label>
              </div>
            </div>

            <!-- Question 51: Leaderboards -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                51. Would leaderboards (among friends/teammates) be motivating or stressful?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="leaderboards" value="motivating-healthy" required />
                  <span>Motivating - healthy competition</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="leaderboards" value="depends-on-child" />
                  <span>Depends on the child</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="leaderboards" value="stressful-avoid" />
                  <span>Stressful - avoid this</span>
                </label>
              </div>
            </div>
          </div>

          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button type="button" id="back-btn" class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth">← back</button>
            <button type="button" id="next-btn" class="btn-primary px-8 py-3">next section →</button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const achievementBadges = document.querySelector('input[name="achievementBadges"]:checked');
        const shareAchievements = document.querySelector('input[name="shareAchievements"]:checked');
        const celebrateAchievements = document.querySelector('input[name="celebrateAchievements"]:checked');
        const leaderboards = document.querySelector('input[name="leaderboards"]:checked');

        if (!achievementBadges) {
          alert('Please answer: Achievement badges motivation? (Q48)');
          return;
        }

        if (!shareAchievements) {
          alert('Please answer: Share achievements on social media? (Q49)');
          return;
        }

        if (!celebrateAchievements) {
          alert('Please answer: How do you celebrate achievements? (Q50)');
          return;
        }

        if (!leaderboards) {
          alert('Please answer: Leaderboards motivating or stressful? (Q51)');
          return;
        }

        // Save section data
        const sectionData = {
          achievementBadges: (achievementBadges as HTMLInputElement).value,
          shareAchievements: (shareAchievements as HTMLInputElement).value,
          celebrateAchievements: (celebrateAchievements as HTMLInputElement).value,
          leaderboards: (leaderboards as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_10', JSON.stringify(sectionData));
        window.location.href = '/survey/11';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/9';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option, .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover, .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input, .checkbox-option input {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span, .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    .rating-option {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .rating-option input {
      width: 20px;
      height: 20px;
      cursor: pointer;
    }

    .rating-option span {
      color: rgb(228 228 231);
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .question-block { padding: 1.5rem; }
      .radio-option input, .checkbox-option input { min-width: 24px; min-height: 24px; }
    }
  </style>
</LayoutRedesign>
