---
import LayoutRedesign from '../../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="HUSTLE Survey - Section 12 of 15">
  <div class="min-h-screen bg-zinc-900">
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 12 of 15</span>
            <span class="text-sm text-zinc-400">80%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 80%"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">privacy & data ownership</h1>
          <p class="text-zinc-400 mb-12">
            your control over your child's athletic data
          </p>

          <div class="space-y-12">
            <!-- Question 55: Data privacy importance -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                55. How important is data privacy for your child's athletic records?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="dataPrivacy" value="extremely-important" required />
                  <span>Extremely important - this is sensitive</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="dataPrivacy" value="very-important" />
                  <span>Very important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="dataPrivacy" value="somewhat-important" />
                  <span>Somewhat important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="dataPrivacy" value="not-major-concern" />
                  <span>Not a major concern</span>
                </label>
              </div>
            </div>

            <!-- Question 56: Data ownership -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                56. Who should own the data?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="dataOwnership" value="i-own-can-delete" required />
                  <span>I own it, can delete anytime</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="dataOwnership" value="app-owns-i-access" />
                  <span>App owns it, I have access</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="dataOwnership" value="shared-ownership" />
                  <span>Shared ownership</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="dataOwnership" value="dont-care" />
                  <span>Don't care</span>
                </label>
              </div>
            </div>

            <!-- Question 57: Anonymized research data -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                57. Would you be comfortable with anonymized data being used for research (e.g., youth sports trends)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="anonymizedResearch" value="yes-if-anonymous" required />
                  <span>Yes, if fully anonymous</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="anonymizedResearch" value="maybe-depends" />
                  <span>Maybe, depends on what's shared</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="anonymizedResearch" value="no-keep-private" />
                  <span>No, keep my data private</span>
                </label>
              </div>
            </div>

            <!-- Question 58: Export and delete data -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                58. Should you be able to export and delete ALL data if you stop using the app?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="exportDeleteData" value="yes-absolutely-critical" required />
                  <span>Yes, absolutely (this is critical)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="exportDeleteData" value="yes-export-enough" />
                  <span>Yes, but export is enough</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="exportDeleteData" value="doesnt-matter" />
                  <span>Doesn't matter</span>
                </label>
              </div>
            </div>
          </div>

          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button type="button" id="back-btn" class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth">← back</button>
            <button type="button" id="next-btn" class="btn-primary px-8 py-3">next section →</button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const dataPrivacy = document.querySelector('input[name="dataPrivacy"]:checked');
        const dataOwnership = document.querySelector('input[name="dataOwnership"]:checked');
        const anonymizedResearch = document.querySelector('input[name="anonymizedResearch"]:checked');
        const exportDeleteData = document.querySelector('input[name="exportDeleteData"]:checked');

        if (!dataPrivacy) {
          alert('Please answer: Data privacy importance? (Q55)');
          return;
        }

        if (!dataOwnership) {
          alert('Please answer: Who should own the data? (Q56)');
          return;
        }

        if (!anonymizedResearch) {
          alert('Please answer: Comfortable with anonymized research? (Q57)');
          return;
        }

        if (!exportDeleteData) {
          alert('Please answer: Export and delete data capability? (Q58)');
          return;
        }

        // Save section data
        const sectionData = {
          dataPrivacy: (dataPrivacy as HTMLInputElement).value,
          dataOwnership: (dataOwnership as HTMLInputElement).value,
          anonymizedResearch: (anonymizedResearch as HTMLInputElement).value,
          exportDeleteData: (exportDeleteData as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_12', JSON.stringify(sectionData));
        window.location.href = '/survey/13';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/11';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option, .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover, .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input, .checkbox-option input {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span, .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    .rating-option {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .rating-option input {
      width: 20px;
      height: 20px;
      cursor: pointer;
    }

    .rating-option span {
      color: rgb(228 228 231);
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .question-block { padding: 1.5rem; }
      .radio-option input, .checkbox-option input { min-width: 24px; min-height: 24px; }
    }
  </style>
</LayoutRedesign>
