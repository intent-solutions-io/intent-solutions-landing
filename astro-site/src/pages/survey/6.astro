---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="HUSTLE Survey - Section 6 of 15">
  <div class="min-h-screen bg-zinc-900">
    <!-- Sticky Progress Bar -->
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 6 of 15</span>
            <span class="text-sm text-zinc-400">40%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 40%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Survey Form -->
    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">ccpiweb</h1>
          <p class="text-zinc-400 mb-12">
            what matters most when tracking games
          </p>

          <div class="space-y-12">
            <!-- Question 25: Game info importance (Select up to 5) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                25. For GAME/COMPETITION logs, what information is most important to track? (Select up to 5)
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="grid md:grid-cols-2 gap-3">
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="opponent" class="game-info-check" />
                  <span>Opponent name</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="result" class="game-info-check" />
                  <span>Result (Win/Loss/Tie)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="score" class="game-info-check" />
                  <span>Final score</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="minutes-played" class="game-info-check" />
                  <span>Minutes/time played</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="position" class="game-info-check" />
                  <span>Position played</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="goals-points" class="game-info-check" />
                  <span>Goals/Points scored</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="assists" class="game-info-check" />
                  <span>Assists</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="saves" class="game-info-check" />
                  <span>Saves (goalkeepers)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="defensive-stats" class="game-info-check" />
                  <span>Defensive stats (blocks, steals, tackles)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="performance-rating" class="game-info-check" />
                  <span>Personal performance rating (1-5)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="highlights" class="game-info-check" />
                  <span>Highlights/memorable moments</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="what-went-well" class="game-info-check" />
                  <span>What went well / what to improve</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="coach-feedback" class="game-info-check" />
                  <span>Coach feedback</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="weather" class="game-info-check" />
                  <span>Weather conditions</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="gameInfo" value="location" class="game-info-check" />
                  <span>Location/venue</span>
                </label>
              </div>

              <div class="mt-4">
                <label class="block text-sm text-zinc-400 mb-2">Other (please specify):</label>
                <input
                  type="text"
                  name="gameInfoOther"
                  class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                  placeholder="Other information..."
                />
              </div>

              <p class="text-sm text-zinc-500 mt-3">Select up to 5 options</p>
            </div>

            <!-- Question 26: Kids logging games -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                26. Should kids be able to log their own games?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="kidsLogging" value="yes-no-approval" required />
                  <span>Yes, with no parent approval needed</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="kidsLogging" value="yes-parent-verify" />
                  <span>Yes, but parent must verify before it counts</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="kidsLogging" value="no-parent-only" />
                  <span>No, parent-only logging</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="kidsLogging" value="doesnt-matter" />
                  <span>Doesn't matter</span>
                </label>
              </div>
            </div>

            <!-- Question 27: Photo/video uploads -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                27. Would you want photo/video uploads attached to game logs?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="photoVideo" value="yes-definitely" required />
                  <span>Yes, definitely</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="photoVideo" value="maybe-unlimited" />
                  <span>Maybe, if storage is unlimited</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="photoVideo" value="no-not-necessary" />
                  <span>No, not necessary</span>
                </label>
              </div>
            </div>

            <!-- Question 28: Emotional state tracking -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                28. How important is tracking "emotional state" after games? (confidence, frustration, joy, etc.)
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="emotionalState" value="very-important" required />
                  <span>Very important - mental game matters</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="emotionalState" value="somewhat-important" />
                  <span>Somewhat important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="emotionalState" value="not-important" />
                  <span>Not important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="emotionalState" value="never-thought" />
                  <span>Never thought about it</span>
                </label>
              </div>
            </div>

            <!-- Question 29: Weather/field conditions -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                29. Do you care about tracking weather/field conditions for games?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="weatherTracking" value="yes-affects-performance" required />
                  <span>Yes, it affects performance</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="weatherTracking" value="nice-to-have" />
                  <span>Nice to have, but not critical</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="weatherTracking" value="no-dont-care" />
                  <span>No, don't care</span>
                </label>
              </div>
            </div>

            <!-- Question 30: Physical soreness/injuries -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                30. Would you want to track physical soreness or minor injuries after games?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="sorenessTracking" value="yes-critical" required />
                  <span>Yes, this is critical</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="sorenessTracking" value="maybe-if-simple" />
                  <span>Maybe, if it's simple</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="sorenessTracking" value="no-not-necessary" />
                  <span>No, not necessary</span>
                </label>
              </div>
            </div>

            <!-- Question 31: Comparing games/trends -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                31. How important is being able to compare multiple games/seasons to see trends?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="trendImportance" value="extremely-important" required />
                  <span>Extremely important (this is the whole point)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="trendImportance" value="very-important" />
                  <span>Very important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="trendImportance" value="somewhat-important" />
                  <span>Somewhat important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="trendImportance" value="not-important" />
                  <span>Not important</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button
              type="button"
              id="back-btn"
              class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              ← back
            </button>

            <button
              type="button"
              id="next-btn"
              class="btn-primary px-8 py-3"
            >
              next section →
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Limit game info checkboxes to 5
      const gameInfoChecks = document.querySelectorAll('.game-info-check');
      gameInfoChecks.forEach(check => {
        check.addEventListener('change', () => {
          const checked = document.querySelectorAll('.game-info-check:checked');
          if (checked.length > 5) {
            (check as HTMLInputElement).checked = false;
            alert('Please select up to 5 items only');
          }
        });
      });

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const gameInfo = document.querySelectorAll('input[name="gameInfo"]:checked');
        const kidsLogging = document.querySelector('input[name="kidsLogging"]:checked');
        const photoVideo = document.querySelector('input[name="photoVideo"]:checked');
        const emotionalState = document.querySelector('input[name="emotionalState"]:checked');
        const weatherTracking = document.querySelector('input[name="weatherTracking"]:checked');
        const sorenessTracking = document.querySelector('input[name="sorenessTracking"]:checked');
        const trendImportance = document.querySelector('input[name="trendImportance"]:checked');

        if (gameInfo.length === 0) {
          alert('Please select at least one game information item (Q25)');
          return;
        }

        if (!kidsLogging) {
          alert('Please answer: Should kids log their own games? (Q26)');
          return;
        }

        if (!photoVideo) {
          alert('Please answer: Photo/video uploads? (Q27)');
          return;
        }

        if (!emotionalState) {
          alert('Please answer: Emotional state tracking? (Q28)');
          return;
        }

        if (!weatherTracking) {
          alert('Please answer: Weather/field conditions? (Q29)');
          return;
        }

        if (!sorenessTracking) {
          alert('Please answer: Soreness/injury tracking? (Q30)');
          return;
        }

        if (!trendImportance) {
          alert('Please answer: Comparing games/trends? (Q31)');
          return;
        }

        // Save section data
        const sectionData = {
          gameInfo: Array.from(gameInfo).map((el: any) => el.value),
          gameInfoOther: (document.querySelector('input[name="gameInfoOther"]') as HTMLInputElement)?.value || '',
          kidsLogging: (kidsLogging as HTMLInputElement).value,
          photoVideo: (photoVideo as HTMLInputElement).value,
          emotionalState: (emotionalState as HTMLInputElement).value,
          weatherTracking: (weatherTracking as HTMLInputElement).value,
          sorenessTracking: (sorenessTracking as HTMLInputElement).value,
          trendImportance: (trendImportance as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_6', JSON.stringify(sectionData));
        window.location.href = '/survey/7';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/5';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option,
    .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover,
    .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input[type="radio"],
    .checkbox-option input[type="checkbox"] {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span,
    .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    /* Mobile optimization */
    @media (max-width: 768px) {
      .question-block {
        padding: 1.5rem;
      }

      .radio-option input[type="radio"],
      .checkbox-option input[type="checkbox"] {
        min-width: 24px;
        min-height: 24px;
      }
    }
  </style>
</Layout>
