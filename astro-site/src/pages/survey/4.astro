---
import LayoutRedesign from '../../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="HUSTLE Survey - Section 4 of 15">
  <div class="min-h-screen bg-zinc-900">
    <!-- Sticky Progress Bar -->
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 4 of 15</span>
            <span class="text-sm text-zinc-400">27%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 27%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Survey Form -->
    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">your pain points</h1>
          <p class="text-zinc-400 mb-12">
            what hasn't worked for you in the past?
          </p>

          <div class="space-y-12">
            <!-- Question 17: Tried other apps -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                17. Have you tried other sports tracking apps before?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="triedOtherApps" value="yes-still-using" required />
                  <span>Yes, still using them</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="triedOtherApps" value="yes-stopped" />
                  <span>Yes, but stopped using them</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="triedOtherApps" value="no-never" />
                  <span>No, never tried any</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="triedOtherApps" value="didnt-know" />
                  <span>Didn't know they existed</span>
                </label>
              </div>
            </div>

            <!-- Question 18: Why stopped (Multi-select) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                18. If you stopped using an app, why? (Select all that apply)
              </label>

              <div class="space-y-3">
                <label class="checkbox-option">
                  <input type="checkbox" name="whyStopped" value="too-complicated" />
                  <span>Too complicated</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="whyStopped" value="missing-features" />
                  <span>Missing key features</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="whyStopped" value="poor-mobile" />
                  <span>Poor mobile experience</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="whyStopped" value="cost-too-much" />
                  <span>Cost too much</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="whyStopped" value="data-entry-slow" />
                  <span>Data entry took too long</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="whyStopped" value="kids-didnt-use" />
                  <span>Kids didn't use it</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="whyStopped" value="no-team-integration" />
                  <span>Didn't integrate with team/coach systems</span>
                </label>
              </div>

              <div class="mt-4">
                <label class="block text-sm text-zinc-400 mb-2">Other (please specify):</label>
                <input
                  type="text"
                  name="whyStoppedOther"
                  class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                  placeholder="Other reason..."
                />
              </div>
            </div>

            <!-- Question 19: Disappointment if can't use -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                19. If we built an app that solved these problems, how disappointed would you be if you couldn't use it?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="disappointmentLevel" value="very-disappointed" required />
                  <span>Very disappointed (this would be a game-changer)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="disappointmentLevel" value="somewhat-disappointed" />
                  <span>Somewhat disappointed (I'd miss it)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="disappointmentLevel" value="not-disappointed" />
                  <span>Not disappointed (nice to have, but not essential)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="disappointmentLevel" value="dont-need" />
                  <span>I don't need this</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button
              type="button"
              id="back-btn"
              class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              ← back
            </button>

            <button
              type="button"
              id="next-btn"
              class="btn-primary px-8 py-3"
            >
              next section →
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const triedOtherApps = document.querySelector('input[name="triedOtherApps"]:checked');
        const disappointmentLevel = document.querySelector('input[name="disappointmentLevel"]:checked');

        if (!triedOtherApps) {
          alert('Please answer: Have you tried other sports tracking apps? (Q17)');
          return;
        }

        if (!disappointmentLevel) {
          alert('Please answer: How disappointed would you be? (Q19)');
          return;
        }

        // Save section data
        const sectionData = {
          triedOtherApps: (triedOtherApps as HTMLInputElement).value,
          whyStopped: Array.from(document.querySelectorAll('input[name="whyStopped"]:checked')).map((el: any) => el.value),
          whyStoppedOther: (document.querySelector('input[name="whyStoppedOther"]') as HTMLInputElement)?.value || '',
          disappointmentLevel: (disappointmentLevel as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_4', JSON.stringify(sectionData));
        window.location.href = '/survey/5';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/3';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option,
    .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover,
    .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input[type="radio"],
    .checkbox-option input[type="checkbox"] {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span,
    .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    /* Mobile optimization */
    @media (max-width: 768px) {
      .question-block {
        padding: 1.5rem;
      }

      .radio-option input[type="radio"],
      .checkbox-option input[type="checkbox"] {
        min-width: 24px;
        min-height: 24px;
      }
    }
  </style>
</LayoutRedesign>
