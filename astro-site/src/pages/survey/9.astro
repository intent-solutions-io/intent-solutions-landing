---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Hustle Survey - Section 9 of 15">
  <div class="min-h-screen bg-zinc-900">
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 9 of 15</span>
            <span class="text-sm text-zinc-400">60%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 60%"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">analytics & insights</h1>
          <p class="text-zinc-400 mb-12">what data would help you make better decisions?</p>

          <div class="space-y-12">
            <!-- Question 35: Dashboard preferences (pick up to 4) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                35. Which dashboards would you use most? (Pick up to 4)
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="practice-hours" class="dashboard-check" />
                  <span>Total practice hours (weekly/monthly/season)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="private-training" class="dashboard-check" />
                  <span>Private training hours tracked</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="games-summary" class="dashboard-check" />
                  <span>Games/competitions + season summary</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="career-stats" class="dashboard-check" />
                  <span>Career stats (sport-specific totals)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="mental-health" class="dashboard-check" />
                  <span>Emotional/mental health patterns</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="injury-history" class="dashboard-check" />
                  <span>Injury history and body soreness trends</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="personal-records" class="dashboard-check" />
                  <span>Personal records and improvements</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="highlights" class="dashboard-check" />
                  <span>Highlight reel of favorite moments</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="recruiting" class="dashboard-check" />
                  <span>Progress toward college recruiting goals</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="comparison" class="dashboard-check" />
                  <span>Comparison to other athletes (anonymized)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="dashboards" value="season-improvement" class="dashboard-check" />
                  <span>Season-over-season improvement tracking</span>
                </label>
              </div>
              <p class="text-sm text-zinc-500 mt-3">Select up to 4 dashboards</p>
            </div>

            <!-- Question 36: Stats comparison interest -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                36. Would you want to see how your child's verified stats compare to others in their sport and grade?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="statsComparison" value="very-interested" required />
                  <span>Yes, very interested</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="statsComparison" value="somewhat-interested" />
                  <span>Somewhat interested</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="statsComparison" value="not-interested" />
                  <span>Not interested</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="statsComparison" value="concerned" />
                  <span>Concerned about this</span>
                </label>
              </div>
            </div>

            <!-- Question 37: Leaderboards comfort -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                37. How comfortable are you with anonymized leaderboards (e.g., "Top 10 freshmen in your sport/region")?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="leaderboardComfort" value="very-comfortable" required />
                  <span>Very comfortable</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="leaderboardComfort" value="somewhat-comfortable" />
                  <span>Somewhat comfortable</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="leaderboardComfort" value="unsure" />
                  <span>Unsure</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="leaderboardComfort" value="not-comfortable" />
                  <span>Not comfortable</span>
                </label>
              </div>
            </div>

            <!-- Question 38: Global benchmark opt-in -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                38. Would you opt-in to include your child's verified data in global benchmarks (fully anonymous)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="benchmarkOptIn" value="yes" required />
                  <span>Yes</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="benchmarkOptIn" value="maybe-control" />
                  <span>Maybe, if I can control what's shared</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="benchmarkOptIn" value="no" />
                  <span>No</span>
                </label>
              </div>
            </div>
          </div>

          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button type="button" id="back-btn" class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth">← back</button>
            <button type="button" id="next-btn" class="btn-primary px-8 py-3">next section →</button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Limit dashboards to 4 selections
      const dashboardChecks = document.querySelectorAll('.dashboard-check');
      dashboardChecks.forEach(check => {
        check.addEventListener('change', () => {
          const checked = document.querySelectorAll('.dashboard-check:checked');
          if (checked.length > 4) {
            (check as HTMLInputElement).checked = false;
            alert('Please select up to 4 dashboards');
          }
        });
      });

      nextBtn?.addEventListener('click', () => {
        const dashboards = document.querySelectorAll('input[name="dashboards"]:checked');
        const comparison = document.querySelector('input[name="statsComparison"]:checked');
        const leaderboard = document.querySelector('input[name="leaderboardComfort"]:checked');
        const benchmark = document.querySelector('input[name="benchmarkOptIn"]:checked');

        if (dashboards.length === 0) {
          alert('Please select at least one dashboard (up to 4)');
          return;
        }

        if (!comparison) {
          alert('Please answer: Stats comparison interest');
          return;
        }

        if (!leaderboard) {
          alert('Please answer: Leaderboard comfort level');
          return;
        }

        if (!benchmark) {
          alert('Please answer: Global benchmark opt-in');
          return;
        }

        const sectionData = {
          dashboards: Array.from(dashboards).map((el: any) => el.value),
          statsComparison: (comparison as HTMLInputElement).value,
          leaderboardComfort: (leaderboard as HTMLInputElement).value,
          benchmarkOptIn: (benchmark as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_9', JSON.stringify(sectionData));
        window.location.href = '/survey/10';
      });

      backBtn?.addEventListener('click', () => window.location.href = '/survey/8');
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option, .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover, .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input, .checkbox-option input {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span, .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    @media (max-width: 768px) {
      .question-block { padding: 1.5rem; }
      .radio-option input, .checkbox-option input { min-width: 24px; min-height: 24px; }
    }
  </style>
</Layout>
