---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Hustle Survey - Section 9 of 15">
  <div class="min-h-screen bg-zinc-900">
    <!-- Sticky Progress Bar -->
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 9 of 15</span>
            <span class="text-sm text-zinc-400">60%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 60%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Survey Form -->
    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">analytics & insights</h1>
          <p class="text-zinc-400 mb-12">
            what data would be most valuable to you?
          </p>

          <div class="space-y-12">
            <!-- Question 43: Insights value (Select up to 3) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                43. What kind of "insights" would be most valuable? (Select up to 3)
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="season-improvement" class="insights-check" />
                  <span>Season-over-season improvement trends</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="teammate-comparison" class="insights-check" />
                  <span>Comparison to teammates (anonymous)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="streaks" class="insights-check" />
                  <span>Streaks (games played, goals scored, etc.)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="position-benchmarks" class="insights-check" />
                  <span>Position-specific benchmarks</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="playing-time" class="insights-check" />
                  <span>Playing time analysis</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="performance-patterns" class="insights-check" />
                  <span>Performance patterns (home vs. away, weather impacts)</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="injury-trends" class="insights-check" />
                  <span>Injury/soreness trends</span>
                </label>
                <label class="checkbox-option">
                  <input type="checkbox" name="insights" value="mental-trends" class="insights-check" />
                  <span>Mental/emotional trends over time</span>
                </label>
              </div>

              <div class="mt-4">
                <label class="block text-sm text-zinc-400 mb-2">Other (please specify):</label>
                <input
                  type="text"
                  name="insightsOther"
                  class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                  placeholder="Other insights..."
                />
              </div>

              <p class="text-sm text-zinc-500 mt-3">Select up to 3 options</p>
            </div>

            <!-- Question 44: AI recommendations -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                44. Would you want AI-powered recommendations? (e.g., "Focus on footwork this week based on recent games")
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="aiRecommendations" value="yes-helpful" required />
                  <span>Yes, that sounds helpful</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="aiRecommendations" value="maybe-depends" />
                  <span>Maybe, depends on accuracy</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="aiRecommendations" value="no-dont-trust" />
                  <span>No, I don't trust AI for this</span>
                </label>
              </div>
            </div>

            <!-- Question 45: Visual progress -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                45. How important is seeing your child's progress over time with charts/graphs?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="visualProgress" value="very-important" required />
                  <span>Very important - visual progress is motivating</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="visualProgress" value="somewhat-important" />
                  <span>Somewhat important</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="visualProgress" value="not-important" />
                  <span>Not important - I just need raw data</span>
                </label>
              </div>
            </div>

            <!-- Question 46: Goal-setting features -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                46. Would you want goal-setting features? (e.g., "Score 10 goals this season")
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="goalSetting" value="yes-definitely" required />
                  <span>Yes, definitely</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="goalSetting" value="maybe-if-kid-into-it" />
                  <span>Maybe, if my kid is into it</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="goalSetting" value="no-too-much-pressure" />
                  <span>No, too much pressure</span>
                </label>
              </div>
            </div>

            <!-- Question 47: Celebrate milestones -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                47. Should the app celebrate milestones/achievements (badges, streaks, etc.)?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="celebrateMilestones" value="yes-kids-love" required />
                  <span>Yes, kids love gamification</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="celebrateMilestones" value="maybe-if-done-right" />
                  <span>Maybe, if done right</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="celebrateMilestones" value="no-keep-simple" />
                  <span>No, keep it simple</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button
              type="button"
              id="back-btn"
              class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              ← back
            </button>

            <button
              type="button"
              id="next-btn"
              class="btn-primary px-8 py-3"
            >
              next section →
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Limit insights to 3 selections
      const insightsChecks = document.querySelectorAll('.insights-check');
      insightsChecks.forEach(check => {
        check.addEventListener('change', () => {
          const checked = document.querySelectorAll('.insights-check:checked');
          if (checked.length > 3) {
            (check as HTMLInputElement).checked = false;
            alert('Please select up to 3 insights only');
          }
        });
      });

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const insights = document.querySelectorAll('input[name="insights"]:checked');
        const aiRecommendations = document.querySelector('input[name="aiRecommendations"]:checked');
        const visualProgress = document.querySelector('input[name="visualProgress"]:checked');
        const goalSetting = document.querySelector('input[name="goalSetting"]:checked');
        const celebrateMilestones = document.querySelector('input[name="celebrateMilestones"]:checked');

        if (insights.length === 0) {
          alert('Please select at least one insight type (Q43)');
          return;
        }

        if (!aiRecommendations) {
          alert('Please answer: AI-powered recommendations? (Q44)');
          return;
        }

        if (!visualProgress) {
          alert('Please answer: Visual progress importance? (Q45)');
          return;
        }

        if (!goalSetting) {
          alert('Please answer: Goal-setting features? (Q46)');
          return;
        }

        if (!celebrateMilestones) {
          alert('Please answer: Celebrate milestones? (Q47)');
          return;
        }

        // Save section data
        const sectionData = {
          insights: Array.from(insights).map((el: any) => el.value),
          insightsOther: (document.querySelector('input[name="insightsOther"]') as HTMLInputElement)?.value || '',
          aiRecommendations: (aiRecommendations as HTMLInputElement).value,
          visualProgress: (visualProgress as HTMLInputElement).value,
          goalSetting: (goalSetting as HTMLInputElement).value,
          celebrateMilestones: (celebrateMilestones as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_9', JSON.stringify(sectionData));
        window.location.href = '/survey/10';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/8';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option,
    .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover,
    .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input[type="radio"],
    .checkbox-option input[type="checkbox"] {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span,
    .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    /* Mobile optimization */
    @media (max-width: 768px) {
      .question-block {
        padding: 1.5rem;
      }

      .radio-option input[type="radio"],
      .checkbox-option input[type="checkbox"] {
        min-width: 24px;
        min-height: 24px;
      }
    }
  </style>
</Layout>
