---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Hustle Survey - Section 5 of 15">
  <div class="min-h-screen bg-zinc-900">
    <!-- Sticky Progress Bar -->
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 5 of 15</span>
            <span class="text-sm text-zinc-400">33%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 33%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Survey Form -->
    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">the app we're building</h1>
          <p class="text-zinc-400 mb-12">
            your feedback on our vision
          </p>

          <div class="space-y-12">
            <!-- Question 20: Interest level -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                20. We're building Hustle: a simple app to log games, practices, training, and track your child's athletic progress. How interested are you in this?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="interestLevel" value="extremely-interested" required />
                  <span>Extremely interested - sign me up now</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="interestLevel" value="very-interested" />
                  <span>Very interested - tell me more</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="interestLevel" value="somewhat-interested" />
                  <span>Somewhat interested - depends on features</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="interestLevel" value="not-very-interested" />
                  <span>Not very interested</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="interestLevel" value="not-interested" />
                  <span>Not interested at all</span>
                </label>
              </div>
            </div>

            <!-- Question 21: Import historical data -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                21. Would you import historical data (past games, stats) if we made it easy?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="importData" value="yes-definitely" required />
                  <span>Yes, definitely</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="importData" value="maybe-if-simple" />
                  <span>Maybe, if it's simple</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="importData" value="no-fresh-start" />
                  <span>No, fresh start is fine</span>
                </label>
              </div>
            </div>

            <!-- Question 22: Simple vs comprehensive -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                22. Which is more important for you?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="simpleVsDetailed" value="simple-fast" required />
                  <span>Simple and fast (fewer fields, quick logging)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="simpleVsDetailed" value="comprehensive" />
                  <span>Comprehensive and detailed (more fields, complete picture)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="simpleVsDetailed" value="balanced" />
                  <span>Balanced between both</span>
                </label>
              </div>
            </div>

            <!-- Question 23: Logging frequency -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                23. How often would you log activities?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="loggingFrequency" value="real-time" required />
                  <span>Immediately after every game/practice (real-time)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="loggingFrequency" value="few-hours" />
                  <span>Within a few hours</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="loggingFrequency" value="end-of-day" />
                  <span>End of each day</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="loggingFrequency" value="weekly" />
                  <span>Once a week</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="loggingFrequency" value="less-than-weekly" />
                  <span>Less than once a week</span>
                </label>
              </div>
            </div>

            <!-- Question 24: Who would log -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                24. Who would log the activities?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="whoLogs" value="parent" required />
                  <span>I would (parent)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="whoLogs" value="child" />
                  <span>My child would</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="whoLogs" value="both" />
                  <span>We'd both contribute</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="whoLogs" value="coach" />
                  <span>Coach would (if they had access)</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex justify-between items-center pt-8 mt-12 border-t border-zinc-800">
            <button
              type="button"
              id="back-btn"
              class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              ← back
            </button>

            <button
              type="button"
              id="next-btn"
              class="btn-primary px-8 py-3"
            >
              next section →
            </button>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nextBtn = document.getElementById('next-btn');
      const backBtn = document.getElementById('back-btn');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Validate and save section data
      nextBtn?.addEventListener('click', () => {
        // Validate required fields
        const interestLevel = document.querySelector('input[name="interestLevel"]:checked');
        const importData = document.querySelector('input[name="importData"]:checked');
        const simpleVsDetailed = document.querySelector('input[name="simpleVsDetailed"]:checked');
        const loggingFrequency = document.querySelector('input[name="loggingFrequency"]:checked');
        const whoLogs = document.querySelector('input[name="whoLogs"]:checked');

        if (!interestLevel) {
          alert('Please answer: How interested are you? (Q20)');
          return;
        }

        if (!importData) {
          alert('Please answer: Would you import historical data? (Q21)');
          return;
        }

        if (!simpleVsDetailed) {
          alert('Please answer: Simple or comprehensive? (Q22)');
          return;
        }

        if (!loggingFrequency) {
          alert('Please answer: How often would you log? (Q23)');
          return;
        }

        if (!whoLogs) {
          alert('Please answer: Who would log activities? (Q24)');
          return;
        }

        // Save section data
        const sectionData = {
          interestLevel: (interestLevel as HTMLInputElement).value,
          importData: (importData as HTMLInputElement).value,
          simpleVsDetailed: (simpleVsDetailed as HTMLInputElement).value,
          loggingFrequency: (loggingFrequency as HTMLInputElement).value,
          whoLogs: (whoLogs as HTMLInputElement).value
        };

        sessionStorage.setItem('survey_section_5', JSON.stringify(sectionData));
        window.location.href = '/survey/6';
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/4';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option,
    .checkbox-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover,
    .checkbox-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input[type="radio"],
    .checkbox-option input[type="checkbox"] {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span,
    .checkbox-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    /* Mobile optimization */
    @media (max-width: 768px) {
      .question-block {
        padding: 1.5rem;
      }

      .radio-option input[type="radio"],
      .checkbox-option input[type="checkbox"] {
        min-width: 24px;
        min-height: 24px;
      }
    }
  </style>
</Layout>
