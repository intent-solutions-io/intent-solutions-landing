---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="HUSTLE Survey - Section 15 of 15">
  <div class="min-h-screen bg-zinc-900">
    <!-- Sticky Progress Bar -->
    <div class="sticky top-0 z-50 bg-zinc-950 border-b border-zinc-800 py-4">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-zinc-400">section 15 of 15 - final step!</span>
            <span class="text-sm text-zinc-400">100%</span>
          </div>
          <div class="relative w-full h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="absolute top-0 left-0 h-full bg-zinc-200 rounded-full transition-all duration-300" style="width: 100%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Survey Form -->
    <section class="py-12">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-h1 font-bold text-zinc-50 mb-4">beta testing & contact</h1>
          <p class="text-zinc-400 mb-12">
            almost done! help us launch hustle and get 1 year free access
          </p>

          <form
            name="hustle-survey"
            method="POST"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            action="/survey/thank-you"
            class="space-y-12"
            id="final-form"
          >
            <!-- Netlify Forms -->
            <input type="hidden" name="form-name" value="hustle-survey" />

            <!-- Honeypot spam protection -->
            <p class="hidden">
              <label>Don't fill this out if you're human: <input name="bot-field" /></label>
            </p>

            <!-- All previous section data will be injected here as hidden fields -->
            <!-- CRITICAL: These fields must be pre-declared in HTML for Netlify Forms to detect them at build time -->
            <div id="hidden-data">
              <!-- Section 1 (1 field) -->
              <input type="hidden" name="consent" value="" />

              <!-- Section 2 (10 fields) -->
              <input type="hidden" name="numAthletes" value="" />
              <input type="hidden" name="grades" value="" />
              <input type="hidden" name="hoursPerWeek" value="" />
              <input type="hidden" name="collegeRecruitment" value="" />
              <input type="hidden" name="sports" value="" />
              <input type="hidden" name="sportsOther" value="" />
              <input type="hidden" name="competitionLevel" value="" />
              <input type="hidden" name="competitionLevelOther" value="" />
              <input type="hidden" name="clubsTeams" value="" />
              <input type="hidden" name="location" value="" />

              <!-- Section 3 (9 fields) -->
              <input type="hidden" name="trackingMethods" value="" />
              <input type="hidden" name="trackingMethodsOther" value="" />
              <input type="hidden" name="appsUsed" value="" />
              <input type="hidden" name="appsUsedOther" value="" />
              <input type="hidden" name="timeSpentManaging" value="" />
              <input type="hidden" name="trackGameStats" value="" />
              <input type="hidden" name="trackPractice" value="" />
              <input type="hidden" name="frustrations" value="" />
              <input type="hidden" name="frustrationsOther" value="" />
              <input type="hidden" name="oneAppImportance" value="" />

              <!-- Section 4-14 (remaining 60+ fields) -->
              <input type="hidden" name="interestLevel" value="" />
              <input type="hidden" name="importData" value="" />
              <input type="hidden" name="simpleVsDetailed" value="" />
              <input type="hidden" name="loggingFrequency" value="" />
              <input type="hidden" name="whoLogs" value="" />
              <input type="hidden" name="timeToLog" value="" />
              <input type="hidden" name="photoVideo" value="" />
              <input type="hidden" name="celebrateMilestones" value="" />
              <input type="hidden" name="goalSetting" value="" />
              <input type="hidden" name="gameInfo" value="" />
              <input type="hidden" name="gameInfoOther" value="" />
              <input type="hidden" name="insights" value="" />
              <input type="hidden" name="insightsOther" value="" />
              <input type="hidden" name="visualProgress" value="" />
              <input type="hidden" name="celebrateAchievements" value="" />
              <input type="hidden" name="shareAchievements" value="" />
              <input type="hidden" name="leaderboards" value="" />
              <input type="hidden" name="achievementBadges" value="" />
              <input type="hidden" name="privateNotes" value="" />
              <input type="hidden" name="sorenessTracking" value="" />
              <input type="hidden" name="weatherTracking" value="" />
              <input type="hidden" name="wearableIntegration" value="" />
              <input type="hidden" name="teamCommunication" value="" />
              <input type="hidden" name="coachAccess" value="" />
              <input type="hidden" name="kidLogin" value="" />
              <input type="hidden" name="kidsLogging" value="" />
              <input type="hidden" name="parentVerificationValue" value="" />
              <input type="hidden" name="verificationTimeLimit" value="" />
              <input type="hidden" name="coachVerification" value="" />
              <input type="hidden" name="verifiedBadgeUseful" value="" />
              <input type="hidden" name="futureFeatures" value="" />
              <input type="hidden" name="futureFeaturesOther" value="" />
              <input type="hidden" name="trendImportance" value="" />
              <input type="hidden" name="exportImportance" value="" />
              <input type="hidden" name="aiRecommendations" value="" />
              <input type="hidden" name="offlineImportance" value="" />
              <input type="hidden" name="customDays" value="" />
              <input type="hidden" name="addToHomeScreen" value="" />
              <input type="hidden" name="triedOtherApps" value="" />
              <input type="hidden" name="whyStopped" value="" />
              <input type="hidden" name="whyStoppedOther" value="" />
              <input type="hidden" name="disappointmentLevel" value="" />
              <input type="hidden" name="timeSavingsValue" value="" />
              <input type="hidden" name="multiKidAccount" value="" />
              <input type="hidden" name="familyPlan" value="" />
              <input type="hidden" name="payPremium" value="" />
              <input type="hidden" name="pricingModel" value="" />
              <input type="hidden" name="monthlyPrice" value="" />
              <input type="hidden" name="annualPrice" value="" />
              <input type="hidden" name="billingPreference" value="" />
              <input type="hidden" name="premiumFeatures" value="" />
              <input type="hidden" name="premiumFeaturesOther" value="" />
              <input type="hidden" name="decisionMaker" value="" />
              <input type="hidden" name="emotionalState" value="" />
              <input type="hidden" name="dataPrivacy" value="" />
              <input type="hidden" name="dataOwnership" value="" />
              <input type="hidden" name="exportDeleteData" value="" />
              <input type="hidden" name="anonymizedResearch" value="" />
            </div>

            <!-- Question 69: Beta Interest -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                69. Are you interested in beta testing this app?
                <span class="text-red-400 ml-1">*</span>
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="betaInterest" value="yes-signup" required />
                  <span>Yes! Sign me up for beta access + 1 year free</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="betaInterest" value="maybe" />
                  <span>Maybe, tell me more first</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="betaInterest" value="no-feedback-only" />
                  <span>No, just wanted to share feedback</span>
                </label>
              </div>
            </div>

            <!-- Question 70: Time Commitment -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                70. If selected for beta, how much time could you commit to testing and feedback?
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="timeCommitment" value="10-15min" />
                  <span>10-15 minutes per week (quick feedback)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeCommitment" value="30-45min" />
                  <span>30-45 minutes per week (regular testing)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeCommitment" value="1hr-plus" />
                  <span>1+ hours per week (power user testing)</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="timeCommitment" value="cant-commit" />
                  <span>Can't commit to specific time</span>
                </label>
              </div>
            </div>

            <!-- Question 71: Email (REQUIRED) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                71. Email address for beta access and updates:
                <span class="text-red-400 ml-1">*</span>
              </label>
              <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="your@email.com"
              />
              <p class="text-sm text-zinc-500 mt-2">
                We'll never share your email or spam you. Promise.
              </p>
            </div>

            <!-- Question 72: Phone (Optional) -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                72. Phone number (optional, for beta testing coordination):
              </label>
              <input
                type="tel"
                name="phone"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="(555) 123-4567"
              />
            </div>

            <!-- Question 73: Best Sports for Beta -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                73. Best sport(s) for us to focus on first in beta?
              </label>
              <input
                type="text"
                name="bestSportsForBeta"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="e.g., Soccer, Basketball..."
              />
            </div>

            <!-- Question 74: Video Interview -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                74. Would you be willing to do a 15-minute video interview to share your experience in more depth?
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="videoInterview" value="yes-love-to" />
                  <span>Yes, I'd love to help</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="videoInterview" value="maybe-timing" />
                  <span>Maybe, depends on timing</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="videoInterview" value="no-thanks" />
                  <span>No thanks</span>
                </label>
              </div>
            </div>

            <!-- Question 75: Sports Parent Groups -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                75. Are you active in sports parent groups (Facebook, team chats, etc.)?
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="parentGroups" value="very-active" />
                  <span>Yes, very active</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="parentGroups" value="somewhat-active" />
                  <span>Somewhat active</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="parentGroups" value="not-really" />
                  <span>Not really</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="parentGroups" value="no" />
                  <span>No</span>
                </label>
              </div>
            </div>

            <!-- Question 76: How They Heard -->
            <div class="question-block">
              <label class="block text-lg font-medium text-zinc-200 mb-4">
                76. How did you hear about this survey?
              </label>

              <div class="space-y-3">
                <label class="radio-option">
                  <input type="radio" name="heardAbout" value="social-media" />
                  <span>Social media</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="heardAbout" value="friend-recommendation" />
                  <span>Friend/parent recommendation</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="heardAbout" value="coach-shared" />
                  <span>Coach shared it</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="heardAbout" value="team-communication" />
                  <span>Team/club communication</span>
                </label>
                <label class="radio-option">
                  <input type="radio" name="heardAbout" value="online-search" />
                  <span>Online search</span>
                </label>
              </div>

              <div class="mt-4">
                <label class="block text-sm text-zinc-400 mb-2">Other (please specify):</label>
                <input
                  type="text"
                  name="heardAboutOther"
                  class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                  placeholder="Other source..."
                />
              </div>
            </div>

            <!-- Navigation -->
            <div class="flex justify-between items-center pt-8 border-t border-zinc-800">
              <button
                type="button"
                id="back-btn"
                class="px-6 py-3 text-zinc-400 hover:text-zinc-200 transition-smooth"
              >
                ← back
              </button>

              <button
                type="submit"
                id="submit-btn"
                class="btn-primary px-8 py-4 text-lg"
              >
                submit survey
              </button>
            </div>

            <!-- Legal Consent Notice -->
            <div class="mt-6 p-4 bg-zinc-800/30 border border-zinc-700/50 rounded-lg">
              <p class="text-center text-sm text-zinc-300 leading-relaxed">
                By signing up, you agree to our
                <a href="/terms" target="_blank" class="text-zinc-100 underline hover:text-white transition-smooth">Terms of Service</a>,
                <a href="/acceptable-use" target="_blank" class="text-zinc-100 underline hover:text-white transition-smooth">Acceptable Use Policy</a>, and
                <a href="/privacy" target="_blank" class="text-zinc-100 underline hover:text-white transition-smooth">Privacy Policy</a>.
              </p>
              <p class="text-center text-xs text-zinc-400 mt-2">
                This survey collects information about youth athletes. We are committed to protecting children's privacy in compliance with COPPA and GDPR.
              </p>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('final-form') as HTMLFormElement;
      const submitBtn = document.getElementById('submit-btn');
      const backBtn = document.getElementById('back-btn');
      const hiddenDataContainer = document.getElementById('hidden-data');

      // Check if user has consented
      const consent = sessionStorage.getItem('survey_consent');
      if (!consent || consent !== 'yes') {
        window.location.href = '/survey/1';
        return;
      }

      // Collect ALL sessionStorage data and populate hidden fields
      // CRITICAL: We now UPDATE existing hidden fields instead of creating new ones
      // This is required for Netlify Forms to detect fields at build time
      function injectSessionData() {
        const allData: any = {};

        // Collect all survey sections from sessionStorage
        for (let i = 1; i <= 15; i++) {
          const sectionData = sessionStorage.getItem(`survey_section_${i}`);
          if (sectionData) {
            try {
              const parsed = JSON.parse(sectionData);
              Object.assign(allData, parsed);
            } catch (e) {
              console.error(`Error parsing section ${i}:`, e);
            }
          }
        }

        console.log('📋 Collected survey data from sessionStorage:', allData);

        // Update values of pre-existing hidden fields
        let fieldsPopulated = 0;
        Object.entries(allData).forEach(([key, value]) => {
          const input = document.querySelector(`input[name="${key}"]`) as HTMLInputElement;

          if (input) {
            if (Array.isArray(value)) {
              // For arrays (checkboxes): join with comma or JSON
              input.value = value.length > 0 ? value.join(', ') : '';
            } else {
              // For single values
              input.value = String(value);
            }
            fieldsPopulated++;
          } else {
            console.warn(`⚠️ Field "${key}" not found in hidden fields`);
          }
        });

        console.log(`✅ Populated ${fieldsPopulated} hidden fields for Netlify submission`);

        // Debug: Show what will be submitted
        const allHiddenFields = Array.from(document.querySelectorAll('#hidden-data input[type="hidden"]')) as HTMLInputElement[];
        const filledFields = allHiddenFields.filter(input => input.value !== '');
        console.log(`📊 Total hidden fields: ${allHiddenFields.length}, Filled: ${filledFields.length}`);
      }

      // Inject session data on page load
      injectSessionData();

      // Handle form submission
      form?.addEventListener('submit', (e) => {
        const betaInterest = document.querySelector('input[name="betaInterest"]:checked');
        const email = document.querySelector('input[name="email"]') as HTMLInputElement;

        if (!betaInterest) {
          e.preventDefault();
          alert('Please answer: Are you interested in beta testing?');
          return;
        }

        if (!email || !email.value) {
          e.preventDefault();
          alert('Please provide your email address');
          return;
        }

        // Save final section data
        const finalData = {
          betaInterest: (betaInterest as HTMLInputElement).value,
          timeCommitment: (document.querySelector('input[name="timeCommitment"]:checked') as HTMLInputElement)?.value || '',
          email: email.value,
          phone: (document.querySelector('input[name="phone"]') as HTMLInputElement)?.value || '',
          bestSportsForBeta: (document.querySelector('input[name="bestSportsForBeta"]') as HTMLInputElement)?.value || '',
          videoInterview: (document.querySelector('input[name="videoInterview"]:checked') as HTMLInputElement)?.value || '',
          parentGroups: (document.querySelector('input[name="parentGroups"]:checked') as HTMLInputElement)?.value || '',
          heardAbout: (document.querySelector('input[name="heardAbout"]:checked') as HTMLInputElement)?.value || '',
          heardAboutOther: (document.querySelector('input[name="heardAboutOther"]') as HTMLInputElement)?.value || ''
        };

        sessionStorage.setItem('survey_section_15', JSON.stringify(finalData));

        // Let form submit naturally to Netlify
        // After successful submission, Netlify will redirect to /survey/thank-you
        // Clear sessionStorage after a short delay to ensure form submits
        setTimeout(() => {
          sessionStorage.clear();
        }, 1000);
      });

      // Back button
      backBtn?.addEventListener('click', () => {
        window.location.href = '/survey/14';
      });
    });
  </script>

  <style>
    .question-block {
      background: rgba(var(--color-bg-secondary), 0.3);
      padding: 2rem;
      border-radius: 0.75rem;
      border: 1px solid rgb(39 39 42 / 0.2);
    }

    .radio-option {
      display: flex;
      align-items: start;
      padding: 1rem;
      background: rgba(var(--color-bg-secondary), 0.5);
      border: 1px solid rgb(39 39 42);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .radio-option:hover {
      border-color: rgb(161 161 170);
      background: rgb(39 39 42 / 0.8);
    }

    .radio-option input[type="radio"] {
      margin-top: 0.125rem;
      margin-right: 0.75rem;
      min-width: 20px;
      min-height: 20px;
      cursor: pointer;
    }

    .radio-option span {
      color: rgb(228 228 231);
      flex: 1;
    }

    @media (max-width: 768px) {
      .question-block {
        padding: 1.5rem;
      }

      .radio-option input[type="radio"] {
        min-width: 24px;
        min-height: 24px;
      }
    }
  </style>
</Layout>
