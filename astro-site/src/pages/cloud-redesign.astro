---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="Cloud & Google Cloud Architecture - Intent Solutions">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge">Cloud & Data</span>
        </div>

        <h1 class="hero-title">
          Google Cloud foundations<br />built for speed and safety
        </h1>

        <p class="hero-description">
          From Vertex AI pipelines to BigQuery analytics and Firebase backends, we build cloud systems that ship fast,
          stay compliant, and remain simple enough for your team to maintain.
        </p>

        <div class="hero-ctas">
          <a href="#contact" class="btn btn-primary btn-lg">
            Schedule a Cloud Workshop
          </a>
          <a href="#capabilities" class="btn btn-secondary btn-lg">
            View Capabilities
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Capabilities Section -->
  <section class="section capabilities-section" id="capabilities">
    <div class="container">
      <div class="section-header">
        <h2>Core Capabilities</h2>
        <p>End-to-end Google Cloud services optimized for AI, data, and modern application development.</p>
      </div>

      <div class="capabilities-grid">
        <div class="capability-card">
          <h3>Vertex AI Pipelines</h3>
          <p>
            Model training, evaluation, and deployment workflows with automated guardrails and rollback.
          </p>
        </div>

        <div class="capability-card">
          <h3>BigQuery Analytics</h3>
          <p>
            Data warehouses with dbt, scheduled transformations, and Looker Studio dashboards your ops team can trust.
          </p>
        </div>

        <div class="capability-card">
          <h3>Firebase / Firestore</h3>
          <p>
            Real-time application backends with security rules, multitenant support, and offline-first UX.
          </p>
        </div>

        <div class="capability-card">
          <h3>Cloud Run & Functions</h3>
          <p>
            Serverless APIs, cron jobs, and automation endpoints that scale without upkeep.
          </p>
        </div>

        <div class="capability-card">
          <h3>Identity & Access</h3>
          <p>
            IAM, service accounts, and workload identity federation configured to keep auditors happy.
          </p>
        </div>

        <div class="capability-card">
          <h3>Observability</h3>
          <p>
            Cloud Logging, Metrics, and Grafana dashboards wired from day one so issues surface immediately.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement Blueprint Section -->
  <section class="section blueprint-section">
    <div class="container">
      <div class="blueprint-grid">
        <div class="blueprint-content">
          <h2>Engagement Blueprint</h2>
          <ol class="blueprint-list">
            <li>Audit your current architecture and capture success metrics.</li>
            <li>Design reference architecture diagrams and IaC templates.</li>
            <li>Implement environments with CI/CD, testing, and monitoring hooks.</li>
            <li>Roll out to production with training for your engineers and operators.</li>
          </ol>
          <p class="blueprint-note">
            Most foundations deploy within four weeks, with optional retained support for continuous optimization.
          </p>
        </div>

        <div class="tooling-card">
          <h3>Tooling We Lean On</h3>
          <ul class="tooling-list">
            <li>Terraform, Pulumi, and Google Cloud Deploy for repeatable infrastructure.</li>
            <li>Cloud Build, GitHub Actions, and Artifact Registry for delivery pipelines.</li>
            <li>Secret Manager + KMS for key rotation and least privilege access.</li>
            <li>Cloud Armor, VPC Service Controls, and BeyondCorp for secure perimeters.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="section why-section">
    <div class="container">
      <div class="section-header">
        <h2>Why Operators Choose Intent Solutions</h2>
        <p>We build cloud foundations that empower your team to ship confidently and scale sustainably.</p>
      </div>

      <div class="why-grid">
        <div class="why-card">
          <h3>Ship Fast, Stay Sane</h3>
          <p>
            We prioritize workable MVPs with clear handoff docs instead of sprawling multi-quarter projects.
          </p>
        </div>

        <div class="why-card">
          <h3>Operator-First Communication</h3>
          <p>
            Weekly syncs, shared Kanban boards, and transparent burn rates keep leadership aligned.
          </p>
        </div>

        <div class="why-card">
          <h3>Compliance Ready</h3>
          <p>
            Access policies, logging, and backup strategies tuned for HIPAA, SOC2, PCI, or CJIS environments.
          </p>
        </div>

        <div class="why-card">
          <h3>Handoff Without Drama</h3>
          <p>
            Internal teams get training, runbooks, and co-working sessions so they feel confident owning the stack.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA + FAQ Section -->
  <section class="section cta-faq-section" id="contact">
    <div class="container">
      <div class="cta-faq-grid">
        <div class="cta-content">
          <h2>Let's tune your cloud roadmap</h2>
          <p>
            Bring your current diagrams (or napkin sketches). We'll highlight gaps, quick wins, and rollout strategies.
          </p>
          <a href="mailto:jeremy@intentsolutions.io" class="btn btn-primary btn-lg">
            Schedule a Cloud Workshop
          </a>
        </div>

        <div class="faq-card">
          <h3>Frequently Asked</h3>
          <div class="faq-item">
            <p class="faq-question">Do you only work on Google Cloud?</p>
            <p class="faq-answer">GCP is home base, but we bridge to AWS, Azure, and on-prem systems when needed.</p>
          </div>
          <div class="faq-item">
            <p class="faq-question">Can you support us after launch?</p>
            <p class="faq-answer">Yes—choose a retainer for monitoring, cost tuning, and roadmap execution.</p>
          </div>
          <div class="faq-item">
            <p class="faq-question">What about data migrations?</p>
            <p class="faq-answer">We provide migration runbooks, rehearsal plans, and rollback strategies to keep stakeholders calm.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</LayoutRedesign>

<style>
  /* Hero Section */
  .hero-section {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, rgb(var(--color-bg-secondary)) 0%, rgb(var(--color-bg-primary)) 100%);
  }

  @media (min-width: 768px) {
    .hero-section {
      padding: 8rem 0 6rem;
    }
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-badge {
    margin-bottom: 1.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-accent-primary));
    background-color: rgb(var(--color-accent-light));
    border: 1px solid rgb(var(--color-accent-lighter));
    border-radius: var(--radius-full);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-text-primary));
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 2.5rem;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Capabilities Section */
  .capabilities-section {
    background-color: white;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .capabilities-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .capability-card {
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: all var(--transition-base);
  }

  .capability-card:hover {
    border-color: rgb(var(--color-accent-primary));
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .capability-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: rgb(var(--color-text-primary));
  }

  .capability-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  /* Blueprint Section */
  .blueprint-section {
    background-color: rgb(var(--color-bg-secondary));
  }

  .blueprint-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .blueprint-grid {
      grid-template-columns: 1fr;
    }
  }

  .blueprint-content h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: rgb(var(--color-text-primary));
  }

  .blueprint-list {
    list-style: decimal;
    padding-left: 1.5rem;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .blueprint-list li {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
  }

  .blueprint-note {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgb(var(--color-text-tertiary));
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid rgb(var(--color-border));
  }

  .tooling-card {
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .tooling-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-text-primary));
  }

  .tooling-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tooling-list li {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    padding-left: 1.25rem;
    position: relative;
  }

  .tooling-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: rgb(var(--color-accent-primary));
  }

  /* Why Section */
  .why-section {
    background-color: white;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .why-card {
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .why-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: rgb(var(--color-text-primary));
  }

  .why-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  /* CTA + FAQ Section */
  .cta-faq-section {
    background-color: rgb(var(--color-bg-secondary));
  }

  .cta-faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .cta-faq-grid {
      grid-template-columns: 1fr;
    }
  }

  .cta-content h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: rgb(var(--color-text-primary));
  }

  .cta-content p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 2rem;
  }

  .faq-card {
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .faq-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-text-primary));
  }

  .faq-item {
    margin-bottom: 1.5rem;
  }

  .faq-item:last-child {
    margin-bottom: 0;
  }

  .faq-question {
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgb(var(--color-text-primary));
    margin-bottom: 0.5rem;
  }

  .faq-answer {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }
</style>
