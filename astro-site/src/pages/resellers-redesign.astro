---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="Distribution Partner Program | Intent Solutions">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge">Distribution Partner Program</span>
        </div>

        <h1 class="hero-title">
          You sell, we host
        </h1>

        <p class="hero-description">
          Become a distribution channel for our AI solutions. Your clients get tenant access to our
          in-house systems—we handle the infrastructure, you own the relationship.
          Model- and cloud-agnostic. Vertex-first security. No lock-in.
        </p>

        <div class="hero-info-box">
          <p><strong>How it works:</strong> You bring clients. We provision tenants. They get hosted AI solutions.</p>
        </div>

        <div class="hero-ctas">
          <a href="#contact" class="btn btn-primary btn-lg">
            Become a Partner
          </a>
          <a href="#catalog" class="btn btn-secondary btn-lg">
            View Solutions Catalog
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="section value-section">
    <div class="container">
      <div class="section-header">
        <h2>Distribution Channel for Hosted AI Solutions</h2>
      </div>

      <div class="value-grid">
        <div class="value-card">
          <h3>Tenant Provisioning</h3>
          <p>
            Each of your clients gets their own isolated tenant on our infrastructure. Separate
            data, separate configs, shared platform.
          </p>
        </div>

        <div class="value-card">
          <h3>White-Label Access</h3>
          <p>
            Your brand on the UI. Clients interact with your logo and your domain—they access
            our hosted systems through you.
          </p>
        </div>

        <div class="value-card">
          <h3>We Handle Operations</h3>
          <p>
            Infrastructure, monitoring, updates, incident response. We run everything—you focus
            on sales and client relationships.
          </p>
        </div>

        <div class="value-card">
          <h3>Scale Without Overhead</h3>
          <p>
            Add clients without adding infrastructure. Each new tenant is a configuration, not
            a deployment project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ideal Partners Section -->
  <section class="section partners-section">
    <div class="container">
      <div class="section-header">
        <h2>Ideal Distribution Partners</h2>
      </div>

      <div class="partners-list">
        <div class="partner-card">
          <h3>Agencies Wanting to Offer AI Without Building Infrastructure</h3>
          <p>
            You have clients asking for AI solutions. We give you tenant access to hosted
            systems you can resell under your brand.
          </p>
        </div>

        <div class="partner-card">
          <h3>Vertical Specialists Who Know Their Market</h3>
          <p>
            You understand healthcare, finance, or legal. We provide the hosted AI platform—you
            configure tenants for your vertical.
          </p>
        </div>

        <div class="partner-card">
          <h3>Consultancies Adding AI to Their Service Mix</h3>
          <p>
            Expand from advisory to hosted solutions. We provision tenants—you own the client
            relationship and set your margins.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement Models Section -->
  <section class="section engagement-section">
    <div class="container">
      <div class="section-header">
        <h2>Partner Engagement Models</h2>
      </div>

      <div class="engagement-grid">
        <div class="engagement-card">
          <h3>Rev-Share Partnership</h3>
          <div class="price">$0 upfront</div>
          <p class="description">
            Revenue share on each tenant you bring. We host the solution, you bring clients.
            Good for testing the partnership.
          </p>
          <ul class="features">
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>No upfront cost to partner</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>We provision tenants for your clients</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Aligned incentives on growth</span>
            </li>
          </ul>
        </div>

        <div class="engagement-card">
          <h3>Wholesale Tenant Pricing</h3>
          <div class="price">Fixed per-tenant rate</div>
          <p class="description">
            Fixed wholesale cost per tenant. You set your retail price and keep the margin.
            Predictable costs for you.
          </p>
          <ul class="features">
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Predictable cost per tenant</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>You control retail pricing</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>White-label included</span>
            </li>
          </ul>
        </div>

        <div class="engagement-card">
          <h3>Partner Retainer</h3>
          <div class="price">Monthly partnership</div>
          <p class="description">
            Monthly retainer for priority support, custom configurations, and dedicated
            onboarding for your clients.
          </p>
          <ul class="features">
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Priority tenant provisioning</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Custom configuration support</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Dedicated onboarding assistance</span>
            </li>
          </ul>
        </div>

        <div class="engagement-card">
          <h3>Per-Tenant Managed Service</h3>
          <div class="price">Flat + usage</div>
          <p class="description">
            Flat platform fee per tenant + usage at provider list prices. Full managed
            service—we handle everything.
          </p>
          <ul class="features">
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Usage at provider list prices</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Full managed operations</span>
            </li>
            <li>
              <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Budget caps and alerts per tenant</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="onboarding-note">
        <p>
          <strong>Onboarding:</strong> $1,500 one-time setup covers partner
          portal access, white-label configuration, and first tenant provisioning
        </p>
      </div>
    </div>
  </section>

  <!-- Solutions Catalog Section -->
  <section class="section catalog-section" id="catalog">
    <div class="container">
      <div class="section-header">
        <h2>Hosted Solutions Catalog</h2>
      </div>

      <div class="catalog-grid">
        <div class="catalog-card">
          <h3>Outbound SDR Agents</h3>
          <ul>
            <li>• Research + enrich leads</li>
            <li>• ICP scoring</li>
            <li>• Personalized outreach</li>
            <li>• Meeting intelligence</li>
          </ul>
          <span class="setup-time">Tenant setup: 1–2 weeks</span>
        </div>

        <div class="catalog-card">
          <h3>Knowledge Search + Grounded Answers</h3>
          <ul>
            <li>• Docs and wiki integration</li>
            <li>• Vector search</li>
            <li>• Citation tracking</li>
            <li>• Access controls</li>
          </ul>
          <span class="setup-time">Tenant setup: 1–2 weeks</span>
        </div>

        <div class="catalog-card">
          <h3>Support Triage Agents</h3>
          <ul>
            <li>• CRM + ticket integrations</li>
            <li>• Response drafting</li>
            <li>• Escalation rules</li>
            <li>• Churn prediction</li>
          </ul>
          <span class="setup-time">Tenant setup: 2–3 weeks</span>
        </div>

        <div class="catalog-card">
          <h3>Private AI Portal</h3>
          <ul>
            <li>• Internal ChatGPT-style UI</li>
            <li>• Model selection (Claude, GPT, Gemini)</li>
            <li>• Company data integration</li>
            <li>• Usage tracking</li>
          </ul>
          <span class="setup-time">Tenant setup: 1–2 weeks</span>
        </div>

        <div class="catalog-card">
          <h3>Automation + Agent Pairing</h3>
          <ul>
            <li>• n8n for orchestration glue</li>
            <li>• Vertex for agent workflows</li>
            <li>• API integrations</li>
            <li>• Scheduled jobs</li>
          </ul>
          <span class="setup-time">Tenant setup: 1–2 weeks</span>
        </div>

        <div class="catalog-card">
          <h3>Custom Configuration</h3>
          <p>
            Combine solutions, custom integrations, specialized workflows. We configure the
            tenant to match client needs.
          </p>
          <span class="setup-time">Setup varies by complexity</span>
        </div>
      </div>

      <div class="catalog-note">
        <p>
          <strong>Note:</strong> All solutions are model- and cloud-agnostic. Tenants can use
          Claude, OpenAI, Gemini, Llama, Mistral, Qwen, fine-tunes, or local models based on
          requirements.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="section process-section">
    <div class="container">
      <div class="section-header">
        <h2>How the Partnership Works</h2>
      </div>

      <div class="process-steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Partner Onboarding</h3>
            <p>
              Initial call to understand your market, client types, and goals. We set up your
              partner portal and white-label configuration.
            </p>
          </div>
        </div>

        <div class="step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>You Bring a Client</h3>
            <p>
              When you close a deal, tell us the client's requirements. We assess fit and
              confirm which hosted solution works best.
            </p>
          </div>
        </div>

        <div class="step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>We Provision Their Tenant</h3>
            <p>
              We create an isolated tenant on our infrastructure. Separate data, separate
              configs, your branding. Client gets access credentials.
            </p>
          </div>
        </div>

        <div class="step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Configure and Customize</h3>
            <p>
              We configure the tenant for your client's specific workflows—integrations, models,
              budget caps, access controls.
            </p>
          </div>
        </div>

        <div class="step">
          <div class="step-number">5</div>
          <div class="step-content">
            <h3>Client Goes Live</h3>
            <p>
              Tenant is active with monitoring, usage tracking, and alerts. Client interacts
              with your branded interface—we handle the backend.
            </p>
          </div>
        </div>

        <div class="step">
          <div class="step-number">6</div>
          <div class="step-content">
            <h3>Ongoing Managed Service</h3>
            <p>
              We handle infrastructure, updates, monitoring, and incident response. You handle
              the client relationship.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Partners Get Section -->
  <section class="section benefits-section">
    <div class="container">
      <div class="section-header">
        <h2>What Partners Get</h2>
      </div>

      <div class="benefits-grid">
        <div class="benefit-card">
          <h3>Partner Portal Access</h3>
          <p>
            Dashboard to view your tenants, usage metrics, billing, and client status at a glance.
          </p>
        </div>

        <div class="benefit-card">
          <h3>Tenant Management</h3>
          <p>
            Request new tenants, configure settings, view logs, manage access controls for each client.
          </p>
        </div>

        <div class="benefit-card">
          <h3>Usage Dashboards and Budgets</h3>
          <p>
            Per-tenant monitoring, cost tracking, usage alerts, performance metrics visible to you and your clients.
          </p>
        </div>

        <div class="benefit-card">
          <h3>White-Label Configuration</h3>
          <p>
            Your branding on the interface—logo, colors, domain. Clients see your brand, not ours.
          </p>
        </div>

        <div class="benefit-card">
          <h3>Sales Enablement Kit</h3>
          <p>
            One-pagers, demo scripts, pitch deck, objection handling guides to help you close deals.
          </p>
        </div>

        <div class="benefit-card">
          <h3>Client-Facing Documentation</h3>
          <p>
            White-labeled user guides, onboarding docs, and support resources for your clients.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Vertex Section -->
  <section class="section vertex-section">
    <div class="container">
      <div class="section-header">
        <h2>Why Vertex for Production</h2>
      </div>

      <div class="vertex-content">
        <p class="vertex-intro">
          Production agents benefit from Vertex defaults and controls. We still support
          self-hosted and low-code when the risk profile and budget fit.
        </p>

        <div class="vertex-comparison">
          <div class="comparison-column">
            <h3>Vertex Agent Engine</h3>
            <ul>
              <li>• IAM, per-workspace service accounts</li>
              <li>• VPC options, Private Service Connect</li>
              <li>• Secret Manager, rotation, SLSA provenance</li>
              <li>• Audit logs, SIEM export, policy controls</li>
              <li>• Evals, guardrails, rollback gates</li>
            </ul>
          </div>

          <div class="comparison-column">
            <h3>Self-Hosted / Low-Code</h3>
            <ul>
              <li>• Good for orchestration glue</li>
              <li>• Quick integration wins</li>
              <li>• Lower volume automations</li>
              <li>• Air-gapped requirements</li>
              <li>• Budget-constrained projects</li>
            </ul>
          </div>
        </div>

        <div class="vertex-link">
          <a href="/learn/security">
            Learn: Security comparison (Vertex vs self-hosted) →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Reference Section -->
  <section class="section pricing-ref-section">
    <div class="container">
      <div class="section-header">
        <h2>Partner Pricing Reference</h2>
      </div>

      <div class="pricing-ref-grid">
        <div class="pricing-ref-card">
          <h3>Partner Onboarding</h3>
          <div class="ref-price">$1,500 one-time</div>
          <p>
            Portal setup, white-label configuration, first tenant provisioning, sales kit.
          </p>
        </div>

        <div class="pricing-ref-card">
          <h3>Per-Tenant Fee</h3>
          <div class="ref-price">From $497/mo</div>
          <p>
            Flat platform fee per tenant + usage at provider list prices. You set retail pricing.
          </p>
        </div>

        <div class="pricing-ref-card">
          <h3>Enterprise Tenants</h3>
          <div class="ref-price">From $1,997/mo</div>
          <p>
            Dedicated resources, priority support, compliance documentation, custom SLAs.
          </p>
        </div>

        <div class="pricing-ref-card">
          <h3>Optional Add-Ons</h3>
          <div class="ref-price">Custom pricing</div>
          <p>
            Custom integrations, compliance audits (HIPAA, SOC 2), dedicated support hours.
          </p>
        </div>
      </div>

      <div class="pricing-ref-note">
        <p>
          <strong>Usage pricing:</strong> Billed at provider list prices
          for AI models, search, storage, and compute. Per-tenant budgets enforced with caps,
          alerts, and prepaid blocks.
        </p>
        <p class="disclaimer">
          Prices subject to change. Contact us for current partner pricing.
        </p>
        <div class="learn-link">
          <a href="/learn/pricing">
            Learn: How pricing works →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="section contact-form-section" id="contact">
    <div class="container">
      <div class="form-wrapper">
        <h2>Let's Talk</h2>
        <p class="form-intro">
          Whether you're exploring partnership options, need a hosted AI solution for your business,
          or just want to learn more—we'd love to hear from you.
        </p>

        <form
          name="partner-inquiry"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="partner-form"
        >
          <input type="hidden" name="form-name" value="partner-inquiry" />
          <p class="hidden">
            <label>
              Don't fill this out if you're human: <input name="bot-field" />
            </label>
          </p>

          <div class="form-group">
            <label for="company-name">Company Name</label>
            <input
              type="text"
              id="company-name"
              name="company-name"
              required
              placeholder="Your Company"
            />
          </div>

          <div class="form-group">
            <label for="contact-name">Your Name</label>
            <input
              type="text"
              id="contact-name"
              name="contact-name"
              required
              placeholder="Your Name"
            />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@company.com"
            />
          </div>

          <div class="form-group">
            <label for="interest">What are you interested in?</label>
            <select id="interest" name="interest">
              <option value="exploring">Just exploring options</option>
              <option value="distribution-partner">Becoming a distribution partner</option>
              <option value="direct-client">AI solution for my business</option>
              <option value="learn-more">Learning more about your services</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Tell us more (optional)</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="What are you looking to accomplish?"
            ></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-block">
            Get in Touch
          </button>

          <p class="form-note">
            We'll get back to you within 1 business day.
          </p>
        </form>
      </div>
    </div>
  </section>
</LayoutRedesign>

<style>
  /* Hero Section */
  .hero-section {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, rgb(var(--color-bg-secondary)) 0%, rgb(var(--color-bg-primary)) 100%);
  }

  @media (min-width: 768px) {
    .hero-section {
      padding: 8rem 0 6rem;
    }
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-badge {
    margin-bottom: 1.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-accent-primary));
    background-color: rgb(var(--color-accent-light));
    border: 1px solid rgb(var(--color-accent-lighter));
    border-radius: var(--radius-full);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-text-primary));
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 2rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-info-box {
    display: inline-block;
    padding: 1rem 1.5rem;
    background-color: rgb(var(--color-bg-secondary));
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-md);
    margin-bottom: 2rem;
  }

  .hero-info-box p {
    font-size: 0.9375rem;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Value Section */
  .value-section {
    background-color: white;
  }

  .value-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .value-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .value-card {
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .value-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: rgb(var(--color-text-primary));
  }

  .value-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  /* Partners Section */
  .partners-section {
    background-color: rgb(var(--color-bg-secondary));
  }

  .partners-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .partner-card {
    background-color: white;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .partner-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: rgb(var(--color-text-primary));
  }

  .partner-card p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  /* Engagement Section */
  .engagement-section {
    background-color: white;
  }

  .engagement-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .engagement-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .engagement-card {
