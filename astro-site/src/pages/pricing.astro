---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="Pricing - Transparent, No Hidden Fees | Intent Solutions">
  <!-- ISSUE 1 FIX: Merged Hero + Pricing Cards Section with Continuous Image Background -->
  <section class="pricing-hero-cards">
    <div class="hero-overlay"></div>

    <!-- Hero Content -->
    <div class="pricing-hero-content">
      <div class="container">
        <div class="hero-badge">
          <span class="badge badge-light">Transparent Pricing</span>
        </div>

        <h1 class="hero-title">
          Clear <span class="highlight-box">pricing</span>.<br />No hidden fees.
        </h1>

        <p class="hero-description">
          All solutions are priced based on complexity, team size, and infrastructure requirements.
          You only pay for what you need—no vendor lock-in, no markup on AI model usage.
        </p>
      </div>
    </div>

    <!-- Pricing Cards Content -->
    <div class="pricing-cards-content">
      <div class="container">
        <!-- First Row: 3 cards -->
        <div class="pricing-row-1">
          <!-- Claude Code -->
          <div class="pricing-card">
            <div class="pricing-header">
              <div class="pricing-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="16 18 22 12 16 6"></polyline>
                  <polyline points="8 6 2 12 8 18"></polyline>
                </svg>
              </div>
              <h3>Claude Code</h3>
            </div>
            <p class="pricing-description">Custom setups, plugin development, team training</p>
            <div class="pricing-tiers">
              <div class="pricing-row">
                <span class="tier-name">Starter</span>
                <span class="tier-price">Custom quote</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">Growth</span>
                <span class="tier-price">Custom quote</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">Scale</span>
                <span class="tier-price">Custom quote</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">Enterprise</span>
                <span class="tier-price">Retainer</span>
              </div>
            </div>
            <a href="/claude-code" class="pricing-link">View details →</a>
          </div>

          <!-- AI Agents (IAM) -->
          <div class="pricing-card">
            <div class="pricing-header">
              <div class="pricing-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="3"></circle>
                  <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 2l-4.2 4.2m13.2-5.2h-6m-6 0H1m13.2 5.2l-4.2-4.2m0-2L5.8 5.8"></path>
                </svg>
              </div>
              <h3>AI Agents (IAM)</h3>
            </div>
            <p class="pricing-description">Intent Agent Models with pre-configured packages</p>
            <div class="pricing-tiers">
              <div class="pricing-row">
                <span class="tier-name">IAM M1</span>
                <span class="tier-price">$497/mo</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">IAM M2</span>
                <span class="tier-price">$997/mo</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">IAM M3</span>
                <span class="tier-price">$1,997/mo</span>
              </div>
            </div>
            <p class="pricing-note">+ AI model usage at cost (no markup)</p>
            <a href="/agents" class="pricing-link">View packages →</a>
          </div>

          <!-- Private AI -->
          <div class="pricing-card">
            <div class="pricing-header">
              <div class="pricing-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
              </div>
              <h3>Private AI</h3>
            </div>
            <p class="pricing-description">ChatGPT experience on your cloud infrastructure</p>
            <div class="pricing-tiers">
              <div class="pricing-row">
                <span class="tier-name">Managed Service</span>
                <span class="tier-price">$1,497/mo</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">Enterprise</span>
                <span class="tier-price">Custom</span>
              </div>
            </div>
            <p class="pricing-note">Deployment: $2,997 one-time setup</p>
            <a href="/private-ai" class="pricing-link">Learn more →</a>
          </div>
        </div>

        <!-- Second Row: 2 cards centered -->
        <div class="pricing-row-2">
          <!-- Automation -->
          <div class="pricing-card">
            <div class="pricing-header">
              <div class="pricing-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                </svg>
              </div>
              <h3>Automation</h3>
            </div>
            <p class="pricing-description">n8n + Netlify workflows and integrations</p>
            <div class="pricing-tiers">
              <div class="pricing-row">
                <span class="tier-name">Single Workflow</span>
                <span class="tier-price">$997 - $2,997</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">Multi-Workflow</span>
                <span class="tier-price">$4,997+</span>
              </div>
            </div>
            <p class="pricing-note">Project-based pricing</p>
            <a href="/automation" class="pricing-link">View examples →</a>
          </div>

          <!-- Cloud & Data -->
          <div class="pricing-card">
            <div class="pricing-header">
              <div class="pricing-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
                </svg>
              </div>
              <h3>Cloud & Data</h3>
            </div>
            <p class="pricing-description">Google Cloud architecture and infrastructure</p>
            <div class="pricing-tiers">
              <div class="pricing-row">
                <span class="tier-name">Architecture Design</span>
                <span class="tier-price">$2,997 - $9,997</span>
              </div>
              <div class="pricing-row">
                <span class="tier-name">Implementation</span>
                <span class="tier-price">Custom quote</span>
              </div>
            </div>
            <p class="pricing-note">Project-based or retainer</p>
            <a href="/cloud" class="pricing-link">View services →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ISSUE 2 FIX: Merged "How Pricing Works" + "Pricing FAQ" + CTA (Dark + Teal Wave) -->
  <section class="pricing-info-section">
    <!-- Teal wave background -->
    <div class="wave-background">
      <svg class="wave wave-1" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="rgba(13, 148, 136, 0.3)" d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
      <svg class="wave wave-2" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="rgba(20, 184, 166, 0.2)" d="M0,64L48,80C96,96,192,128,288,128C384,128,480,96,576,90.7C672,85,768,107,864,144C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
    </div>

    <!-- How Pricing Works -->
    <div class="how-pricing-content">
      <div class="container">
        <h2>How Pricing <span class="highlight-box">Works</span></h2>
        <p class="section-subtitle">Transparent methodology with no hidden surprises</p>

        <div class="steps-grid">
          <div class="step">
            <span class="step-number">1</span>
            <h3>Discovery Call</h3>
            <p>We discuss your needs, team size, technical requirements, and timeline. No sales pressure—just honest assessment.</p>
          </div>
          <div class="step">
            <span class="step-number">2</span>
            <h3>Custom Quote</h3>
            <p>You receive a detailed proposal with scope, timeline, and pricing breakdown. All costs transparent upfront.</p>
          </div>
          <div class="step">
            <span class="step-number">3</span>
            <h3>Fixed or Recurring</h3>
            <p>Choose project-based (one-time payment) or monthly subscription (for ongoing services). Cancel anytime.</p>
          </div>
          <div class="step">
            <span class="step-number">4</span>
            <h3>Usage Costs</h3>
            <p>AI model usage passed through at provider rates—no markup. You see exactly what you pay for API calls.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Pricing FAQ -->
    <div class="pricing-faq-content">
      <div class="container">
        <h2>Pricing <span class="highlight-box">FAQ</span></h2>

        <div class="faq-grid">
          <div class="faq-item">
            <h3>Do you mark up AI model usage?</h3>
            <p>No. AI usage (Claude, GPT, Gemini, etc.) is billed at provider rates with zero markup. You see transparent pass-through costs.</p>
          </div>

          <div class="faq-item">
            <h3>What's included in monthly subscriptions?</h3>
            <p>Hosting, maintenance, monitoring, updates, and support. Usage costs (AI calls, cloud resources) are separate and billed monthly.</p>
          </div>

          <div class="faq-item">
            <h3>Can I cancel anytime?</h3>
            <p>Yes. Monthly subscriptions can be cancelled with 30 days notice. No long-term contracts or cancellation fees.</p>
          </div>

          <div class="faq-item">
            <h3>Do you offer discounts for nonprofits?</h3>
            <p>Yes. Nonprofits and educational institutions receive 20% off all services. Contact us for eligibility verification.</p>
          </div>

          <div class="faq-item">
            <h3>What payment methods do you accept?</h3>
            <p>Bank transfer (ACH), credit card, or invoice (NET 30 for established clients). All payments processed securely.</p>
          </div>

          <div class="faq-item">
            <h3>Do you offer refunds?</h3>
            <p>Project-based work: Refund available if deliverables don't meet agreed specifications. Monthly services: Pro-rated refund within first 30 days.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="cta-content">
      <div class="container">
        <h2>Ready to get a <span class="highlight-box">custom quote</span>?</h2>
        <p>Tell us about your project and we'll provide a transparent, detailed proposal.</p>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-primary">Request a Quote</a>
      </div>
    </div>
  </section>
</LayoutRedesign>

<style>
  /* ============================================
     Highlight Box
     ============================================ */
  .highlight-box {
    display: inline-block;
    background: var(--color-highlight);
    color: var(--bg-dark);
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
  }

  /* ============================================
     ISSUE 1 FIX: Merged Hero + Pricing Cards
     ============================================ */
  .pricing-hero-cards {
    position: relative;
    background:
      linear-gradient(
        to bottom,
        rgba(10, 15, 26, 0.88) 0%,
        rgba(10, 15, 26, 0.75) 30%,
        rgba(10, 15, 26, 0.80) 100%
      ),
      url('/images/cosmic-bg-dark.jpg') center/cover no-repeat;
    background-attachment: scroll, fixed;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(13, 148, 136, 0.1));
    pointer-events: none;
  }

  /* Hero Content */
  .pricing-hero-content {
    position: relative;
    z-index: 2;
    padding: 8rem 0 4rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .pricing-hero-content {
      padding: 6rem 0 3rem;
    }
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-badge {
    margin-bottom: 1.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-full);
  }

  .badge-light {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
  }

  .hero-title {
    color: #ffffff;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .hero-description {
    color: #e2e8f0;
    font-size: 1.125rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Pricing Cards Content */
  .pricing-cards-content {
    position: relative;
    z-index: 2;
    padding: 3rem 0 5rem;
  }

  @media (max-width: 768px) {
    .pricing-cards-content {
      padding: 2rem 0 4rem;
    }
  }

  /* First Row: 3 cards */
  .pricing-row-1 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* Second Row: 2 cards centered */
  .pricing-row-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .pricing-row-1 {
      grid-template-columns: repeat(2, 1fr);
    }

    .pricing-row-2 {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }

  @media (max-width: 640px) {
    .pricing-row-1,
    .pricing-row-2 {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Pricing Cards - WHITE background on dark section */
  .pricing-card {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 2rem;
    border-radius: var(--radius-xl);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: all var(--transition-base);
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
  }

  .pricing-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .pricing-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    color: rgb(var(--color-accent-primary));
    background-color: rgb(var(--color-accent-light));
    border-radius: var(--radius-lg);
    flex-shrink: 0;
  }

  .pricing-card h3 {
    color: rgb(var(--color-text-primary));
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
  }

  .pricing-description {
    color: rgb(var(--color-text-secondary));
    font-size: 0.9375rem;
    margin-bottom: 1.5rem;
  }

  .pricing-tiers {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .pricing-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .pricing-row:last-child {
    border-bottom: none;
  }

  .tier-name {
    color: rgb(var(--color-text-primary));
    font-weight: 500;
    font-size: 0.875rem;
  }

  .tier-price {
    color: rgb(var(--color-text-primary));
    font-weight: 600;
    font-size: 0.875rem;
  }

  .pricing-note {
    color: rgb(var(--color-text-tertiary));
    font-size: 0.8125rem;
    font-style: italic;
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .pricing-link {
    color: rgb(var(--color-accent-primary));
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 1rem;
    transition: gap var(--transition-fast);
  }

  .pricing-link:hover {
    gap: 0.5rem;
  }

  /* ============================================
     ISSUE 2 FIX: Dark + Teal Wave Section
     ============================================ */
  .pricing-info-section {
    position: relative;
    background: #0a0f1a;
    overflow: hidden;
  }

  /* Teal wave background */
  .wave-background {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40%;
    pointer-events: none;
    z-index: 0;
  }

  .wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .wave-1 {
    animation: wave-float 20s ease-in-out infinite;
  }

  .wave-2 {
    animation: wave-float 15s ease-in-out infinite reverse;
  }

  @keyframes wave-float {
    0%, 100% {
      transform: translateX(0) translateY(0);
    }
    50% {
      transform: translateX(-20px) translateY(10px);
    }
  }

  /* How Pricing Works */
  .how-pricing-content {
    position: relative;
    z-index: 1;
    padding: 5rem 0 4rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .how-pricing-content {
      padding: 3rem 0 3rem;
    }
  }

  .how-pricing-content h2 {
    color: #ffffff;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    color: #e2e8f0;
    font-size: 1rem;
    margin-bottom: 3rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }

  .step {
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgb(var(--color-accent-primary));
    color: #ffffff;
    font-weight: 700;
    border-radius: 50%;
    margin-bottom: 1rem;
  }

  .step h3 {
    color: #ffffff;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .step p {
    color: #e2e8f0;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* Pricing FAQ */
  .pricing-faq-content {
    position: relative;
    z-index: 1;
    padding: 4rem 0;
  }

  @media (max-width: 768px) {
    .pricing-faq-content {
      padding: 3rem 0;
    }
  }

  .pricing-faq-content h2 {
    color: #ffffff;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 3rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  .faq-item h3 {
    color: #ffffff;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .faq-item p {
    color: #e2e8f0;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  /* CTA */
  .cta-content {
    position: relative;
    z-index: 1;
    padding: 4rem 0 6rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .cta-content {
      padding: 3rem 0 4rem;
    }
  }

  .cta-content h2 {
    color: #ffffff;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: #e2e8f0;
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #ffffff;
    color: #0a0f1a;
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
  }
</style>
