---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer';
---

<Layout title="Intel Engine: Model 1 - A2A Intelligence Framework | Intent Solutions">
  <SiteNav />

  <!-- Hero Section -->
  <section class="min-h-[60vh] flex items-center bg-gradient-main relative overflow-hidden">
    <div class="absolute w-96 h-96 bg-zinc-100/5 rounded-full blur-3xl top-0 right-0 -translate-y-1/2 translate-x-1/2" />

    <div class="container mx-auto px-8 py-24 relative z-10">
      <div class="max-w-4xl">
        <div class="inline-block px-3 py-1 bg-zinc-800/50 border border-zinc-700 rounded-full mb-6">
          <span class="text-xs font-semibold text-zinc-300">INTEL ENGINE: MODEL 1</span>
        </div>

        <h1 class="text-hero font-extrabold text-zinc-50 mb-6">
          intelligence before<br />automation
        </h1>

        <p class="text-body-lg text-zinc-400 mb-8 max-w-2xl">
          Two-layer agent architecture. Intelligence layer learns from your closed deals and scores every lead. Automation layer executes outreach on high-probability targets only. Continuous feedback loop. 10x better response rates.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="mailto:jeremy@intentsolutions.io?subject=Intel Engine Demo Request" class="btn-primary">
            book a demo
          </a>
          <a href="#how-it-works" class="inline-flex items-center text-zinc-200 hover:text-zinc-50 transition-smooth">
            see how it works ↓
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-24 bg-zinc-950 border-t border-zinc-800/50">
    <div class="container mx-auto px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-h1 font-bold text-zinc-50 mb-6">the problem with current automation</h2>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
            <div class="text-red-400 font-semibold mb-3">❌ Traditional LinkedIn Automation</div>
            <ul class="space-y-2 text-sm text-zinc-400">
              <li>• Scrape 10,000 leads from Apollo</li>
              <li>• Send generic template to everyone</li>
              <li>• 0.5% response rate (50 responses)</li>
              <li>• Burn domain reputation</li>
              <li>• No learning or improvement</li>
            </ul>
          </div>

          <div class="bg-zinc-900 border border-indigo-500/30 rounded-lg p-6">
            <div class="text-green-400 font-semibold mb-3">✓ Intel Engine Approach</div>
            <ul class="space-y-2 text-sm text-zinc-400">
              <li>• Analyze your 50+ closed deals</li>
              <li>• Build ICP model from YOUR wins</li>
              <li>• Score all 10,000 leads</li>
              <li>• Contact only top 500 A-tier (5%)</li>
              <li>• 5-10% response rate (250+ responses)</li>
            </ul>
          </div>
        </div>

        <div class="mt-8 p-6 bg-zinc-900/50 border border-zinc-800 rounded-lg">
          <p class="text-zinc-300 text-lg font-semibold mb-2">Result: 5x more meetings from 95% less outreach</p>
          <p class="text-sm text-zinc-500">Focus on the right leads, not all leads.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="py-24 bg-zinc-950">
    <div class="container mx-auto px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-h1 font-bold text-zinc-50 mb-12 text-center">how it works</h2>

        <div class="space-y-8">
          <!-- Step 1 -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <div class="flex items-start gap-6">
              <div class="flex-shrink-0 w-12 h-12 bg-indigo-500/20 border border-indigo-500/30 rounded-lg flex items-center justify-center">
                <span class="text-xl font-bold text-indigo-300">1</span>
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-zinc-50 mb-3">Intelligence Layer: Data Ingestion</h3>
                <p class="text-zinc-400 mb-4">
                  Connects to your data sources and learns from your historical wins
                </p>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <div class="text-sm font-semibold text-zinc-300 mb-2">Data Sources:</div>
                    <ul class="text-sm text-zinc-500 space-y-1">
                      <li>• Apollo.io (firmographics)</li>
                      <li>• Sales Navigator (LinkedIn signals)</li>
                      <li>• HubSpot/CRM (closed deals)</li>
                      <li>• Clearbit (enrichment)</li>
                    </ul>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-zinc-300 mb-2">What It Learns:</div>
                    <ul class="text-sm text-zinc-500 space-y-1">
                      <li>• Which verticals close fastest</li>
                      <li>• Optimal company size range</li>
                      <li>• Tech stack compatibility</li>
                      <li>• Funding stage patterns</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <div class="flex items-start gap-6">
              <div class="flex-shrink-0 w-12 h-12 bg-indigo-500/20 border border-indigo-500/30 rounded-lg flex items-center justify-center">
                <span class="text-xl font-bold text-indigo-300">2</span>
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-zinc-50 mb-3">Intelligence Layer: ICP Model Training</h3>
                <p class="text-zinc-400 mb-4">
                  Builds dynamic scoring model from YOUR closed deals (not industry averages)
                </p>
                <div class="bg-zinc-800/50 p-4 rounded border border-zinc-700 font-mono text-xs text-zinc-400">
                  <div>Example Pattern Discovered:</div>
                  <div class="mt-2 text-zinc-500">
                    "Series A fintech companies with 20-50 employees<br/>
                    using Salesforce convert at 42% in 45 days.<br/>
                    Healthcare takes 6+ months (deprioritize)."
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <div class="flex items-start gap-6">
              <div class="flex-shrink-0 w-12 h-12 bg-indigo-500/20 border border-indigo-500/30 rounded-lg flex items-center justify-center">
                <span class="text-xl font-bold text-indigo-300">3</span>
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-zinc-50 mb-3">Intelligence Layer: Lead Scoring</h3>
                <p class="text-zinc-400 mb-4">
                  Scores every prospect 0-100 and prioritizes A/B/C tiers
                </p>
                <div class="grid md:grid-cols-3 gap-4">
                  <div class="bg-green-500/10 border border-green-500/30 rounded p-4">
                    <div class="text-green-400 font-semibold mb-1">A-Tier (80-100)</div>
                    <div class="text-xs text-zinc-500">Top 5% of leads<br/>Contact immediately</div>
                  </div>
                  <div class="bg-yellow-500/10 border border-yellow-500/30 rounded p-4">
                    <div class="text-yellow-400 font-semibold mb-1">B-Tier (60-79)</div>
                    <div class="text-xs text-zinc-500">Top 15% of leads<br/>Contact after A-tier</div>
                  </div>
                  <div class="bg-zinc-700/30 border border-zinc-700 rounded p-4">
                    <div class="text-zinc-400 font-semibold mb-1">C-Tier (<60)</div>
                    <div class="text-xs text-zinc-500">Low probability<br/>Skip entirely</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <div class="flex items-start gap-6">
              <div class="flex-shrink-0 w-12 h-12 bg-emerald-500/20 border border-emerald-500/30 rounded-lg flex items-center justify-center">
                <span class="text-xl font-bold text-emerald-300">4</span>
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-zinc-50 mb-3">Automation Layer: Execution</h3>
                <p class="text-zinc-400 mb-4">
                  Receives scored leads from Intelligence Agent and executes personalized outreach
                </p>
                <ul class="text-sm text-zinc-400 space-y-2">
                  <li>• Sends connection requests on LinkedIn</li>
                  <li>• Personalized messages (not templates)</li>
                  <li>• Rate-limited to protect sender reputation</li>
                  <li>• Tracks responses and conversions</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Step 5 -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <div class="flex items-start gap-6">
              <div class="flex-shrink-0 w-12 h-12 bg-purple-500/20 border border-purple-500/30 rounded-lg flex items-center justify-center">
                <span class="text-xl font-bold text-purple-300">5</span>
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-zinc-50 mb-3">Feedback Loop: Continuous Learning</h3>
                <p class="text-zinc-400 mb-4">
                  Automation Agent reports results back to Intelligence Agent for model improvement
                </p>
                <div class="bg-zinc-800/50 p-4 rounded border border-zinc-700">
                  <div class="text-sm text-zinc-400">
                    <div class="font-semibold text-zinc-300 mb-2">A2A Communication:</div>
                    <div class="text-xs text-zinc-500 space-y-1">
                      <div>Automation → Intelligence: "Lead abc123 booked meeting"</div>
                      <div>Intelligence updates model: "Increase weight for this pattern"</div>
                      <div>Next batch: More accurate targeting</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI Calculator -->
  <section class="py-24 bg-zinc-950 border-t border-zinc-800/50">
    <div class="container mx-auto px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-h1 font-bold text-zinc-50 mb-12 text-center">roi breakdown</h2>

        <div class="grid md:grid-cols-2 gap-8 mb-8">
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <h3 class="text-xl font-bold text-zinc-50 mb-6">Traditional SDR Team</h3>
            <div class="space-y-4">
              <div class="flex justify-between items-center pb-3 border-b border-zinc-800">
                <span class="text-zinc-400">3 SDRs × $75K salary</span>
                <span class="text-zinc-50 font-semibold">$225K/yr</span>
              </div>
              <div class="flex justify-between items-center pb-3 border-b border-zinc-800">
                <span class="text-zinc-400">Benefits (30%)</span>
                <span class="text-zinc-50 font-semibold">$67K/yr</span>
              </div>
              <div class="flex justify-between items-center pb-3 border-b border-zinc-800">
                <span class="text-zinc-400">Tools (Apollo, Sales Nav)</span>
                <span class="text-zinc-50 font-semibold">$12K/yr</span>
              </div>
              <div class="flex justify-between items-center pt-2">
                <span class="text-zinc-300 font-semibold">Total Annual Cost</span>
                <span class="text-red-400 text-2xl font-bold">$304K</span>
              </div>
            </div>
          </div>

          <div class="bg-zinc-900 border border-indigo-500/30 rounded-lg p-8">
            <h3 class="text-xl font-bold text-zinc-50 mb-6">Intel Engine: Model 1</h3>
            <div class="space-y-4">
              <div class="flex justify-between items-center pb-3 border-b border-zinc-800">
                <span class="text-zinc-400">Managed service</span>
                <span class="text-zinc-50 font-semibold">$18K/yr</span>
              </div>
              <div class="flex justify-between items-center pb-3 border-b border-zinc-800">
                <span class="text-zinc-400">One-time setup</span>
                <span class="text-zinc-50 font-semibold">$22.5K</span>
              </div>
              <div class="flex justify-between items-center pb-3 border-b border-zinc-800">
                <span class="text-zinc-400">Data sources (Apollo, etc)</span>
                <span class="text-zinc-50 font-semibold">$3K/yr</span>
              </div>
              <div class="flex justify-between items-center pt-2">
                <span class="text-zinc-300 font-semibold">Total Year 1 Cost</span>
                <span class="text-green-400 text-2xl font-bold">$43.5K</span>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-indigo-500/10 border border-indigo-500/30 rounded-lg p-8 text-center">
          <div class="text-3xl font-bold text-zinc-50 mb-2">Save $260K in Year 1</div>
          <div class="text-zinc-400">86% cost reduction + 10x better response rates</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Stack -->
  <section class="py-24 bg-zinc-950 border-t border-zinc-800/50">
    <div class="container mx-auto px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-h1 font-bold text-zinc-50 mb-12 text-center">technical architecture</h2>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
            <h3 class="text-lg font-bold text-zinc-50 mb-4">Intelligence Container</h3>
            <ul class="space-y-2 text-sm text-zinc-400">
              <li>• FastAPI (Python 3.12)</li>
              <li>• PostgreSQL 15</li>
              <li>• LangChain (pattern analysis)</li>
              <li>• scikit-learn (ML scoring)</li>
              <li>• Docker containerized</li>
            </ul>
          </div>

          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
            <h3 class="text-lg font-bold text-zinc-50 mb-4">Automation Container</h3>
            <ul class="space-y-2 text-sm text-zinc-400">
              <li>• FastAPI (Python 3.12)</li>
              <li>• PostgreSQL 15</li>
              <li>• LinkedIn/Apollo APIs</li>
              <li>• Rate limiting & queue management</li>
              <li>• Docker containerized</li>
            </ul>
          </div>
        </div>

        <div class="mt-8 bg-zinc-900 border border-zinc-800 rounded-lg p-6">
          <h3 class="text-lg font-bold text-zinc-50 mb-4">A2A Communication Layer</h3>
          <p class="text-sm text-zinc-400 mb-4">
            Uses Google's A2A Protocol (JSON-RPC over HTTPS) for agent-to-agent communication
          </p>
          <div class="bg-zinc-800/50 p-4 rounded border border-zinc-700 font-mono text-xs text-zinc-500">
            Intelligence → Automation: Send scored leads<br/>
            Automation → Intelligence: Report outcomes<br/>
            Intelligence: Update model and improve
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-24 bg-zinc-950 border-t border-zinc-800/50">
    <div class="container mx-auto px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-h1 font-bold text-zinc-50 mb-12 text-center">pricing</h2>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Self-serve -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <div class="text-sm font-semibold text-zinc-400 mb-2">SELF-SERVE</div>
            <div class="text-3xl font-bold text-zinc-50 mb-6">$497<span class="text-lg text-zinc-400">/mo</span></div>
            <ul class="space-y-3 text-sm text-zinc-400 mb-8">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Docker containers delivered</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>You deploy on your infrastructure</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Email support (24h response)</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Full source code access</span>
              </li>
            </ul>
            <a href="mailto:jeremy@intentsolutions.io?subject=Intel Engine Self-Serve" class="block w-full text-center px-6 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-50 rounded transition-colors">
              Get Started
            </a>
          </div>

          <!-- Managed -->
          <div class="bg-zinc-900 border border-indigo-500/30 rounded-lg p-8 relative">
            <div class="absolute top-4 right-4 px-3 py-1 bg-indigo-500/20 text-indigo-300 text-xs font-semibold rounded">
              RECOMMENDED
            </div>
            <div class="text-sm font-semibold text-zinc-400 mb-2">MANAGED</div>
            <div class="text-3xl font-bold text-zinc-50 mb-6">$1,497<span class="text-lg text-zinc-400">/mo</span></div>
            <ul class="space-y-3 text-sm text-zinc-400 mb-8">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>We host and manage everything</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>99.9% uptime SLA</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Priority support (4h response)</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Monitoring & auto-scaling</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Export your data anytime</span>
              </li>
            </ul>
            <a href="mailto:jeremy@intentsolutions.io?subject=Intel Engine Managed" class="block w-full text-center px-6 py-3 bg-indigo-500 hover:bg-indigo-600 text-white rounded transition-colors">
              Get Started
            </a>
          </div>

          <!-- Custom -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
            <div class="text-sm font-semibold text-zinc-400 mb-2">CUSTOM BUILD</div>
            <div class="text-3xl font-bold text-zinc-50 mb-6">$15-30K<span class="text-lg text-zinc-400"> setup</span></div>
            <ul class="space-y-3 text-sm text-zinc-400 mb-8">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Bespoke integrations</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Custom ML model tuning</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Industry-specific workflows</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>90-day optimization period</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>+ $497/mo maintenance</span>
              </li>
            </ul>
            <a href="mailto:jeremy@intentsolutions.io?subject=Intel Engine Custom Build" class="block w-full text-center px-6 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-50 rounded transition-colors">
              Discuss Build
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-zinc-950 border-t border-zinc-800/50">
    <div class="container mx-auto px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-h1 font-bold text-zinc-50 mb-4">ready to 10x your outbound?</h2>
        <p class="text-zinc-400 mb-8">
          Book a 15-minute demo to see Intel Engine in action with your data.
        </p>
        <a href="mailto:jeremy@intentsolutions.io?subject=Intel Engine Demo Request" class="btn-primary">
          book a demo
        </a>
        <p class="text-sm text-zinc-500 mt-6">
          jeremy@intentsolutions.io · no contracts · export your data anytime
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
