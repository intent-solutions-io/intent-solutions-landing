---
// Thank you page for survey completion
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You - IntentSolutions">
  <div class="min-h-screen bg-gradient-to-br from-zinc-900 to-zinc-800 flex items-center justify-center px-4">
    <div class="max-w-2xl w-full text-center">
      <div class="bg-zinc-800/50 backdrop-blur-sm border border-zinc-700 rounded-2xl p-12 shadow-2xl">
        <div class="mb-8">
          <svg class="w-20 h-20 mx-auto text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>

        <h1 class="text-4xl font-bold text-zinc-50 mb-4">Thank You!</h1>

        <p class="text-xl text-zinc-300 mb-6">
          Your survey response has been received.
        </p>

        <p class="text-lg text-zinc-400 mb-8">
          We appreciate you taking the time to help us build HUSTLE™. Your feedback will directly shape the future of youth sports tracking.
        </p>

        <div class="bg-zinc-900/50 border border-zinc-700 rounded-lg p-6 mb-8">
          <h2 class="text-lg font-semibold text-zinc-200 mb-3">What Happens Next?</h2>
          <ul class="text-left text-zinc-400 space-y-2">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>We'll review your responses and identify beta testing candidates</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>If selected, you'll receive an email invitation within 2 weeks</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Beta testers get 1 year free access when we launch</span>
            </li>
          </ul>
        </div>

        <a
          href="/"
          class="inline-block px-8 py-4 bg-zinc-700 hover:bg-zinc-600 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
        >
          ← Return to Home
        </a>
      </div>
    </div>
  </div>
</Layout>
