---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer';
---

<Layout
  title="Distribution Partner Program | Intent Solutions"
  description="Your distribution channel for AI solutions. Partners get tenant access to our in-house systems. Model- and cloud-agnostic. Vertex-first security."
>
  <SiteNav />

  <main class="bg-zinc-900">
    <!-- Hero -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl">
          <p class="uppercase tracking-[0.3em] text-xs font-semibold text-zinc-500 mb-4">
            distribution partner program
          </p>
          <h1 class="text-h1 font-bold text-zinc-50 mb-6">
            you sell, we host
          </h1>
          <p class="text-lg text-zinc-400 leading-relaxed mb-6">
            Become a distribution channel for our AI solutions. Your clients get tenant access to our
            in-house systems—we handle the infrastructure, you own the relationship.
            Model- and cloud-agnostic. Vertex-first security. No lock-in.
          </p>
          <div class="inline-block px-4 py-2 bg-zinc-800/50 border border-zinc-700 rounded-lg">
            <p class="text-sm text-zinc-300">
              <strong>How it works:</strong> You bring clients. We provision tenants. They get hosted AI solutions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Value Props -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-12 text-center">
            distribution channel for hosted ai solutions
          </h2>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                tenant provisioning
              </h3>
              <p class="text-sm text-zinc-400">
                Each of your clients gets their own isolated tenant on our infrastructure. Separate
                data, separate configs, shared platform.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                white-label access
              </h3>
              <p class="text-sm text-zinc-400">
                Your brand on the UI. Clients interact with your logo and your domain—they access
                our hosted systems through you.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                we handle operations
              </h3>
              <p class="text-sm text-zinc-400">
                Infrastructure, monitoring, updates, incident response. We run everything—you focus
                on sales and client relationships.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                scale without overhead
              </h3>
              <p class="text-sm text-zinc-400">
                Add clients without adding infrastructure. Each new tenant is a configuration, not
                a deployment project.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Ideal Partners -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">ideal distribution partners</h2>

          <div class="space-y-4">
            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                agencies wanting to offer ai without building infrastructure
              </h3>
              <p class="text-sm text-zinc-400">
                You have clients asking for AI solutions. We give you tenant access to hosted
                systems you can resell under your brand.
              </p>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                vertical specialists who know their market
              </h3>
              <p class="text-sm text-zinc-400">
                You understand healthcare, finance, or legal. We provide the hosted AI platform—you
                configure tenants for your vertical.
              </p>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                consultancies adding ai to their service mix
              </h3>
              <p class="text-sm text-zinc-400">
                Expand from advisory to hosted solutions. We provision tenants—you own the client
                relationship and set your margins.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Engagement Models -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-12 text-center">
            partner engagement models
          </h2>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">rev-share partnership</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">$0 upfront</div>
              <p class="text-sm text-zinc-400 mb-6">
                Revenue share on each tenant you bring. We host the solution, you bring clients.
                Good for testing the partnership.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>No upfront cost to partner</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>We provision tenants for your clients</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Aligned incentives on growth</span>
                </li>
              </ul>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">wholesale tenant pricing</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">fixed per-tenant rate</div>
              <p class="text-sm text-zinc-400 mb-6">
                Fixed wholesale cost per tenant. You set your retail price and keep the margin.
                Predictable costs for you.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Predictable cost per tenant</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>You control retail pricing</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>White-label included</span>
                </li>
              </ul>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">partner retainer</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">monthly partnership</div>
              <p class="text-sm text-zinc-400 mb-6">
                Monthly retainer for priority support, custom configurations, and dedicated
                onboarding for your clients.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Priority tenant provisioning</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Custom configuration support</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Dedicated onboarding assistance</span>
                </li>
              </ul>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">per-tenant managed service</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">flat + usage</div>
              <p class="text-sm text-zinc-400 mb-6">
                Flat platform fee per tenant + usage at provider list prices. Full managed
                service—we handle everything.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Usage at provider list prices</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Full managed operations</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Budget caps and alerts per tenant</span>
                </li>
              </ul>
            </div>
          </div>

          <div class="mt-8 text-center">
            <p class="text-sm text-zinc-400">
              <strong class="text-zinc-300">Onboarding:</strong> Setup covers partner
              portal access, white-label configuration, and first tenant provisioning
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Starter Packs -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">hosted solutions catalog</h2>

          <div class="grid md:grid-cols-3 gap-6 mb-8">
            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                outbound sdr agents
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• Research + enrich leads</li>
                <li>• ICP scoring</li>
                <li>• Personalized outreach</li>
                <li>• Meeting intelligence</li>
              </ul>
              <span class="text-xs text-zinc-500">Tenant setup: 1–2 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                knowledge search + grounded answers
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• Docs and wiki integration</li>
                <li>• Vector search</li>
                <li>• Citation tracking</li>
                <li>• Access controls</li>
              </ul>
              <span class="text-xs text-zinc-500">Tenant setup: 1–2 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                support triage agents
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• CRM + ticket integrations</li>
                <li>• Response drafting</li>
                <li>• Escalation rules</li>
                <li>• Churn prediction</li>
              </ul>
              <span class="text-xs text-zinc-500">Tenant setup: 2–3 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                private ai portal
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• Internal ChatGPT-style UI</li>
                <li>• Model selection (Claude, GPT, Gemini)</li>
                <li>• Company data integration</li>
                <li>• Usage tracking</li>
              </ul>
              <span class="text-xs text-zinc-500">Tenant setup: 1–2 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                automation + agent pairing
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• n8n for orchestration glue</li>
                <li>• Vertex for agent workflows</li>
                <li>• API integrations</li>
                <li>• Scheduled jobs</li>
              </ul>
              <span class="text-xs text-zinc-500">Tenant setup: 1–2 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                custom configuration
              </h3>
              <p class="text-sm text-zinc-400 mb-4">
                Combine solutions, custom integrations, specialized workflows. We configure the
                tenant to match client needs.
              </p>
              <span class="text-xs text-zinc-500">Setup varies by complexity</span>
            </div>
          </div>

          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
            <p class="text-sm text-zinc-300">
              <strong>Note:</strong> All solutions are model- and cloud-agnostic. Tenants can use
              Claude, OpenAI, Gemini, Llama, Mistral, Qwen, fine-tunes, or local models based on
              requirements.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8 text-center">how the partnership works</h2>

          <div class="space-y-8">
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                1
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  partner onboarding
                </h3>
                <p class="text-sm text-zinc-400">
                  Initial call to understand your market, client types, and goals. We set up your
                  partner portal and white-label configuration.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                2
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  you bring a client
                </h3>
                <p class="text-sm text-zinc-400">
                  When you close a deal, tell us the client's requirements. We assess fit and
                  confirm which hosted solution works best.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                3
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  we provision their tenant
                </h3>
                <p class="text-sm text-zinc-400">
                  We create an isolated tenant on our infrastructure. Separate data, separate
                  configs, your branding. Client gets access credentials.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                4
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  configure and customize
                </h3>
                <p class="text-sm text-zinc-400">
                  We configure the tenant for your client's specific workflows—integrations, models,
                  budget caps, access controls.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                5
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  client goes live
                </h3>
                <p class="text-sm text-zinc-400">
                  Tenant is active with monitoring, usage tracking, and alerts. Client interacts
                  with your branded interface—we handle the backend.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                6
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  ongoing managed service
                </h3>
                <p class="text-sm text-zinc-400">
                  We handle infrastructure, updates, monitoring, and incident response. You handle
                  the client relationship.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Standard Deliverables -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">what partners get</h2>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                partner portal access
              </h3>
              <p class="text-sm text-zinc-400">
                Dashboard to view your tenants, usage metrics, billing, and client status at a glance.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                tenant management
              </h3>
              <p class="text-sm text-zinc-400">
                Request new tenants, configure settings, view logs, manage access controls for each client.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                usage dashboards and budgets
              </h3>
              <p class="text-sm text-zinc-400">
                Per-tenant monitoring, cost tracking, usage alerts, performance metrics visible to you and your clients.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                white-label configuration
              </h3>
              <p class="text-sm text-zinc-400">
                Your branding on the interface—logo, colors, domain. Clients see your brand, not ours.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                sales enablement kit
              </h3>
              <p class="text-sm text-zinc-400">
                One-pagers, demo scripts, pitch deck, objection handling guides to help you close deals.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                client-facing documentation
              </h3>
              <p class="text-sm text-zinc-400">
                White-labeled user guides, onboarding docs, and support resources for your clients.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Vertex -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">why vertex for production</h2>

          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8 mb-6">
            <p class="text-zinc-300 leading-relaxed mb-6">
              Production agents benefit from Vertex defaults and controls. We still support
              self-hosted and low-code when the risk profile and budget fit.
            </p>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h3 class="text-sm font-semibold text-zinc-100 mb-2 uppercase tracking-widest">
                  Vertex Agent Engine
                </h3>
                <ul class="space-y-2 text-sm text-zinc-400">
                  <li>• IAM, per-workspace service accounts</li>
                  <li>• VPC options, Private Service Connect</li>
                  <li>• Secret Manager, rotation, SLSA provenance</li>
                  <li>• Audit logs, SIEM export, policy controls</li>
                  <li>• Evals, guardrails, rollback gates</li>
                </ul>
              </div>

              <div>
                <h3 class="text-sm font-semibold text-zinc-100 mb-2 uppercase tracking-widest">
                  Self-Hosted / Low-Code
                </h3>
                <ul class="space-y-2 text-sm text-zinc-400">
                  <li>• Good for orchestration glue</li>
                  <li>• Quick integration wins</li>
                  <li>• Lower volume automations</li>
                  <li>• Air-gapped requirements</li>
                  <li>• Budget-constrained projects</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="text-center">
            <a
              href="/learn/security"
              class="text-sm text-zinc-200 hover:text-zinc-50 transition-smooth inline-flex items-center gap-2"
            >
              Learn: Security comparison (Vertex vs self-hosted)
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section class="py-24 bg-zinc-950">
      <div class="container mx-auto px-8">
        <div class="max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-6 text-center">
            let's talk
          </h2>
          <p class="text-zinc-400 mb-8 text-center">
            Whether you're exploring partnership options, need a hosted AI solution for your business,
            or just want to learn more—we'd love to hear from you.
          </p>

          <form
            id="partner-form"
            class="space-y-6"
          >

            <div>
              <label for="company-name" class="block text-sm font-medium text-zinc-300 mb-2">
                company name
              </label>
              <input
                type="text"
                id="company-name"
                name="company-name"
                required
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="Your Company"
              />
            </div>

            <div>
              <label for="contact-name" class="block text-sm font-medium text-zinc-300 mb-2">
                your name
              </label>
              <input
                type="text"
                id="contact-name"
                name="contact-name"
                required
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="Your Name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-zinc-300 mb-2">
                email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="you@company.com"
              />
            </div>

            <div>
              <label for="interest" class="block text-sm font-medium text-zinc-300 mb-2">
                what are you interested in?
              </label>
              <select
                id="interest"
                name="interest"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 focus:outline-none focus:border-zinc-400 transition-smooth"
              >
                <option value="exploring">Just exploring options</option>
                <option value="distribution-partner">Becoming a distribution partner</option>
                <option value="direct-client">AI solution for my business</option>
                <option value="learn-more">Learning more about your services</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-zinc-300 mb-2">
                tell us more (optional)
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth resize-none"
                placeholder="What are you looking to accomplish?"
              ></textarea>
            </div>

            <button type="submit" class="w-full btn-primary">
              get in touch
            </button>

            <p class="text-xs text-zinc-500 text-center">
              We'll get back to you within 1 business day.
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('partner-form') as HTMLFormElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = {
      companyName: formData.get('company-name') as string,
      contactName: formData.get('contact-name') as string,
      email: formData.get('email') as string,
      interest: formData.get('interest') as string,
      message: formData.get('message') as string || undefined,
    };

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'sending...';

    try {
      const response = await fetch('/api/partner', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        form.innerHTML = `
          <div class="text-center py-8">
            <p class="text-zinc-50 text-lg mb-2">Thanks for reaching out!</p>
            <p class="text-zinc-400">We'll be in touch within 1 business day.</p>
          </div>
        `;

        // Track in Firebase Analytics
        if ((window as any).gtag) {
          (window as any).gtag('event', 'form_submit', {
            form_name: 'partner-inquiry',
            interest: data.interest,
          });
        }
      } else {
        throw new Error('Submission failed');
      }
    } catch (error) {
      console.error('Partner form error:', error);
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
      alert('Something went wrong. Please email jeremy@intentsolutions.io directly.');
    }
  });
</script>
