---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer';
---

<Layout
  title="Reseller & White-Label Program | Intent Solutions"
  description="You sell, we build. White-label AI products for agencies. Model- and cloud-agnostic. Vertex-first security."
>
  <SiteNav />

  <main class="bg-zinc-900">
    <!-- Hero -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl">
          <p class="uppercase tracking-[0.3em] text-xs font-semibold text-zinc-500 mb-4">
            reseller program
          </p>
          <h1 class="text-h1 font-bold text-zinc-50 mb-6">
            you sell, we build
          </h1>
          <p class="text-lg text-zinc-400 leading-relaxed mb-6">
            We act as your CTO/product team and deliver white-label AI products under your brand.
            Model- and cloud-agnostic. Vertex-first security. No lock-in.
          </p>
          <div class="inline-block px-4 py-2 bg-zinc-800/50 border border-zinc-700 rounded-lg">
            <p class="text-sm text-zinc-300">
              <strong>Positioning:</strong> You're the CEO. We're your CTO.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Value Props -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-12 text-center">
            white-label ai product studio for agencies and consultancies
          </h2>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                co-sell + build
              </h3>
              <p class="text-sm text-zinc-400">
                We join your sales calls as "CTO," scope the win, and architect the solution. You
                close, we deliver.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                white-label delivery
              </h3>
              <p class="text-sm text-zinc-400">
                Your brand on UI, docs, and support. Our team fulfills. Clients see your logo, not
                ours.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                managed operations
              </h3>
              <p class="text-sm text-zinc-400">
                Monitoring, incident response, evals, secure releases. We handle 24/7 operations so
                you don't need a team.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                productization
              </h3>
              <p class="text-sm text-zinc-400">
                Turn custom builds into repeatable packs, templates, and playbooks. Scale your
                offering without reinventing every time.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Ideal Partners -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">ideal partners</h2>

          <div class="space-y-4">
            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                agencies with pipeline but no in-house ai engineering
              </h3>
              <p class="text-sm text-zinc-400">
                You can sell AI faster than you can staff delivery. We become your technical
                backbone.
              </p>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                niche experts who can sell into a vertical but lack delivery capacity
              </h3>
              <p class="text-sm text-zinc-400">
                You know healthcare, finance, or legal inside out. We handle the technical
                execution and compliance.
              </p>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                fractional cmo shops that want a product line
              </h3>
              <p class="text-sm text-zinc-400">
                Expand from services to productized AI offerings. We build, you brand and sell.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Engagement Models -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-12 text-center">
            engagement models
          </h2>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">rev-share co-sell</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">$0 retainer</div>
              <p class="text-sm text-zinc-400 mb-6">
                We co-sell and build together. Revenue share on closed-won deals. Good for new
                product lines.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>No upfront cost to partner</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Aligned incentives on deals</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>We join sales calls as your CTO</span>
                </li>
              </ul>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">wholesale</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">fixed wholesale pricing</div>
              <p class="text-sm text-zinc-400 mb-6">
                Fixed wholesale for delivery + managed ops. You set retail pricing. Predictable
                margins for you.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Predictable cost structure</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>You control retail pricing</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>White-label ops included</span>
                </li>
              </ul>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">cto retainer</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">monthly retainer</div>
              <p class="text-sm text-zinc-400 mb-6">
                Monthly retainer for roadmap planning, architecture, security reviews, and sprint
                leadership.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Ongoing strategic guidance</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Architecture reviews</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Sprint leadership</span>
                </li>
              </ul>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8">
              <h3 class="text-xl font-semibold text-zinc-100 mb-3">per-workspace managed service</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-4">flat + usage</div>
              <p class="text-sm text-zinc-400 mb-6">
                Flat platform fee + usage at provider list prices. Enterprise add-ons available.
              </p>
              <ul class="space-y-2 text-sm text-zinc-400">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Usage at provider list prices</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Bring your own cloud accounts</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Budget caps and alerts</span>
                </li>
              </ul>
            </div>
          </div>

          <div class="mt-8 text-center">
            <p class="text-sm text-zinc-400">
              <strong class="text-zinc-300">Discovery sprint:</strong> $1,500, 1–2 weeks, produces
              architecture, backlog, and rollout plan (stays constant across all models)
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Starter Packs -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">starter packs (scope catalog)</h2>

          <div class="grid md:grid-cols-3 gap-6 mb-8">
            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                outbound sdr agents
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• Research + enrich leads</li>
                <li>• ICP scoring</li>
                <li>• Personalized outreach</li>
                <li>• Meeting intelligence</li>
              </ul>
              <span class="text-xs text-zinc-500">Typical delivery: 2–4 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                knowledge search + grounded answers
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• Docs and wiki integration</li>
                <li>• Vector search</li>
                <li>• Citation tracking</li>
                <li>• Access controls</li>
              </ul>
              <span class="text-xs text-zinc-500">Typical delivery: 2–3 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                support triage agents
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• CRM + ticket integrations</li>
                <li>• Response drafting</li>
                <li>• Escalation rules</li>
                <li>• Churn prediction</li>
              </ul>
              <span class="text-xs text-zinc-500">Typical delivery: 3–5 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                private ai portal
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• Internal ChatGPT-style UI</li>
                <li>• Model selection (Claude, GPT, Gemini)</li>
                <li>• Company data integration</li>
                <li>• Usage tracking</li>
              </ul>
              <span class="text-xs text-zinc-500">Typical delivery: 3–6 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                automation + agent pairing
              </h3>
              <ul class="text-sm text-zinc-400 space-y-2 mb-4">
                <li>• n8n for orchestration glue</li>
                <li>• Vertex for agent workflows</li>
                <li>• API integrations</li>
                <li>• Scheduled jobs</li>
              </ul>
              <span class="text-xs text-zinc-500">Typical delivery: 2–4 weeks</span>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-3">
                custom scope
              </h3>
              <p class="text-sm text-zinc-400 mb-4">
                Combine agents, custom logic, specialized integrations. Discovery sprint scopes
                feasibility.
              </p>
              <span class="text-xs text-zinc-500">Delivery varies by complexity</span>
            </div>
          </div>

          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
            <p class="text-sm text-zinc-300">
              <strong>Note:</strong> All packs are model- and cloud-agnostic. We deploy Claude,
              OpenAI, Gemini, Llama, Mistral, Qwen, fine-tunes, or local models based on your
              requirements.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8 text-center">how it works</h2>

          <div class="space-y-8">
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                1
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  qualify deal and risks
                </h3>
                <p class="text-sm text-zinc-400">
                  Initial call to understand vertical, timeline, compliance needs, and budget. We
                  assess technical feasibility.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                2
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  discovery sprint ($1,500)
                </h3>
                <p class="text-sm text-zinc-400">
                  1–2 weeks. Deliverables: architecture diagram, prioritized backlog, rollout plan,
                  risk assessment. This validates scope before committing to build.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                3
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  proposal with options (good/better/best)
                </h3>
                <p class="text-sm text-zinc-400">
                  We provide tiered options: basic MVP, enhanced features, or enterprise-grade.
                  Transparent pricing and timelines.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                4
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  mvp build (2–6 weeks)
                </h3>
                <p class="text-sm text-zinc-400">
                  Fixed-bid delivery. Includes deployment, testing, documentation, and team
                  training. White-label UI and docs.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                5
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  launch with budgets and alerts
                </h3>
                <p class="text-sm text-zinc-400">
                  Go live with monitoring, usage caps, cost alerts, and dashboards. Clients see
                  your branding.
                </p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-100 font-bold">
                6
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                  managed ops + iteration (monthly)
                </h3>
                <p class="text-sm text-zinc-400">
                  Ongoing monitoring, incident response, model updates, feature iteration. Flat
                  monthly fee + usage.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Standard Deliverables -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">standard deliverables</h2>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                architecture docs and data maps
              </h3>
              <p class="text-sm text-zinc-400">
                System diagrams, data flow maps, security architecture, compliance mappings.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                agent prompts/specs, tools, and tests
              </h3>
              <p class="text-sm text-zinc-400">
                Prompt templates, tool definitions, eval suites, test coverage reports.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                observability dashboards and budgets
              </h3>
              <p class="text-sm text-zinc-400">
                Monitoring dashboards, cost tracking, usage alerts, performance metrics.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                security checklist and release runbooks
              </h3>
              <p class="text-sm text-zinc-400">
                Deployment procedures, rollback steps, incident response playbooks.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                reseller kit for your client
              </h3>
              <p class="text-sm text-zinc-400">
                One-pagers, demo scripts, pitch deck, objection handling guides.
              </p>
            </div>

            <div class="card-slate">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">
                white-label ui and docs
              </h3>
              <p class="text-sm text-zinc-400">
                Brandable frontends, client-facing documentation, support portal.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Vertex -->
    <section class="py-24 bg-zinc-950 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">why vertex for production</h2>

          <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-8 mb-6">
            <p class="text-zinc-300 leading-relaxed mb-6">
              Production agents benefit from Vertex defaults and controls. We still support
              self-hosted and low-code when the risk profile and budget fit.
            </p>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h3 class="text-sm font-semibold text-zinc-100 mb-2 uppercase tracking-widest">
                  Vertex Agent Engine
                </h3>
                <ul class="space-y-2 text-sm text-zinc-400">
                  <li>• IAM, per-workspace service accounts</li>
                  <li>• VPC options, Private Service Connect</li>
                  <li>• Secret Manager, rotation, SLSA provenance</li>
                  <li>• Audit logs, SIEM export, policy controls</li>
                  <li>• Evals, guardrails, rollback gates</li>
                </ul>
              </div>

              <div>
                <h3 class="text-sm font-semibold text-zinc-100 mb-2 uppercase tracking-widest">
                  Self-Hosted / Low-Code
                </h3>
                <ul class="space-y-2 text-sm text-zinc-400">
                  <li>• Good for orchestration glue</li>
                  <li>• Quick integration wins</li>
                  <li>• Lower volume automations</li>
                  <li>• Air-gapped requirements</li>
                  <li>• Budget-constrained projects</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="text-center">
            <a
              href="/learn/security"
              class="text-sm text-zinc-200 hover:text-zinc-50 transition-smooth inline-flex items-center gap-2"
            >
              Learn: Security comparison (Vertex vs self-hosted)
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Anchors -->
    <section class="py-24 border-b border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-8">pricing anchors (public-facing)</h2>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">mvp build</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-3">$8K–$25K</div>
              <p class="text-sm text-zinc-400">
                Typical scope, fixed-bid. Varies by integrations, compliance, and data complexity.
              </p>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">managed service</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-3">from $1,497/mo</div>
              <p class="text-sm text-zinc-400">
                Flat platform fee + usage at provider list prices. Includes monitoring and support.
              </p>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">enterprise private ai</h3>
              <div class="text-2xl font-bold text-zinc-50 mb-3">from $3,000/mo</div>
              <p class="text-sm text-zinc-400">
                Dedicated infrastructure, priority support, compliance documentation.
              </p>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-zinc-100 mb-2">optional add-ons</h3>
              <div class="text-lg font-bold text-zinc-50 mb-3">custom pricing</div>
              <p class="text-sm text-zinc-400">
                Custom SLAs, security audits, compliance work (HIPAA, SOC 2, FedRAMP).
              </p>
            </div>
          </div>

          <div class="mt-8 bg-zinc-900/50 border border-zinc-800 rounded-lg p-6">
            <p class="text-sm text-zinc-400">
              <strong class="text-zinc-300">Usage pricing:</strong> Billed at provider list prices
              for search, storage, models, and network. Bring your own cloud accounts or we
              provision a tenant. Budgets enforced with caps, alerts, and prepaid blocks.
            </p>
            <div class="mt-4">
              <a
                href="/learn/pricing"
                class="text-sm text-zinc-200 hover:text-zinc-50 transition-smooth inline-flex items-center gap-2"
              >
                Learn: How pricing works
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Seller Kit Request -->
    <section class="py-24 bg-zinc-950">
      <div class="container mx-auto px-8">
        <div class="max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold text-zinc-50 mb-6 text-center">
            request seller kit
          </h2>
          <p class="text-zinc-400 mb-8 text-center">
            Get our pitch deck (10 slides), vertical one-pagers, demo scripts, pricing calculator,
            and case study templates. We'll send an automated email with everything you need to
            start selling.
          </p>

          <form
            name="seller-kit"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-6"
          >
            <input type="hidden" name="form-name" value="seller-kit" />
            <p class="hidden">
              <label>
                Don't fill this out if you're human: <input name="bot-field" />
              </label>
            </p>

            <div>
              <label for="agency-name" class="block text-sm font-medium text-zinc-300 mb-2">
                agency/company name
              </label>
              <input
                type="text"
                id="agency-name"
                name="agency-name"
                required
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="Your Agency Name"
              />
            </div>

            <div>
              <label for="contact-name" class="block text-sm font-medium text-zinc-300 mb-2">
                your name
              </label>
              <input
                type="text"
                id="contact-name"
                name="contact-name"
                required
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="Your Name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-zinc-300 mb-2">
                email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="you@agency.com"
              />
            </div>

            <div>
              <label for="website" class="block text-sm font-medium text-zinc-300 mb-2">
                agency website (optional)
              </label>
              <input
                type="url"
                id="website"
                name="website"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="https://yoursite.com"
              />
            </div>

            <div>
              <label for="verticals" class="block text-sm font-medium text-zinc-300 mb-2">
                verticals you serve
              </label>
              <input
                type="text"
                id="verticals"
                name="verticals"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 placeholder-zinc-500 focus:outline-none focus:border-zinc-400 transition-smooth"
                placeholder="e.g., healthcare, finance, B2B SaaS"
              />
            </div>

            <div>
              <label for="pipeline-stage" class="block text-sm font-medium text-zinc-300 mb-2">
                current pipeline stage
              </label>
              <select
                id="pipeline-stage"
                name="pipeline-stage"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 focus:outline-none focus:border-zinc-400 transition-smooth"
              >
                <option value="exploring">Just exploring</option>
                <option value="have-leads">Have active leads</option>
                <option value="signed-client">Have a signed client ready</option>
                <option value="multiple-deals">Managing multiple deals</option>
              </select>
            </div>

            <div>
              <label for="engagement-model" class="block text-sm font-medium text-zinc-300 mb-2">
                preferred engagement model
              </label>
              <select
                id="engagement-model"
                name="engagement-model"
                class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-50 focus:outline-none focus:border-zinc-400 transition-smooth"
              >
                <option value="">Select one</option>
                <option value="rev-share">Rev-share co-sell</option>
                <option value="wholesale">Wholesale pricing</option>
                <option value="cto-retainer">CTO retainer</option>
                <option value="per-workspace">Per-workspace managed service</option>
                <option value="not-sure">Not sure yet</option>
              </select>
            </div>

            <button type="submit" class="w-full btn-primary">
              send seller kit
            </button>

            <p class="text-xs text-zinc-500 text-center">
              You'll receive an automated email with the seller kit within 5 minutes. Check spam if
              you don't see it.
            </p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
