---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="Automation Programs - Intent Solutions">
  <!-- SECTION 1: Hero + Features (IMAGE BACKGROUND) -->
  <section class="automation-hero-section">
    <div class="container">
      <!-- Hero Content -->
      <div class="hero-content">
        <span class="section-badge">Automation</span>
        <h1><span class="highlight-box">Automations</span> That Feel Like An Extra Teammate</h1>
        <p>We design n8n and Netlify automation programs that handle the boring stuff—reporting, onboarding, follow-ups—while keeping humans in the driver's seat.</p>
      </div>

      <!-- Features Content -->
      <div class="features-content">
        <div class="features-grid">
          <div class="feature">
            <h3>Observable & Auditable</h3>
            <p>Everything is documented with clear logs, making it easy to review what happened and when for compliance needs.</p>
          </div>
          <div class="feature">
            <h3>Humans in the Loop</h3>
            <p>Automations assist your team rather than replace them. Critical decisions always have human oversight.</p>
          </div>
          <div class="feature">
            <h3>Ready for Scale</h3>
            <p>Built on n8n and Netlify infrastructure that grows with your business without breaking.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Custom + CTA (DARK + TEAL WAVE) -->
  <section class="automation-cta-section">
    <div class="wave-background">
      <svg class="wave wave-1" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="rgba(13, 148, 136, 0.3)" d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
      <svg class="wave wave-2" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="rgba(20, 184, 166, 0.2)" d="M0,64L48,80C96,96,192,128,288,128C384,128,480,96,576,90.7C672,85,768,107,864,144C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
    </div>

    <div class="custom-content">
      <div class="container">
        <h2>Need Something <span class="highlight-box">Custom</span>?</h2>
        <p>We configure Intent Agent Models for research, compliance, data processing, content generation, or any business logic you need.</p>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-secondary-light">Discuss Your Use Case</a>
      </div>
    </div>

    <div class="cta-content">
      <div class="container">
        <h2>Ready to Build Your <span class="highlight-box">AI System</span>?</h2>
        <p>Tell us about your team and goals — we'll respond within 24 hours.</p>
        <a href="mailto:jeremy@intentsolutions.io" class="btn-primary">Start a Project</a>
      </div>
    </div>
  </section>
</LayoutRedesign>

<style>
  /* ============================================
     Highlight Box
     ============================================ */
  .highlight-box {
    display: inline-block;
    background: var(--color-highlight);
    color: var(--bg-dark);
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
  }

  /* ============================================
     SECTION 1: Hero + Features (IMAGE)
     ============================================ */
  .automation-hero-section {
    position: relative;
    background:
      linear-gradient(
        to bottom,
        rgba(10, 15, 26, 0.88) 0%,
        rgba(10, 15, 26, 0.75) 40%,
        rgba(10, 15, 26, 0.80) 100%
      ),
      url('/images/hero-automation.jpg') center/cover no-repeat;
    background-attachment: scroll, fixed;
    overflow: hidden;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero Content */
  .hero-content {
    padding: 8rem 0 4rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-light);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .hero-content h1 {
    color: var(--text-light);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .hero-content p {
    color: var(--text-light-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 750px;
    margin: 0 auto;
  }

  /* Features Content */
  .features-content {
    padding: 4rem 0 6rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .feature {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2rem;
    border-radius: var(--radius-lg);
    transition: var(--transition-base);
  }

  .feature:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
  }

  .feature h3 {
    color: var(--color-accent-secondary);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .feature p {
    color: var(--text-light-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 6rem 0 3rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .features-content {
      padding: 3rem 0 4rem;
    }
  }

  /* ============================================
     SECTION 2: Custom + CTA (DARK + WAVES)
     ============================================ */
  .automation-cta-section {
    position: relative;
    background: var(--bg-dark);
    overflow: hidden;
  }

  .wave-background {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .wave-1 {
    animation: wave-float 20s ease-in-out infinite;
  }

  .wave-2 {
    animation: wave-float 15s ease-in-out infinite reverse;
  }

  @keyframes wave-float {
    0%, 100% {
      transform: translateX(0) translateY(0);
    }
    50% {
      transform: translateX(-20px) translateY(10px);
    }
  }

  .custom-content,
  .cta-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  /* Custom Content */
  .custom-content {
    padding: 5rem 0 4rem;
  }

  .custom-content h2 {
    color: var(--text-light);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .custom-content p {
    color: var(--text-light-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto 1.5rem;
  }

  .btn-secondary-light {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.3);
    color: var(--text-light);
    padding: 0.875rem 2rem;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .btn-secondary-light:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--text-light);
    transform: translateY(-2px);
  }

  /* CTA Content */
  .cta-content {
    padding: 4rem 0 6rem;
  }

  .cta-content h2 {
    color: var(--text-light);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: var(--text-light-muted);
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--text-light);
    color: var(--bg-dark);
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .custom-content {
      padding: 3rem 0 2rem;
    }

    .cta-content {
      padding: 3rem 0 5rem;
    }
  }
</style>
