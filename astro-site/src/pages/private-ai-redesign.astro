---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="Private AI - Intent Solutions">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge">Private AI Infrastructure</span>
        </div>

        <h1 class="hero-title">
          Your AI. Your data.<br />Your control.
        </h1>

        <p class="hero-description">
          Keep data on your cloud while offering a ChatGPT-style experience to every teammate.
          Model-agnostic, HIPAA-ready, and fully managed.
        </p>

        <div class="hero-ctas">
          <a href="#contact" class="btn btn-primary btn-lg">
            Start Your Private AI
          </a>
          <a href="#pricing" class="btn btn-secondary btn-lg">
            View Pricing
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Section -->
  <section class="section comparison-section">
    <div class="container">
      <div class="section-header">
        <h2>Why Private AI?</h2>
        <p>Compare cloud-based AI with private infrastructure built for your organization.</p>
      </div>

      <div class="comparison-grid">
        <div class="comparison-column">
          <div class="comparison-header cloud">
            <h3>Cloud AI</h3>
            <p class="comparison-subtitle">(ChatGPT, Claude, Gemini)</p>
          </div>
          <ul class="comparison-list">
            <li class="comparison-item negative">
              <svg class="icon-x" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
              <span>Your data leaves your infrastructure</span>
            </li>
            <li class="comparison-item negative">
              <svg class="icon-x" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
              <span>Limited control over model versions</span>
            </li>
            <li class="comparison-item negative">
              <svg class="icon-x" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
              <span>Vendor lock-in with single provider</span>
            </li>
            <li class="comparison-item negative">
              <svg class="icon-x" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
              <span>Compliance concerns (HIPAA, SOC 2)</span>
            </li>
            <li class="comparison-item negative">
              <svg class="icon-x" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
              <span>No custom model fine-tuning</span>
            </li>
          </ul>
        </div>

        <div class="comparison-column">
          <div class="comparison-header private">
            <h3>Private AI</h3>
            <p class="comparison-subtitle">(Your Infrastructure)</p>
          </div>
          <ul class="comparison-list">
            <li class="comparison-item positive">
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Data stays in your Google Cloud project</span>
            </li>
            <li class="comparison-item positive">
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Switch between 9+ AI models anytime</span>
            </li>
            <li class="comparison-item positive">
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>No vendor lock-in, complete portability</span>
            </li>
            <li class="comparison-item positive">
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>HIPAA-ready, audit logs included</span>
            </li>
            <li class="comparison-item positive">
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Fine-tune models on your data</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="section pricing-section" id="pricing">
    <div class="container">
      <div class="section-header">
        <h2>Private AI Packages</h2>
        <p>Choose the package that fits your team's needs. All packages include deployment, training, and ongoing support.</p>
      </div>

      <div class="pricing-grid">
        <!-- Professional Package -->
        <div class="pricing-card">
          <div class="pricing-header">
            <h3>Professional Package</h3>
            <p class="pricing-description">For teams of 10-50 who need enterprise AI without enterprise complexity</p>
          </div>

          <div class="pricing-cost">
            <div class="price-setup">
              <span class="price-label">Setup</span>
              <span class="price-value">$8,000</span>
              <span class="price-note">one-time</span>
            </div>
            <div class="price-monthly">
              <span class="price-label">Monthly</span>
              <span class="price-value">$3,000</span>
              <span class="price-note">per month</span>
            </div>
          </div>

          <ul class="pricing-features">
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>ChatGPT-style web interface</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>9+ AI models (Claude, Gemini, Llama, etc.)</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Deployed to your Google Cloud project</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>HIPAA-ready infrastructure</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>User authentication & role management</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Basic monitoring & logging</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>4 hours training + documentation</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Email support (24hr response)</span>
            </li>
          </ul>

          <a href="#contact" class="btn btn-primary btn-block">Get Started</a>
        </div>

        <!-- Enterprise Package -->
        <div class="pricing-card featured">
          <div class="featured-badge">Most Popular</div>
          <div class="pricing-header">
            <h3>Enterprise Package</h3>
            <p class="pricing-description">For organizations requiring custom integrations, advanced security, and dedicated support</p>
          </div>

          <div class="pricing-cost">
            <div class="price-setup">
              <span class="price-label">Setup</span>
              <span class="price-value">$15,000</span>
              <span class="price-note">one-time</span>
            </div>
            <div class="price-monthly">
              <span class="price-label">Monthly</span>
              <span class="price-value">$5,000</span>
              <span class="price-note">per month</span>
            </div>
          </div>

          <ul class="pricing-features">
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span><strong>Everything in Professional, plus:</strong></span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Custom model fine-tuning</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Advanced RAG with vector search</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Custom integrations (Slack, Teams, CRM)</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>SSO/SAML authentication</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Advanced monitoring & alerting</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Multi-region deployment</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Dedicated Slack channel</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Priority support (4hr response)</span>
            </li>
            <li>
              <svg class="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Quarterly strategy sessions</span>
            </li>
          </ul>

          <a href="#contact" class="btn btn-primary btn-block">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="section included-section">
    <div class="container">
      <div class="section-header">
        <h2>What's Included</h2>
        <p>Everything you need for production-ready private AI infrastructure.</p>
      </div>

      <div class="included-grid">
        <div class="included-card">
          <div class="included-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
            </svg>
          </div>
          <h3>Infrastructure</h3>
          <ul>
            <li>Google Cloud Run deployment</li>
            <li>Firebase authentication</li>
            <li>Cloud Storage for files</li>
            <li>Firestore for chat history</li>
            <li>Load balancing & auto-scaling</li>
          </ul>
        </div>

        <div class="included-card">
          <div class="included-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 2l-4.2 4.2m13.2-5.2h-6m-6 0H1m13.2 5.2l-4.2-4.2m0-2L5.8 5.8"></path>
            </svg>
          </div>
          <h3>AI Models</h3>
          <ul>
            <li>Claude 3.5 Sonnet, Opus</li>
            <li>Gemini 1.5 Pro, Flash</li>
            <li>Llama 3.1, 3.2</li>
            <li>Command R+, Mistral</li>
            <li>Switch models anytime</li>
          </ul>
        </div>

        <div class="included-card">
          <div class="included-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="9" y1="9" x2="15" y2="9"></line>
              <line x1="9" y1="15" x2="15" y2="15"></line>
            </svg>
          </div>
          <h3>Applications</h3>
          <ul>
            <li>ChatGPT-style web interface</li>
            <li>Mobile-responsive design</li>
            <li>File upload & analysis</li>
            <li>Conversation history</li>
            <li>Prompt templates</li>
          </ul>
        </div>

        <div class="included-card">
          <div class="included-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <h3>Security</h3>
          <ul>
            <li>Data stays in your cloud</li>
            <li>HIPAA-ready infrastructure</li>
            <li>SOC 2 compliance ready</li>
            <li>Audit logs & monitoring</li>
            <li>Role-based access control</li>
          </ul>
        </div>

        <div class="included-card">
          <div class="included-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <h3>Support</h3>
          <ul>
            <li>48-hour deployment</li>
            <li>Team training included</li>
            <li>Complete documentation</li>
            <li>Email & Slack support</li>
            <li>Regular updates & patches</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Example Scopes Section -->
  <section class="section examples-section">
    <div class="container">
      <div class="section-header">
        <h2>Example Scopes</h2>
        <p>Real-world implementations we've built for clients across industries.</p>
      </div>

      <div class="examples-grid">
        <div class="example-card">
          <div class="example-header">
            <h3>Healthcare Practice</h3>
            <span class="example-badge">HIPAA Ready</span>
          </div>
          <p class="example-scope"><strong>Scope:</strong> 15-person clinic needed HIPAA-compliant AI for clinical notes, patient communication drafts, and research.</p>
          <ul class="example-features">
            <li><strong>Solution:</strong> Professional Package</li>
            <li><strong>Models:</strong> Claude 3.5 Sonnet (primary), Gemini 1.5 Pro (backup)</li>
            <li><strong>Integration:</strong> Custom prompts for clinical documentation</li>
            <li><strong>Timeline:</strong> 48 hours from kickoff to launch</li>
            <li><strong>Cost:</strong> $8K setup + $3K/month</li>
          </ul>
        </div>

        <div class="example-card">
          <div class="example-header">
            <h3>Law Firm</h3>
            <span class="example-badge">Enterprise</span>
          </div>
          <p class="example-scope"><strong>Scope:</strong> 50-attorney firm needed private AI with document analysis, legal research, and contract review capabilities.</p>
          <ul class="example-features">
            <li><strong>Solution:</strong> Enterprise Package</li>
            <li><strong>Models:</strong> Claude Opus, Gemini Pro, fine-tuned Llama</li>
            <li><strong>Integration:</strong> RAG with 10K+ legal documents, custom Slack bot</li>
            <li><strong>Timeline:</strong> 2 weeks (custom RAG pipeline)</li>
            <li><strong>Cost:</strong> $15K setup + $5K/month</li>
          </ul>
        </div>

        <div class="example-card">
          <div class="example-header">
            <h3>CPA Firm</h3>
            <span class="example-badge">Professional</span>
          </div>
          <p class="example-scope"><strong>Scope:</strong> 20-person accounting firm needed secure AI for tax research, client communication, and document preparation.</p>
          <ul class="example-features">
            <li><strong>Solution:</strong> Professional Package</li>
            <li><strong>Models:</strong> Claude 3.5 Sonnet, Gemini Flash</li>
            <li><strong>Integration:</strong> Custom tax research prompts, audit logging</li>
            <li><strong>Timeline:</strong> 48 hours</li>
            <li><strong>Cost:</strong> $8K setup + $3K/month</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Launch Plan Section -->
  <section class="section launch-section">
    <div class="container">
      <div class="section-header">
        <h2>Your 48-Hour Launch Plan</h2>
        <p>We move fast. Here's exactly what happens from kickoff to launch.</p>
      </div>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-marker">1</div>
          <div class="timeline-content">
            <h3>Day 1: Setup & Configuration</h3>
            <ul>
              <li><strong>Hour 0-2:</strong> Kickoff call, gather requirements, review security needs</li>
              <li><strong>Hour 2-4:</strong> Create Google Cloud project, enable APIs, configure IAM</li>
              <li><strong>Hour 4-6:</strong> Deploy infrastructure (Cloud Run, Firebase, Firestore)</li>
              <li><strong>Hour 6-8:</strong> Configure AI models, test API connections</li>
            </ul>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">2</div>
          <div class="timeline-content">
            <h3>Day 2: Testing & Training</h3>
            <ul>
              <li><strong>Hour 0-2:</strong> Internal testing, security review, user acceptance testing</li>
              <li><strong>Hour 2-4:</strong> Team training session, walkthrough documentation</li>
              <li><strong>Hour 4-6:</strong> Launch to pilot users, monitor performance</li>
              <li><strong>Hour 6-8:</strong> Address feedback, final tweaks, full team launch</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Security Section -->
  <section class="section security-section">
    <div class="container">
      <div class="section-header">
        <h2>Security-First Data Flow</h2>
        <p>Your data never leaves your infrastructure. Here's how it works.</p>
      </div>

      <div class="security-diagram">
        <div class="flow-step">
          <div class="flow-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <h3>1. User Input</h3>
          <p>Team member asks question through your private web interface</p>
        </div>

        <div class="flow-arrow">→</div>

        <div class="flow-step">
          <div class="flow-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
            </svg>
          </div>
          <h3>2. Your Cloud</h3>
          <p>Request stays in your Google Cloud project (us-central1)</p>
        </div>

        <div class="flow-arrow">→</div>

        <div class="flow-step">
          <div class="flow-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M12 1v6m0 6v6"></path>
            </svg>
          </div>
          <h3>3. AI Processing</h3>
          <p>Vertex AI processes request using your chosen model</p>
        </div>

        <div class="flow-arrow">→</div>

        <div class="flow-step">
          <div class="flow-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <h3>4. Secure Storage</h3>
          <p>Response saved in your Firestore, audit logged</p>
        </div>
      </div>

      <div class="security-badges">
        <div class="security-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>HIPAA Ready</span>
        </div>
        <div class="security-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>SOC 2 Compliant</span>
        </div>
        <div class="security-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>Audit Logs</span>
        </div>
        <div class="security-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>Data Residency</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section faq-section">
    <div class="container">
      <div class="section-header">
        <h2>Frequently Asked Questions</h2>
      </div>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>Do I need my own Google Cloud account?</h3>
          <p>Yes. Private AI deploys to your Google Cloud project, ensuring your data stays under your control. We'll help you set everything up if you don't have an account yet.</p>
        </div>

        <div class="faq-item">
          <h3>What are the ongoing Google Cloud costs?</h3>
