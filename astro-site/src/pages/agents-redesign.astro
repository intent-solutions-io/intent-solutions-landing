---
import LayoutRedesign from '../layouts/LayoutRedesign.astro';
---

<LayoutRedesign title="AI Agents - Containerized Automation | Intent Solutions">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge">AI Agents · Custom Built for Your Workflow</span>
        </div>

        <h1 class="hero-title">
          Customizable Intent<br />Agent Models (IAM)
        </h1>

        <p class="hero-description">
          We customize Intent Agent Models for any workflow. Below are pre-configured packages (M1/M2/M3) for sales and support.
          See PipelinePilot MVP for a custom 4-agent SDR automation built with IAM. We configure agents for research, compliance,
          data processing, content generation, or any business logic you need.
        </p>

        <div class="hero-ctas">
          <a href="/learn/pricing" class="btn btn-primary btn-lg">
            See How Pricing Works
          </a>
          <a href="mailto:jeremy@intentsolutions.io?subject=AI Agent Demo Request" class="btn btn-secondary btn-lg">
            Book a Demo →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Example Callout -->
  <section class="example-section">
    <div class="container">
      <div class="example-content">
        <p class="example-label">Example: Customized IAM for SDR Automation</p>
        <p class="example-text">
          PipelinePilot shows what's possible with customized Intent Agent Models. It uses 4 specialized IAM agents
          (Orchestrator, Data Captain, Content Analyst, Readiness Auditor) configured for SDR workflows—from
          Clay/Apollo ingestion to multi-step outbound campaigns. The IAE packages below (M1/M2/M3) are pre-configured
          starters. We customize IAM for any workflow.
        </p>
        <a href="https://pipelinepilot-prod.web.app" target="_blank" rel="noopener noreferrer" class="example-link">
          See PipelinePilot MVP →
        </a>
      </div>
    </div>
  </section>

  <!-- IAE Models Section -->
  <section class="section models-section">
    <div class="container">
      <div class="section-header">
        <h2>Intent Agent Engine (IAE) Models</h2>
      </div>

      <div class="models-grid">
        <!-- IAE Model 1 -->
        <div class="model-card model-featured">
          <h3>IAE: Model 1</h3>
          <p class="model-description">
            Intelligence Core. Analyzes your closed deals, learns your ICP, scores leads from one data source.
            Intelligence only—no execution. Google Cloud native.
          </p>

          <div class="model-includes">
            <h4>What's Included:</h4>
            <div class="tag-list">
              <span class="tag">Vertex AI Anthropic</span>
              <span class="tag">1 Data Connector</span>
              <span class="tag">ICP Scoring</span>
              <span class="tag">BigQuery Analytics</span>
            </div>
          </div>

          <div class="model-replaces">
            <h4>Replaces:</h4>
            <p>1-2 data analysts at $80-160K/year salary. Save 78-89% with managed service at $1,497/mo.</p>
          </div>

          <div class="model-pricing">
            <div class="pricing-row">
              <span>Self-serve</span>
              <span class="price">$497/mo</span>
            </div>
            <div class="pricing-row">
              <span>Managed</span>
              <span class="price">$1,497/mo</span>
            </div>
            <div class="pricing-row small">
              <span>Custom build</span>
              <span>$15-30K + $497/mo</span>
            </div>
          </div>

          <a href="/intel-engine" class="model-link">Learn More →</a>
        </div>

        <!-- IAE Model 2 -->
        <div class="model-card">
          <h3>IAE: Model 2</h3>
          <p class="model-description">
            Execution Layer. Takes scored leads from M1, executes personalized outreach, captures meeting intelligence,
            sends feedback to M1. Multi-channel orchestration.
          </p>

          <div class="model-includes">
            <h4>What It Adds:</h4>
            <div class="tag-list">
              <span class="tag">Outbound Execution</span>
              <span class="tag">Email Campaigns</span>
              <span class="tag">Meeting Intelligence</span>
              <span class="tag">Feedback Loop</span>
            </div>
          </div>

          <div class="model-replaces">
            <h4>Replaces:</h4>
            <p>3-5 SDRs at $225-375K/year salary. 10x better response rates. Total with M1: $2,997/mo bundle.</p>
          </div>

          <div class="model-pricing">
            <div class="pricing-row">
              <span>A la carte</span>
              <span class="price">$1,997/mo</span>
            </div>
            <div class="pricing-row featured">
              <span>M1+M2 bundle</span>
              <span class="price">$2,997/mo</span>
            </div>
            <div class="pricing-row small">
              <span>Save $497/mo with bundle</span>
            </div>
          </div>

          <a href="mailto:jeremy@intentsolutions.io?subject=IAE Model 2 Demo" class="model-link">Book Demo →</a>
        </div>

        <!-- IAE Model 3 -->
        <div class="model-card">
          <h3>IAE: Model 3</h3>
          <p class="model-description">
            Support Intelligence. Monitors support tickets, identifies pain points, sends churn signals to M1,
            drafts responses using M2 execution layer. Human-in-the-loop approval.
          </p>

          <div class="model-includes">
            <h4>What It Adds:</h4>
            <div class="tag-list">
              <span class="tag">Ticket Triage</span>
              <span class="tag">Response Drafting</span>
              <span class="tag">Churn Prediction</span>
              <span class="tag">ICP Refinement</span>
            </div>
          </div>

          <div class="model-replaces">
            <h4>Replaces:</h4>
            <p>2 support agents at $120-160K/year salary. First response in 4 minutes vs 4 hours. Full stack: $3,997/mo bundle.</p>
          </div>

          <div class="model-pricing">
            <div class="pricing-row">
              <span>A la carte</span>
              <span class="price">$997/mo</span>
            </div>
            <div class="pricing-row featured">
              <span>Full stack bundle</span>
              <span class="price">$3,997/mo</span>
            </div>
            <div class="pricing-row small">
              <span>Save $1,491/mo with bundle</span>
            </div>
          </div>

          <a href="mailto:jeremy@intentsolutions.io?subject=IAE Model 3 Demo" class="model-link">Book Demo →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How Pricing Works -->
  <section class="section pricing-info-section">
    <div class="container">
      <div class="section-header">
        <h2>How Pricing Works</h2>
        <p>Transparent engagement ladder. Discovery sprint, MVP build, managed service, or enterprise.</p>
      </div>

      <div class="pricing-tiers">
        <div class="tier-card">
          <h3>Discovery Sprint</h3>
          <p class="tier-price">$2,997</p>
          <p>2-week discovery to validate use case, define requirements, and prototype solution.</p>
        </div>

        <div class="tier-card">
          <h3>MVP Build</h3>
          <p class="tier-price">$15-30K</p>
          <p>Custom agent development with your data, workflows, and business logic. 4-6 week delivery.</p>
        </div>

        <div class="tier-card tier-featured">
          <div class="tier-badge">Most Popular</div>
          <h3>Managed Service</h3>
          <p class="tier-price">$497-3,997/mo</p>
          <p>Ongoing hosting, monitoring, updates, and support. Choose from IAE M1/M2/M3 packages.</p>
        </div>

        <div class="tier-card">
          <h3>Enterprise</h3>
          <p class="tier-price">Custom</p>
          <p>White-label solutions, dedicated support, SLA guarantees, and custom integrations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Intentional AI, practical solutions</h2>
        <p>Book a 15-minute demo to see the agents in action and discuss your use case.</p>
        <div class="cta-buttons">
          <a href="mailto:jeremy@intentsolutions.io?subject=AI Agent Demo Request" class="btn btn-primary btn-lg">
            Book a Demo
          </a>
          <a href="#pricing" class="btn btn-secondary btn-lg">
            See Pricing Again ↑
          </a>
        </div>
        <p class="cta-note">
          jeremy@intentsolutions.io · no contracts · no lock-in · export your data anytime
        </p>
      </div>
    </div>
  </section>
</LayoutRedesign>

<style>
  /* Hero Section */
  .hero-section {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, rgb(var(--color-bg-secondary)) 0%, rgb(var(--color-bg-primary)) 100%);
  }

  @media (min-width: 768px) {
    .hero-section {
      padding: 8rem 0 6rem;
    }
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-badge {
    margin-bottom: 1.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-accent-primary));
    background-color: rgb(var(--color-accent-light));
    border: 1px solid rgb(var(--color-accent-lighter));
    border-radius: var(--radius-full);
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
    color: rgb(var(--color-text-primary));
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 3.5rem;
    }
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 2.5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Example Section */
  .example-section {
    padding: 2rem 0;
    background: linear-gradient(135deg, rgb(var(--color-accent-primary) / 0.1), rgb(67 56 202 / 0.05));
    border-top: 1px solid rgb(var(--color-accent-primary) / 0.2);
    border-bottom: 1px solid rgb(var(--color-accent-primary) / 0.2);
  }

  .example-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .example-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: rgb(var(--color-accent-primary));
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .example-text {
    font-size: 1rem;
    line-height: 1.7;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 1rem;
  }

  .example-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgb(var(--color-accent-primary));
    text-decoration: none;
    transition: gap var(--transition-fast);
  }

  .example-link:hover {
    gap: 0.75rem;
  }

  /* Models Section */
  .models-section {
    background-color: white;
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .models-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .models-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .model-card {
    padding: 2rem;
    background-color: white;
    border: 2px solid rgb(var(--color-border));
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .model-card:hover {
    border-color: rgb(var(--color-accent-primary));
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }

  .model-featured {
    border-color: rgb(var(--color-accent-primary));
    box-shadow: var(--shadow-lg);
  }

  .model-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: rgb(var(--color-text-primary));
  }

  .model-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 1.5rem;
  }

  .model-includes,
  .model-replaces {
    margin-bottom: 1.5rem;
  }

  .model-includes h4,
  .model-replaces h4 {
    font-size: 0.875rem;
    font-weight: 700;
    color: rgb(var(--color-text-primary));
    margin-bottom: 0.75rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgb(var(--color-text-secondary));
    background-color: rgb(var(--color-bg-secondary));
    border-radius: var(--radius-md);
  }

  .model-replaces p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  .model-pricing {
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(var(--color-border));
    margin-bottom: 1.5rem;
  }

  .pricing-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    font-size: 0.9375rem;
  }

  .pricing-row.featured {
    background-color: rgb(var(--color-accent-light));
    padding: 0.75rem 1rem;
    margin: 0 -1rem;
    border-radius: var(--radius-md);
  }

  .pricing-row.small {
    font-size: 0.8125rem;
    color: rgb(var(--color-text-tertiary));
  }

  .price {
    font-weight: 700;
    color: rgb(var(--color-text-primary));
  }

  .pricing-row.featured .price {
    color: rgb(var(--color-accent-primary));
  }

  .model-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgb(var(--color-accent-primary));
    text-decoration: none;
    transition: gap var(--transition-fast);
  }

  .model-link:hover {
    gap: 0.75rem;
  }

  /* Pricing Info Section */
  .pricing-info-section {
    background-color: rgb(var(--color-bg-secondary));
  }

  .pricing-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .pricing-tiers {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pricing-tiers {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .tier-card {
    position: relative;
    padding: 2rem;
    background-color: white;
    border: 2px solid rgb(var(--color-border));
    border-radius: var(--radius-xl);
    text-align: center;
  }

  .tier-featured {
    border-color: rgb(var(--color-accent-primary));
    box-shadow: var(--shadow-lg);
  }

  .tier-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    background-color: rgb(var(--color-accent-primary));
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tier-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: rgb(var(--color-text-primary));
  }

  .tier-price {
    font-size: 2rem;
    font-weight: 700;
    color: rgb(var(--color-accent-primary));
    margin-bottom: 1rem;
  }

  .tier-card p:last-child {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgb(var(--color-text-secondary));
    margin: 0;
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, rgb(var(--color-accent-primary)), rgb(67 56 202));
    color: white;
  }

  .cta-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    color: white;
    margin-bottom: 1rem;
  }

  .cta-content > p {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .cta-buttons .btn {
    background-color: white;
    color: rgb(var(--color-accent-primary));
    border-color: white;
  }

  .cta-buttons .btn:hover {
    background-color: rgba(255, 255, 255, 0.95);
    transform: translateY(-2px);
  }

  .cta-buttons .btn-secondary {
    background-color: transparent;
    color: white;
    border-color: white;
  }

  .cta-buttons .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .cta-note {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }
</style>
