---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Footer from '../../components/Footer';
import LearnHero from '../../components/LearnHero';
import LearnOfferings from '../../components/LearnOfferings';
import Contact from '../../components/Contact';
---

<Layout
  title="Learn with Jeremy | Claude Code Training & Coaching"
  description="Skip the tutorials that stop at 'Hello World'. 1:1 coaching, live workshops, and hands-on training from a Claude Code specialist with 227+ plugins."
>
  <SiteNav />

  <main class="bg-zinc-900">
    <LearnHero client:load />
    <LearnOfferings client:visible />

    <!-- Resources Section - Previous education cards -->
    <section class="py-20 bg-zinc-900 border-t border-zinc-800/60">
      <div class="container mx-auto px-8">
        <div class="text-center mb-12">
          <h2 class="text-h2 font-bold text-zinc-50 mb-4">
            resources
          </h2>
          <p class="text-zinc-400">
            Self-serve guides on how we work
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
          <!-- Pricing Card -->
          <a
            href="/learn/pricing"
            class="card-slate block transition-smooth hover:border-zinc-600 group h-full flex flex-col"
          >
            <div class="text-4xl mb-4">💰</div>
            <h3 class="text-xl font-semibold text-zinc-100 mb-3 group-hover:text-zinc-50">
              how pricing works
            </h3>
            <p class="text-sm text-zinc-400 flex-1 mb-4">
              Flat platform fee + usage at provider list prices. Budget controls, prepaid blocks,
              and export flexibility. No lock-in.
            </p>
            <span class="text-sm text-zinc-200 group-hover:text-zinc-50 inline-flex items-center gap-2">
              Read guide
              <span aria-hidden="true">→</span>
            </span>
          </a>

          <!-- Security Card -->
          <a
            href="/learn/security"
            class="card-slate block transition-smooth hover:border-zinc-600 group h-full flex flex-col"
          >
            <div class="text-4xl mb-4">🔒</div>
            <h3 class="text-xl font-semibold text-zinc-100 mb-3 group-hover:text-zinc-50">
              security: vertex vs self-hosted
            </h3>
            <p class="text-sm text-zinc-400 flex-1 mb-4">
              Why we recommend Vertex Agent Engine for production agents. Comparison with
              self-hosted low-code and when each approach fits.
            </p>
            <span class="text-sm text-zinc-200 group-hover:text-zinc-50 inline-flex items-center gap-2">
              Compare approaches
              <span aria-hidden="true">→</span>
            </span>
          </a>

          <!-- Models Card -->
          <a
            href="/learn/models"
            class="card-slate block transition-smooth hover:border-zinc-600 group h-full flex flex-col"
          >
            <div class="text-4xl mb-4">🤖</div>
            <h3 class="text-xl font-semibold text-zinc-100 mb-3 group-hover:text-zinc-50">
              model-agnostic delivery
            </h3>
            <p class="text-sm text-zinc-400 flex-1 mb-4">
              Claude, OpenAI, Gemini, Llama, Mistral, Qwen, fine-tunes, or local. We select per
              use case, data policy, latency, and cost.
            </p>
            <span class="text-sm text-zinc-200 group-hover:text-zinc-50 inline-flex items-center gap-2">
              See options
              <span aria-hidden="true">→</span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <Contact client:visible />
  </main>

  <Footer />
</Layout>
