---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Help Build the Future of Youth Sports Tracking | HUSTLE Survey">
  <div class="min-h-screen bg-zinc-900">
    <!-- Hero Section -->
    <section class="pt-8 pb-16 bg-gradient-main relative overflow-hidden">
      <div class="absolute w-96 h-96 bg-zinc-100/5 rounded-full blur-3xl top-0 right-0 -translate-y-1/2 translate-x-1/2" />

      <div class="container mx-auto px-8 relative z-10">
        <!-- Minimal Home Link - Top Left Corner -->
        <div class="absolute top-4 left-8">
          <a href="/" class="inline-flex items-center gap-1 text-xs text-zinc-400 hover:text-zinc-200 transition-colors">
            ← home
          </a>
        </div>

        <div class="max-w-4xl mx-auto text-center mt-8">
          <h1 class="text-hero font-extrabold text-zinc-50 mb-6">
            help us build the future of<br />youth sports tracking
          </h1>
          <p class="text-xl text-zinc-300 mb-12 leading-relaxed">
            share your experience as a sports parent—get 1 year free when we launch
          </p>

          <!-- Key Benefits Grid -->
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            <div class="card-slate text-center">
              <div class="text-4xl mb-3">⏱️</div>
              <p class="text-zinc-200 font-medium">8-10 minutes</p>
              <p class="text-sm text-zinc-400 mt-1">quick & easy</p>
            </div>

            <div class="card-slate text-center">
              <div class="text-4xl mb-3">💡</div>
              <p class="text-zinc-200 font-medium">your feedback</p>
              <p class="text-sm text-zinc-400 mt-1">shapes what we build</p>
            </div>

            <div class="card-slate text-center">
              <div class="text-4xl mb-3">🎁</div>
              <p class="text-zinc-200 font-medium">1 year free</p>
              <p class="text-sm text-zinc-400 mt-1">beta testers reward</p>
            </div>

            <div class="card-slate text-center">
              <div class="text-4xl mb-3">🔒</div>
              <p class="text-zinc-200 font-medium">fully private</p>
              <p class="text-sm text-zinc-400 mt-1">anonymous responses</p>
            </div>
          </div>

          <!-- CTA Button -->
          <a href="/survey/1" class="inline-block btn-primary text-lg px-8 py-4">
            start survey →
          </a>
        </div>
      </div>
    </section>

    <!-- What You'll Help Build Section -->
    <section class="py-16 bg-zinc-950">
      <div class="container mx-auto px-8">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-h2 font-bold text-zinc-50 mb-8 text-center">
            what you'll help us build
          </h2>

          <div class="space-y-6 text-zinc-300 text-lg leading-relaxed">
            <p>
              <strong class="text-zinc-100">HUSTLE</strong> is a youth sports tracking app designed for competitive athletes
              and their families. Think of it as a verified digital record of every game, practice, and training session—all
              in one place, regardless of sport.
            </p>

            <p>
              We're building this because sports parents told us tracking their kids' athletic journey is chaotic. Information
              is scattered across apps, screenshots, and memory. Stats are unverified. Progress is hard to measure.
            </p>

            <p class="text-zinc-100 font-medium">
              Your feedback will directly shape which features we build first, how the app works, and whether it actually
              solves the problems you face every week.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Section -->
    <section class="py-16 bg-zinc-900 border-t border-zinc-800">
      <div class="container mx-auto px-8 text-center">
        <p class="text-zinc-400 mb-4">
          join sports parents helping us build HUSTLE
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-sm text-zinc-500">
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">ECNL</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">MLS Next</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">AAU</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">USAG</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">Perfect Game</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">USSSA</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">USA Volleyball</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">ASA/USA Softball</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">High School Varsity</span>
          <span class="px-4 py-2 bg-zinc-800/50 rounded-lg">Travel Teams</span>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-16 bg-zinc-950">
      <div class="container mx-auto px-8 text-center">
        <h3 class="text-h2 font-bold text-zinc-50 mb-6">
          ready to share your experience?
        </h3>
        <p class="text-zinc-400 mb-8 text-lg">
          complete the survey and get early access to HUSTLE when we launch
        </p>
        <a href="/survey/1" class="inline-block btn-primary text-lg px-8 py-4">
          start survey →
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 bg-zinc-950 border-t border-zinc-800/50">
      <div class="container mx-auto px-8">
        <div class="max-w-4xl mx-auto text-center space-y-4">
          <p class="font-semibold text-zinc-50">intent solutions io</p>
          <p class="text-sm text-zinc-400">creating industries that don't exist</p>
          <p class="text-sm text-zinc-500">gulf shores, alabama</p>

          <div class="pt-6 flex justify-center gap-6 text-sm flex-wrap">
            <a
              href="mailto:jeremy@intentsolutions.io"
              class="text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              email
            </a>
            <a
              href="https://github.com/jeremylongshore"
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              github
            </a>
            <a
              href="https://jeremylongshore.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              portfolio
            </a>
            <a
              href="https://startaitools.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-200 transition-smooth"
            >
              blog
            </a>
          </div>

          <div class="pt-4 flex justify-center gap-6 text-xs">
            <a
              href="/terms"
              class="text-zinc-500 hover:text-zinc-300 transition-smooth"
            >
              terms of service
            </a>
            <a
              href="/privacy"
              class="text-zinc-500 hover:text-zinc-300 transition-smooth"
            >
              privacy policy
            </a>
          </div>

          <p class="text-xs text-zinc-600 pt-6">
            © 2025 intent solutions io. all rights reserved.
          </p>
        </div>
      </div>
    </footer>
  </div>
</Layout>
