# Environment Variables for Survey Email Function
# Copy this to .env for local development

# REQUIRED: Resend API Key (get from https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: Email address to send FROM
# Must be a verified domain in Resend
RESEND_FROM_EMAIL=thankyou@intentsolutions.io

# Optional: Override sender name
# RESEND_FROM_NAME=HUSTLE Team
